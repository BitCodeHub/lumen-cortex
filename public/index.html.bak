    <!-- Markdown parser for AI responses -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    
    <!-- Syntax highlighting for code -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

    <script>
        let currentScanId = null;
        let pollInterval = null;
        let currentScanMessageId = null;

        // ═══════════════════════════════════════════════════════════════════
        // AI CHAT & VOICE - Phase 1, 2, 3, 4 Implementation
        // ═══════════════════════════════════════════════════════════════════
        
        let sessionId = 'session-' + Date.now();
        let isVoiceOutputEnabled = false;
        let recognition = null;
        let isListening = false;
        let voiceSynth = window.speechSynthesis;

        // Initialize marked for markdown parsing
        if (typeof marked !== 'undefined') {
            marked.setOptions({
                highlight: function(code, lang) {
                    if (typeof hljs !== 'undefined' && lang && hljs.getLanguage(lang)) {
                        return hljs.highlight(code, { language: lang }).value;
                    }
                    return code;
                },
                breaks: true,
                gfm: true
            });
        }

        // Selected scan mode
        let selectedScanMode = null;

        // Select scan mode (Step 1)
        function selectScanMode(mode) {
            selectedScanMode = mode;
            
            // Update button styles
            const quickBtn = document.getElementById('quickModeBtn');
            const deepBtn = document.getElementById('deepModeBtn');
            const sendBtn = document.getElementById('sendBtn');
            const modeLabel = document.getElementById('selectedModeLabel');
            
            // Reset both buttons
            quickBtn.style.background = '#1a1a25';
            deepBtn.style.background = '#1a1a25';
            
            if (mode === 'full_attack') {
                quickBtn.style.background = '#00ff41';
                quickBtn.style.color = '#0a0a0f';
                deepBtn.style.color = '#ff6600';
                modeLabel.textContent = '⚡ Quick Scan';
                modeLabel.style.background = '#00ff41';
                modeLabel.style.color = '#0a0a0f';
            } else {
                deepBtn.style.background = '#ff6600';
                deepBtn.style.color = '#0a0a0f';
                quickBtn.style.color = '#00ff41';
                modeLabel.textContent = '🔬 Deep Scan';
                modeLabel.style.background = '#ff6600';
                modeLabel.style.color = '#0a0a0f';
            }
            
            // Enable scan button
            sendBtn.disabled = false;
            sendBtn.style.background = 'linear-gradient(135deg, #0abdc6, #00ff41)';
            sendBtn.style.color = '#0a0a0f';
            
            // Focus on input
            document.getElementById('userInput').focus();
        }

        // Start scan with selected mode (Step 2)
        async function startSelectedScan() {
            if (!selectedScanMode) {
                alert('Please select a scan mode first (Quick or Deep)');
                return;
            }
            
            // Reset to scan mode during active scanning
            currentMode = 'scan';
            
            const input = document.getElementById('userInput');
            let target = input.value.trim();
            
            if (!target) {
                alert('Please enter a target URL');
                input.focus();
                return;
            }
            
            // Ensure URL has protocol
            if (!target.startsWith('http')) {
                target = 'https://' + target;
            }
            
            // Run the scan
            await runScanMode(selectedScanMode);
        }

        // ═══════════════════════════════════════════════════════════════
        // 🧠 SMART INPUT HANDLING - Unified Chat & Tools
        // ═══════════════════════════════════════════════════════════════
        
        let currentInputMode = 'chat'; // 'chat', 'scan', 'network', 'github', etc.
        let inputContext = null; // Additional context for the current mode
        
        // Smart input handler - detects intent and routes appropriately
        function handleSmartInput(event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                handleSmartSend();
            }
        }
        
        // Smart send - routes based on input content and current mode
        async function handleSmartSend() {
            const input = document.getElementById('userInput');
            const text = input.value.trim();
            
            if (!text) return;
            
            // Check for pending AI feature input FIRST
            if (checkPendingAIFeature(text)) {
                input.value = '';
                return;
            }
            
            // Detect input type
            const isUrl = /^(https?:\/\/|[a-z0-9][-a-z0-9]*\.[a-z]{2,})/i.test(text);
            const isGithubUrl = /github\.com/i.test(text);
            const isNetworkCommand = /^(scan network|network scan|wifi scan|device scan|arp scan)/i.test(text);
            const isScanCommand = /^(scan|check|test|analyze|pentest|security)/i.test(text);
            
            // Route based on current mode or detected intent
            if (currentInputMode === 'scan' || (isUrl && !isGithubUrl && isScanCommand)) {
                // Web security scan
                await triggerWebScan(text);
            } else if (currentInputMode === 'network' || isNetworkCommand) {
                // Network scan
                await triggerNetworkScan(text);
            } else if (currentInputMode === 'github' || isGithubUrl) {
                // GitHub scan
                await triggerGithubScan(text);
            } else if (isUrl && !text.includes(' ')) {
                // Just a URL - ask what they want to do
                showUrlOptions(text);
            } else {
                // Default: send to AI chat
                await sendChatMessage();
            }
            
            // Clear context after action
            clearInputContext();
        }
        
        // Set input mode from chips or panel buttons
        function setInputMode(mode, context = null) {
            // Toggle: if same mode clicked again, clear it
            if (currentInputMode === mode) {
                clearInputContext();
                return;
            }
            currentInputMode = mode;
            inputContext = context;
            
            const input = document.getElementById('userInput');
            const contextDiv = document.getElementById('inputContext');
            const contextIcon = document.getElementById('contextIcon');
            const contextText = document.getElementById('contextText');
            
            // Update visual indicator
            contextDiv.style.display = 'block';
            
            const modeConfig = {
                'chat': { icon: '🤖', text: 'AI Chat - Ask anything', placeholder: 'Ask me anything...', color: '#0abdc6' },
                'scan': { icon: '🔍', text: 'Security Scan - Enter URL to scan', placeholder: 'Enter URL to scan (e.g., https://example.com)', color: '#00ff41' },
                'network': { icon: '🛡️', text: 'Network Guardian - WiFi security', placeholder: 'Type "scan" or ask about your network...', color: '#00ff41' },
                'github': { icon: '🐙', text: 'GitHub Scanner - Enter repo URL', placeholder: 'Enter GitHub URL or repo (user/repo)', color: '#8b5cf6' },
                'secrets': { icon: '🔑', text: 'Secret Hunter - Search for exposed keys', placeholder: 'Enter keyword or repo to search...', color: '#ff6600' }
            };
            
            const config = modeConfig[mode] || modeConfig.chat;
            contextIcon.textContent = config.icon;
            contextText.textContent = config.text;
            contextDiv.style.borderColor = config.color;
            input.placeholder = config.placeholder;
            input.focus();
            
            // Update chip styles
            document.querySelectorAll('.mode-chip').forEach(chip => {
                chip.style.background = chip.dataset.mode === mode ? '#0abdc6' : 'var(--bg-input)';
                chip.style.color = chip.dataset.mode === mode ? '#0a0a0f' : 'var(--text)';
            });
        }
        
        // Show input context indicator
        function showInputContext() {
            const contextDiv = document.getElementById('inputContext');
            if (currentInputMode !== 'chat') {
                contextDiv.style.display = 'block';
            }
        }
        
        // Track active prompt button
        let activePromptButton = null;
        
        // Clear input context
        function clearInputContext() {
            currentInputMode = 'chat';
            inputContext = null;
            activePromptButton = null;
            document.getElementById('inputContext').style.display = 'none';
            document.getElementById('userInput').value = '';
            document.getElementById('userInput').placeholder = 'Ask anything or enter a URL to scan...';
            
            // Reset chip styles
            document.querySelectorAll('.mode-chip').forEach(chip => {
                chip.style.background = 'var(--bg-input)';
                chip.style.color = 'var(--text)';
            });
            
            // Reset prompt button styles (Explain, Fix, Voice)
            document.querySelectorAll('.prompt-chip').forEach(chip => {
                chip.style.background = 'var(--bg-input)';
                chip.style.color = 'var(--text)';
            });
            
            // Restart typewriter animation
            startTypewriterAnimation(allSuggestions);
        }
        
        // Show options when user enters just a URL
        function showUrlOptions(url) {
            addMessage(`
                <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #0abdc6;">
                    <strong style="color: #0abdc6;">🔗 What would you like to do with ${url}?</strong>
                    <div style="display: flex; gap: 10px; margin-top: 15px; flex-wrap: wrap;">
                        <button onclick="triggerWebScan('${url}')" style="background: linear-gradient(135deg, #00ff41, #0abdc6); color: #0a0a0f; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                            🔍 Security Scan
                        </button>
                        <button onclick="triggerDeepScan('${url}')" style="background: #ff6600; color: #0a0a0f; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                            🔬 Deep Scan
                        </button>
                        <button onclick="addMonitoringUrl('${url}')" style="background: #1a1a25; color: #0abdc6; border: 1px solid #0abdc6; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                            📡 Monitor
                        </button>
                    </div>
                </div>
            `);
            document.getElementById('userInput').value = '';
        }
        
        // Trigger web security scan
        async function triggerWebScan(target) {
            if (!target.startsWith('http')) {
                target = 'https://' + target;
            }
            document.getElementById('userInput').value = '';
            addMessage(`🔍 Starting security scan on ${target}...`, true);
            
            // Use existing scan function
            selectedScanMode = 'full_attack';
            document.getElementById('userInput').value = target;
            await runScanMode('full_attack');
        }
        
        // Trigger deep scan
        async function triggerDeepScan(target) {
            if (!target.startsWith('http')) {
                target = 'https://' + target;
            }
            document.getElementById('userInput').value = '';
            addMessage(`🔬 Starting deep security scan on ${target}...`, true);
            
            selectedScanMode = 'deep_scan';
            document.getElementById('userInput').value = target;
            await runScanMode('deep_scan');
        }
        
        // Trigger network scan
        async function triggerNetworkScan(text) {
            document.getElementById('userInput').value = '';
            
            if (text.toLowerCase().includes('ai') || text.toLowerCase().includes('full') || text.toLowerCase().includes('deep')) {
                await scanNetworkFull();
            } else {
                await scanNetworkQuick();
            }
        }
        
        // Trigger GitHub scan
        async function triggerGithubScan(target) {
            document.getElementById('userInput').value = '';
            
            // Extract repo path
            let repo = target.replace(/https?:\/\/(www\.)?github\.com\//i, '').replace(/\/$/, '');
            
            addMessage(`🐙 Scanning GitHub repo: ${repo}...`, true);
            document.getElementById('githubRepoUrl').value = repo;
            await scanGitHubRepo();
        }
        
        // Add URL to monitoring
        function addMonitoringUrl(url) {
            document.getElementById('monitorUrl').value = url;
            document.getElementById('addMonitoringForm').style.display = 'block';
            addMonitoringSite();
        }
        
        // Insert prompt into input (toggleable)
        function insertPrompt(text, element = null) {
            const input = document.getElementById('userInput');
            
            // Toggle: if same prompt clicked again, clear it
            if (activePromptButton === text) {
                clearInputContext();
                return;
            }
            
            // Set active prompt
            activePromptButton = text;
            
            // Stop typewriter when inserting prompt
            stopTypewriterAnimation();
            
            // Reset other prompt chip styles
            document.querySelectorAll('.prompt-chip').forEach(chip => {
                chip.style.background = 'var(--bg-input)';
                chip.style.color = 'var(--text)';
            });
            
            // Highlight clicked chip if element provided
            if (element) {
                element.style.background = '#0abdc6';
                element.style.color = '#0a0a0f';
            }
            
            input.value = text;
            input.focus();
            // Trigger cursor to end
            input.setSelectionRange(text.length, text.length);
        }
        
        // Handle input keypress - legacy support
        function handleInputKeypress(event) {
            handleSmartInput(event);
        }

        // ═══════════════════════════════════════════════════════════════
        // 🔄 DYNAMIC UI MODE SWITCHING (Enterprise UX)
        // ═══════════════════════════════════════════════════════════════
        
        let currentMode = 'chat'; // 'scan', 'qa', 'chat'
        let typewriterInterval = null;
        let typewriterTimeout = null;
        
        // ═══════════════════════════════════════════════════════════════
        // ✨ TYPEWRITER PLACEHOLDER ANIMATION
        // ═══════════════════════════════════════════════════════════════
        
        const allSuggestions = [
            'Ask anything or enter a URL to scan...',
            'What vulnerabilities should I fix first?',
            'Scan https://example.com for security issues',
            'How do I protect against SQL injection?',
            'Explain the XSS findings',
            'Check my network for intruders',
            'What are the OWASP Top 10?',
            'Generate a security report',
        ];
        
        function startTypewriterAnimation(suggestions) {
            stopTypewriterAnimation();
            
            const input = document.getElementById('userInput');
            if (!input || input === document.activeElement) return;
            
            let suggestionIndex = 0;
            let charIndex = 0;
            let isDeleting = false;
            
            function animate() {
                if (input === document.activeElement) {
                    stopTypewriterAnimation();
                    return;
                }
                
                const currentSuggestion = suggestions[suggestionIndex];
                
                if (!isDeleting) {
                    charIndex++;
                    if (charIndex >= currentSuggestion.length) {
                        isDeleting = true;
                        typewriterTimeout = setTimeout(() => {
                            typewriterInterval = setTimeout(animate, 50);
                        }, 2000);
                        input.placeholder = currentSuggestion;
                        return;
                    }
                } else {
                    charIndex--;
                    if (charIndex <= 0) {
                        isDeleting = false;
                        suggestionIndex = (suggestionIndex + 1) % suggestions.length;
                        typewriterTimeout = setTimeout(() => {
                            typewriterInterval = setTimeout(animate, 100);
                        }, 500);
                        input.placeholder = '|';
                        return;
                    }
                }
                
                input.placeholder = currentSuggestion.substring(0, charIndex) + '|';
                typewriterInterval = setTimeout(animate, isDeleting ? 30 : 60);
            }
            
            typewriterTimeout = setTimeout(animate, 1000);
        }
        
        function stopTypewriterAnimation() {
            if (typewriterInterval) clearTimeout(typewriterInterval);
            if (typewriterTimeout) clearTimeout(typewriterTimeout);
            typewriterInterval = null;
            typewriterTimeout = null;
        }
        
        // Initialize on DOM ready
        document.addEventListener('DOMContentLoaded', () => {
            const input = document.getElementById('userInput');
            if (input) {
                input.addEventListener('focus', () => {
                    stopTypewriterAnimation();
                    if (currentInputMode === 'chat') {
                        input.placeholder = 'Ask anything or enter a URL to scan...';
                    }
                });
                
                input.addEventListener('blur', () => {
                    if (input.value === '' && currentInputMode === 'chat') {
                        setTimeout(() => startTypewriterAnimation(allSuggestions), 500);
                    }
                });
                
                // Start animation
                startTypewriterAnimation(allSuggestions);
            }
        });
        
        // Switch to Q&A mode after scan completes (legacy support)
        function switchToQAMode() {
            currentMode = 'qa';
            const input = document.getElementById('userInput');
            const btn = document.getElementById('sendBtn');
            
            // Start typewriter animation with Q&A suggestions
            if (input.value === '') {
                startTypewriterAnimation(qaSuggestions);
            }
            
            // Change button to "Ask Me"
            btn.innerHTML = '💬 Ask Me';
            btn.style.background = 'linear-gradient(135deg, #0abdc6, #00ff41)';
            btn.style.color = '#0a0a0f';
            btn.disabled = false;
            
            // Update button click handler
            btn.onclick = sendChatMessage;
            
            // Add visual indicator
            const modeLabel = document.getElementById('selectedModeLabel');
            if (modeLabel) {
                modeLabel.innerHTML = '🤖 <strong>AI Q&A Mode</strong> — Ask security questions';
                modeLabel.style.background = 'linear-gradient(135deg, #0abdc620, #00ff4120)';
                modeLabel.style.borderColor = '#00ff41';
                modeLabel.style.color = '#00ff41';
            }
            
            // Show helpful hints
            const hintsDiv = document.querySelector('.input-hints');
            if (hintsDiv) {
                hintsDiv.innerHTML = `
                    <span style="color: #00ff41; font-size: 11px;">✅ Scan complete! Try asking:</span>
                    <span onclick="insertPrompt('What are the critical vulnerabilities?')" style="cursor: pointer;">🔴 Critical</span>
                    <span onclick="insertPrompt('How do I fix these issues?')" style="cursor: pointer;">🔧 Remediation</span>
                    <span onclick="insertPrompt('Show OWASP mapping')" style="cursor: pointer;">📋 OWASP</span>
                    <span onclick="insertPrompt('Generate compliance report')" style="cursor: pointer;">📊 Compliance</span>
                    <span onclick="switchToScanMode()" style="cursor: pointer; color: #ff6600;">🔄 New Scan</span>
                `;
            }
            
            console.log('🔄 Switched to Q&A mode');
        }
        
        // Switch back to scan mode (for new scans)
        function switchToScanMode() {
            currentMode = 'scan';
            const input = document.getElementById('userInput');
            const btn = document.getElementById('sendBtn');
            
            // Reset to scan mode with typewriter animation
            input.value = '';
            startTypewriterAnimation(scanSuggestions);
            
            // Reset button
            btn.innerHTML = '🔍 SCAN';
            btn.style.background = '#333';
            btn.style.color = '#666';
            btn.disabled = true;
            btn.onclick = startSelectedScan;
            
            // Reset mode label
            const modeLabel = document.getElementById('selectedModeLabel');
            if (modeLabel) {
                modeLabel.innerHTML = 'No mode selected';
                modeLabel.style.background = '#2a2a3a';
                modeLabel.style.color = '#666';
            }
            
            // Reset hints
            const hintsDiv = document.querySelector('.input-hints');
            if (hintsDiv) {
                hintsDiv.innerHTML = `
                    <span style="color: #666; font-size: 11px;">After scan, ask me anything:</span>
                    <span onclick="insertPrompt('explain the findings')">💡 Explain</span>
                    <span onclick="insertPrompt('how to fix ')">🔧 Fix</span>
                    <span onclick="showOwaspMapping()">📋 OWASP</span>
                    <span onclick="toggleVoiceOutput()" id="voiceOutputToggle">🔊 Voice Off</span>
                `;
            }
            
            console.log('🔄 Switched to Scan mode');
        }

        // Main chat function - routes to scan or AI chat
        async function sendChatMessage() {
            const input = document.getElementById('userInput');
            const message = input.value.trim();
            if (!message) return;

            const btn = document.getElementById('sendBtn');
            btn.disabled = true;
            btn.textContent = '⏳';

            // Add user message to chat
            addMessage(message, true);
            input.value = '';

            // Check if this is a scan request
            const urlMatch = message.match(/(https?:\/\/[^\s]+|[a-z0-9][-a-z0-9]*\.[a-z]{2,})/i);
            const isScanRequest = /\b(scan|check|test|analyze|audit|security)\b/i.test(message) && urlMatch;

            if (isScanRequest) {
                // Route to security scan
                const target = urlMatch[0].startsWith('http') ? urlMatch[0] : 'https://' + urlMatch[0];
                await runSecurityScanWithChat(target, message);
            } else {
                // Route to AI chat
                await sendToAIChat(message);
            }

            btn.disabled = false;
            btn.textContent = '💬 SEND';
        }

        // Send message to AI chat backend
        async function sendToAIChat(message) {
            // Show typing indicator
            const typingId = addTypingIndicator();

            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message, sessionId })
                });

                const data = await response.json();
                
                // Remove typing indicator
                removeTypingIndicator(typingId);

                if (data.action === 'scan') {
                    // AI wants to trigger a scan
                    addMessage(data.message, false);
                    await runSecurityScanWithChat(data.target, message);
                } else {
                    // Regular AI response
                    addAIMessage(data.message);
                    
                    // Speak if voice output enabled
                    if (isVoiceOutputEnabled) {
                        speakText(data.message);
                    }
                }
            } catch (error) {
                removeTypingIndicator(typingId);
                addMessage(`❌ Error: ${error.message}`, false);
            }
        }

        // Track the current scan progress message
        let scanProgressMessageId = null;

        // Run security scan and attach to chat context
        async function runSecurityScanWithChat(target, originalMessage) {
            addMessage(`🔍 Starting security scan of **${target}**...`, false);

            try {
                // Run the scan
                const response = await fetch('/api/attack', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ target, attackType: 'full_attack' })
                });

                const data = await response.json();
                currentScanId = data.scanId;

                // Update stats
                document.getElementById('toolCount').textContent = data.toolCount || data.tools.length;
                document.getElementById('aiToolCount').textContent = data.aiToolCount || 0;

                // Update Active Tools panel
                const toolsWithInfo = data.tools.map(t => ({ tool: t, ai: false, status: 'running' }));
                updateToolList(toolsWithInfo);

                // Show risk panel
                document.getElementById('riskPanel').style.display = 'block';
                document.getElementById('riskIndicator').className = 'risk-indicator medium';
                document.getElementById('riskIndicator').textContent = 'SCANNING';

                // Store progress message ID so we can update it
                scanProgressMessageId = addMessage(`
                    <div style="border-left: 3px solid #0abdc6; padding-left: 15px;" id="scan-progress-content">
                        <strong style="color: #0abdc6;">🛡️ SECURITY SCAN IN PROGRESS</strong><br><br>
                        <strong>🎯 Target:</strong> ${target}<br>
                        <strong>🔧 Tools:</strong> ${data.toolCount || data.tools.length} selected<br>
                        <strong>⏳ Status:</strong> <span id="scan-status-text">Analyzing...</span><br><br>
                        <div class="typing-indicator" id="scan-typing-indicator">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                `, false);

                // Poll for completion
                await pollScanAndChat(data.scanId, target, data.toolCount || data.tools.length);

            } catch (error) {
                addMessage(`❌ Scan Error: ${error.message}`, false);
            }
        }

        // Poll scan status and trigger AI analysis when complete
        async function pollScanAndChat(scanId, target, toolCount) {
            return new Promise((resolve) => {
                const poll = setInterval(async () => {
                    try {
                        const response = await fetch(`/api/attack/${scanId}`);
                        const data = await response.json();

                        // Update tool list with current status
                        if (data.results && data.results.length > 0) {
                            updateToolList(data.results);
                        } else if (data.tools) {
                            updateToolList(data.tools.map(t => ({ tool: t, status: 'running' })));
                        }

                        if (data.status === 'complete') {
                            clearInterval(poll);

                            // Update stats
                            document.getElementById('findingCount').textContent = data.totalVulns || 0;
                            document.getElementById('scanTime').textContent = `${Math.round(data.duration)}s`;

                            // Update risk indicator
                            const riskLevel = data.analysis?.riskLevel || 'LOW';
                            document.getElementById('riskIndicator').className = `risk-indicator ${riskLevel.toLowerCase()}`;
                            document.getElementById('riskIndicator').textContent = riskLevel;

                            // Final tool list update with completion status
                            if (data.results) {
                                updateToolList(data.results.map(r => ({ ...r, status: r.status || 'success' })));
                            }

                            // Update the progress message to show COMPLETE
                            const progressContent = document.getElementById('scan-progress-content');
                            if (progressContent) {
                                const riskColor = data.analysis?.riskLevel === 'CRITICAL' ? '#ff0040' : 
                                                  data.analysis?.riskLevel === 'HIGH' ? '#ff4444' : 
                                                  data.analysis?.riskLevel === 'MEDIUM' ? '#ffaa00' : '#00ff41';
                                progressContent.innerHTML = `
                                    <strong style="color: #00ff41;">✅ SECURITY SCAN COMPLETE</strong><br><br>
                                    <strong>🎯 Target:</strong> ${target}<br>
                                    <strong>🔧 Tools Used:</strong> ${toolCount}<br>
                                    <strong>⏱️ Duration:</strong> ${Math.round(data.duration)}s<br>
                                    <strong>🔍 Findings:</strong> <span style="color: ${riskColor}; font-weight: bold;">${data.totalVulns || 0}</span><br>
                                    <strong>📊 Risk Level:</strong> <span style="color: ${riskColor}; font-weight: bold;">${data.analysis?.riskLevel || 'Unknown'}</span><br><br>
                                    <button onclick="generateAIReport()" style="background: linear-gradient(135deg, #00ff41, #0abdc6); border: none; padding: 10px 20px; border-radius: 6px; color: #0a0a0f; font-weight: bold; cursor: pointer; font-family: inherit;">
                                        📋 Generate Full Report
                                    </button>
                                `;
                                progressContent.style.borderColor = riskColor;
                            }

                            // Attach scan to chat session
                            const attachResponse = await fetch('/api/chat/attach-scan', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ sessionId, scanId })
                            });

                            const attachData = await attachResponse.json();

                            // Show AI analysis
                            addAIMessage(attachData.analysis || 'Scan complete! Ask me anything about the findings, or click "Generate Full Report" above.');

                            // Speak summary if voice enabled
                            if (isVoiceOutputEnabled && attachData.analysis) {
                                speakText(attachData.analysis);
                            }

                            // 🔄 DYNAMIC UI CHANGE: Switch to Q&A mode after scan completes
                            switchToQAMode();

                            resolve();
                        }
                    } catch (error) {
                        console.error('Poll error:', error);
                    }
                }, 2000);
            });
        }

        // Add AI message with markdown formatting
        function addAIMessage(content) {
            const messagesDiv = document.querySelector('.chat-messages');
            const messageDiv = document.createElement('div');
            messageDiv.className = 'message ai';
            
            // Parse markdown
            let htmlContent = content;
            if (typeof marked !== 'undefined') {
                htmlContent = marked.parse(content);
            }

            messageDiv.innerHTML = `
                <div class="message-label">🤖 Neo</div>
                <div class="message-content">${htmlContent}</div>
            `;

            messagesDiv.appendChild(messageDiv);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;

            // Apply syntax highlighting
            if (typeof hljs !== 'undefined') {
                messageDiv.querySelectorAll('pre code').forEach((block) => {
                    hljs.highlightElement(block);
                });
            }
        }

        // Add typing indicator
        function addTypingIndicator() {
            const messagesDiv = document.querySelector('.chat-messages');
            const id = 'typing-' + Date.now();
            const div = document.createElement('div');
            div.id = id;
            div.className = 'message ai';
            div.innerHTML = `
                <div class="message-label">🤖 Neo</div>
                <div class="message-content">
                    <div class="typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            `;
            messagesDiv.appendChild(div);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
            return id;
        }

        // Remove typing indicator
        function removeTypingIndicator(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }

        // ═══════════════════════════════════════════════════════════════════
        // PHASE 3: VOICE INPUT/OUTPUT
        // ═══════════════════════════════════════════════════════════════════

        // Initialize speech recognition
        function initVoiceInput() {
            if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                recognition = new SpeechRecognition();
                recognition.continuous = false;
                recognition.interimResults = true;
                recognition.lang = 'en-US';

                recognition.onstart = () => {
                    isListening = true;
                    document.getElementById('voiceBtn').classList.add('listening');
                    document.getElementById('voiceBtn').textContent = '🔴';
                };

                recognition.onend = () => {
                    isListening = false;
                    document.getElementById('voiceBtn').classList.remove('listening');
                    document.getElementById('voiceBtn').textContent = '🎤';
                };

                recognition.onresult = (event) => {
                    const transcript = Array.from(event.results)
                        .map(result => result[0].transcript)
                        .join('');
                    
                    document.getElementById('userInput').value = transcript;

                    // If final result, send the message
                    if (event.results[event.results.length - 1].isFinal) {
                        setTimeout(() => sendChatMessage(), 500);
                    }
                };

                recognition.onerror = (event) => {
                    console.error('Speech recognition error:', event.error);
                    isListening = false;
                    document.getElementById('voiceBtn').classList.remove('listening');
                    document.getElementById('voiceBtn').textContent = '🎤';
                    
                    // User-friendly error messages
                    const errorMessages = {
                        'not-allowed': '❌ Microphone permission denied. Click the lock icon in the address bar to allow.',
                        'no-speech': '🔇 No speech detected. Try speaking louder or closer to the mic.',
                        'audio-capture': '❌ No microphone found. Please connect a microphone.',
                        'network': '❌ Network error. Check your internet connection.',
                        'aborted': '🎤 Voice input cancelled.',
                        'service-not-allowed': '❌ Speech service not allowed. Make sure you\'re on HTTPS or localhost.'
                    };
                    
                    const msg = errorMessages[event.error] || `❌ Voice error: ${event.error}`;
                    if (event.error !== 'aborted') {
                        addMessage(msg, false);
                    }
                };

                console.log('✅ Voice input initialized');
            } else {
                console.log('❌ Speech recognition not supported');
                document.getElementById('voiceBtn').style.display = 'none';
            }
        }

        // Toggle voice input
        function toggleVoiceInput() {
            if (!recognition) {
                initVoiceInput();
                if (!recognition) {
                    addMessage('❌ Voice input not supported in this browser. Try Chrome or Edge.', false);
                    return;
                }
            }

            if (isListening) {
                recognition.stop();
            } else {
                try {
                    recognition.start();
                    addMessage('🎤 Listening... Speak now!', false);
                } catch (e) {
                    console.error('Voice error:', e);
                    if (e.message.includes('not-allowed')) {
                        addMessage('❌ Microphone permission denied. Please allow microphone access in your browser settings.', false);
                    } else {
                        addMessage(`❌ Voice error: ${e.message}. Make sure you\'re using HTTPS or localhost.`, false);
                    }
                }
            }
        }

        // Toggle voice output
        function toggleVoiceOutput() {
            isVoiceOutputEnabled = !isVoiceOutputEnabled;
            const toggle = document.getElementById('voiceOutputToggle');
            toggle.textContent = isVoiceOutputEnabled ? '🔊 Voice On' : '🔊 Voice Off';
            toggle.classList.toggle('active', isVoiceOutputEnabled);
        }

        // Speak text using Web Speech API (fallback) or ElevenLabs
        function speakText(text) {
            // Strip markdown for speech
            const plainText = text
                .replace(/```[\s\S]*?```/g, 'code block omitted')
                .replace(/`[^`]+`/g, '')
                .replace(/\*\*([^*]+)\*\*/g, '$1')
                .replace(/\*([^*]+)\*/g, '$1')
                .replace(/#{1,6}\s/g, '')
                .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
                .replace(/[🔴🟠🟡🟢📍🔧🚨💡🎯🛡️⚠️✅❌]/g, '')
                .slice(0, 500); // Limit length for speech

            // Use Web Speech API
            if (voiceSynth) {
                voiceSynth.cancel(); // Stop any current speech
                const utterance = new SpeechSynthesisUtterance(plainText);
                utterance.rate = 1.0;
                utterance.pitch = 1.0;
                voiceSynth.speak(utterance);
            }
        }

        // ═══════════════════════════════════════════════════════════════════
        // PHASE 4: ADVANCED FEATURES
        // ═══════════════════════════════════════════════════════════════════

        // Show OWASP mapping
        async function showOwaspMapping() {
            const btn = document.getElementById('sendBtn');
            btn.disabled = true;

            addMessage('📋 Generate OWASP Top 10 mapping for current findings', true);
            
            const typingId = addTypingIndicator();

            try {
                const response = await fetch('/api/chat/owasp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sessionId })
                });

                const data = await response.json();
                removeTypingIndicator(typingId);

                if (data.error) {
                    addMessage(`⚠️ ${data.error}. Run a scan first!`, false);
                } else {
                    addAIMessage(data.message);
                }
            } catch (error) {
                removeTypingIndicator(typingId);
                addMessage(`❌ Error: ${error.message}`, false);
            }

            btn.disabled = false;
        }

        // Generate ticket
        async function generateTicket(format = 'github') {
            addMessage(`🎫 Generate ${format === 'jira' ? 'Jira' : 'GitHub'} ticket for findings`, true);
            
            const typingId = addTypingIndicator();

            try {
                const response = await fetch('/api/chat/ticket', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sessionId, format })
                });

                const data = await response.json();
                removeTypingIndicator(typingId);

                if (data.error) {
                    addMessage(`⚠️ ${data.error}`, false);
                } else {
                    addAIMessage(data.message);
                }
            } catch (error) {
                removeTypingIndicator(typingId);
                addMessage(`❌ Error: ${error.message}`, false);
            }
        }

        // Clear conversation
        async function clearConversation() {
            try {
                await fetch('/api/chat/clear', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sessionId })
                });

                // Clear UI
                const messagesDiv = document.querySelector('.chat-messages');
                messagesDiv.innerHTML = `
                    <div class="message ai">
                        <div class="message-label">🤖 Neo</div>
                        <div class="message-content">
                            <strong>Welcome to Lumen Cortex AI Security Assistant!</strong><br><br>
                            I can help you:<br>
                            • <strong>Scan websites</strong> - "scan example.com"<br>
                            • <strong>Explain findings</strong> - "what is this XSS vulnerability?"<br>
                            • <strong>Recommend fixes</strong> - "how do I fix SQL injection?"<br>
                            • <strong>Generate tickets</strong> - "create a GitHub issue"<br>
                            • <strong>Map to standards</strong> - "show OWASP mapping"<br><br>
                            🎤 Use voice input or type your question below!
                        </div>
                    </div>
                `;

                // Reset session
                sessionId = 'session-' + Date.now();

            } catch (error) {
                console.error('Clear error:', error);
            }
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', () => {
            initVoiceInput();
            
            // Show welcome message
            const messagesDiv = document.querySelector('.chat-messages');
            if (messagesDiv.children.length === 0) {
                messagesDiv.innerHTML = `
                    <div class="message ai">
                        <div class="message-label">🤖 Neo</div>
                        <div class="message-content">
                            <div style="background: linear-gradient(135deg, rgba(0,255,65,0.1), rgba(10,189,198,0.1)); border: 1px solid var(--primary); border-radius: 8px; padding: 15px; margin-bottom: 15px;">
                                <strong style="font-size: 1.1em;">👋 Welcome to Lumen Cortex!</strong><br>
                                <span style="color: #0abdc6;">I'm Neo — your AI Cybersecurity Expert & Code Expert</span>
                            </div>
                            
                            <strong style="color: #00ff41;">💻 CODING ASSISTANT</strong><br>
                            <div style="margin: 8px 0 12px 0; padding-left: 10px; border-left: 2px solid #00ff41;">
                                • <strong>Paste any code</strong> → I'll explain what it does<br>
                                • <strong>"Review this"</strong> → Get tech lead code review<br>
                                • <strong>"Continue this"</strong> → I'll complete your code<br>
                                • <strong>"Fix this"</strong> → I'll debug and improve it<br>
                                • <strong>Ask me to build anything</strong> → I'll write the code
                            </div>
                            
                            <strong style="color: #0abdc6;">🛡️ SECURITY SCANNING</strong><br>
                            <div style="margin: 8px 0 12px 0; padding-left: 10px; border-left: 2px solid #0abdc6;">
                                • Enter a URL → Run DAST/SAST scans<br>
                                • Ask about vulnerabilities<br>
                                • Get remediation code
                            </div>
                            
                            <div style="background: rgba(0,0,0,0.3); padding: 10px; border-radius: 6px; margin-top: 10px;">
                                <strong style="color: #ffaa00;">⚡ Try it now:</strong> Paste some code below or ask me anything!
                            </div>
                        </div>
                    </div>
                `;
            }
            
            // Start typewriter placeholder animation
            startPlaceholderAnimation();
        });

        // ═══════════════════════════════════════════════════════════════════
        // END AI CHAT IMPLEMENTATION
        // ═══════════════════════════════════════════════════════════════════

        // Matrix rain effect
        const canvas = document.getElementById('matrix');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        
        const chars = 'LUMEN CORTEX0123456789ABCDEF';
        const fontSize = 14;
        const columns = canvas.width / fontSize;
        const drops = Array(Math.floor(columns)).fill(1);
        
        function drawMatrix() {
            ctx.fillStyle = 'rgba(10, 10, 15, 0.05)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#00ff41';
            ctx.font = fontSize + 'px monospace';
            
            for (let i = 0; i < drops.length; i++) {
                const text = chars[Math.floor(Math.random() * chars.length)];
                ctx.fillText(text, i * fontSize, drops[i] * fontSize);
                if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) {
                    drops[i] = 0;
                }
                drops[i]++;
            }
        }
        setInterval(drawMatrix, 50);

        function addMessage(content, isUser = false, messageId = null) {
            const messages = document.getElementById('chatMessages');
            
            // If messageId provided, try to update existing message
            if (messageId) {
                const existing = document.getElementById(messageId);
                if (existing) {
                    existing.querySelector('.message-content').innerHTML = processCodeBlocks(content, !isUser);
                    messages.scrollTop = messages.scrollHeight;
                    return messageId;
                }
            }
            
            // Create new message
            const div = document.createElement('div');
            const newId = messageId || 'msg-' + Date.now();
            div.id = newId;
            div.className = `message ${isUser ? 'user' : 'ai'}`;
            
            // Process code blocks in AI responses to add download buttons
            const processedContent = processCodeBlocks(content, !isUser);
            
            div.innerHTML = `
                <div class="message-label">${isUser ? 'You' : '🤖 Neo'}</div>
                <div class="message-content">${processedContent}</div>
            `;
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
            return newId;
        }
        
        // Process code blocks and add interactive buttons
        function processCodeBlocks(content, addButtons = false) {
            if (!addButtons) return content;
            
            // Match code blocks with optional language
            const codeBlockRegex = /```(\w+)?\n([\s\S]*?)```/g;
            let blockIndex = 0;
            
            return content.replace(codeBlockRegex, (match, lang, code) => {
                const blockId = 'code-block-' + Date.now() + '-' + blockIndex++;
                const language = lang || 'text';
                const escapedCode = code.trim();
                
                // Determine suggested filename based on language
                const langToExt = {
                    'javascript': 'js', 'typescript': 'ts', 'python': 'py', 'java': 'java',
                    'cpp': 'cpp', 'c': 'c', 'csharp': 'cs', 'go': 'go', 'rust': 'rs',
                    'ruby': 'rb', 'php': 'php', 'swift': 'swift', 'kotlin': 'kt',
                    'html': 'html', 'css': 'css', 'scss': 'scss', 'json': 'json',
                    'yaml': 'yaml', 'yml': 'yml', 'xml': 'xml', 'sql': 'sql',
                    'bash': 'sh', 'shell': 'sh', 'markdown': 'md', 'md': 'md'
                };
                const ext = langToExt[language.toLowerCase()] || 'txt';
                const suggestedName = `code.${ext}`;
                
                // Store code for later download
                window.codeBlocks = window.codeBlocks || {};
                window.codeBlocks[blockId] = { code: escapedCode, language, suggestedName };
                
                return `
                    <div class="code-block-container" style="position: relative; margin: 10px 0;">
                        <div style="display: flex; justify-content: space-between; align-items: center; background: #1a1a25; padding: 6px 10px; border-radius: 6px 6px 0 0; border: 1px solid #2a2a3a; border-bottom: none;">
                            <span style="color: #0abdc6; font-size: 0.8em;">${language}</span>
                            <div style="display: flex; gap: 6px;">
                                <button onclick="copyCodeBlock('${blockId}')" style="background: none; border: 1px solid #666; color: #888; padding: 3px 8px; border-radius: 4px; cursor: pointer; font-size: 0.75em;" title="Copy code">📋 Copy</button>
                                <button onclick="downloadCodeBlock('${blockId}')" style="background: none; border: 1px solid #00ff41; color: #00ff41; padding: 3px 8px; border-radius: 4px; cursor: pointer; font-size: 0.75em;" title="Download file">💾 Download</button>
                                <button onclick="applyCodeBlock('${blockId}')" style="background: linear-gradient(135deg, #00ff41, #0abdc6); border: none; color: #0a0a0f; padding: 3px 8px; border-radius: 4px; cursor: pointer; font-size: 0.75em; font-weight: bold;" title="Apply changes">✨ Apply</button>
                            </div>
                        </div>
                        <pre style="background: #0a0a0f; padding: 12px; margin: 0; border-radius: 0 0 6px 6px; border: 1px solid #2a2a3a; overflow-x: auto; font-size: 0.85em;"><code>${escapeHtml(escapedCode)}</code></pre>
                    </div>
                `;
            });
        }
        
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // Copy code block to clipboard
        function copyCodeBlock(blockId) {
            const block = window.codeBlocks?.[blockId];
            if (!block) return;
            
            navigator.clipboard.writeText(block.code).then(() => {
                addMessage('📋 Code copied to clipboard!', false);
            }).catch(err => {
                console.error('Copy failed:', err);
            });
        }
        
        // Download code block as file
        function downloadCodeBlock(blockId) {
            const block = window.codeBlocks?.[blockId];
            if (!block) return;
            
            const filename = prompt('Save as:', block.suggestedName);
            if (!filename) return;
            
            const blob = new Blob([block.code], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            addMessage(`💾 Downloaded: ${filename}`, false);
        }
        
        // Apply code changes (replaces attached file or asks for filename)
        function applyCodeBlock(blockId) {
            const block = window.codeBlocks?.[blockId];
            if (!block) return;
            
            // If there was an attached file, offer to save with same name
            const originalName = attachedFile?.name;
            const filename = prompt('Save modified file as:', originalName || block.suggestedName);
            if (!filename) return;
            
            const blob = new Blob([block.code], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            addMessage(`✨ Applied changes and saved: ${filename}`, false);
        }
        
        // ═══════════════════════════════════════════════════════════════
        // 🐛 AI DEBUGGER - Comprehensive Code Analysis System
        // ═══════════════════════════════════════════════════════════════
        
        let debugFileContent = null;
        let debugFileName = null;
        let selectedDebugType = 'all';
        
        // Select debug analysis type
        function selectDebugType(type) {
            selectedDebugType = type;
            document.querySelectorAll('.debug-type-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.dataset.type === type) {
                    btn.classList.add('active');
                }
            });
        }
        
        // Initialize default selection
        setTimeout(() => selectDebugType('all'), 100);
        
        // Handle debug file drop
        function handleDebugFileDrop(event) {
            event.preventDefault();
            const uploadArea = document.getElementById('debugFileUploadArea');
            uploadArea.style.borderColor = '#e91e63';
            uploadArea.style.background = 'transparent';
            
            const file = event.dataTransfer.files[0];
            if (file) {
                handleDebugFileUpload(file);
            }
        }
        
        // Handle debug file upload
        async function handleDebugFileUpload(file) {
            if (!file) return;
            
            debugFileName = file.name;
            
            try {
                debugFileContent = await readFileAsText(file);
                
                // Show file info
                document.getElementById('debugFileInfo').style.display = 'block';
                document.getElementById('debugFileName').textContent = `📄 ${file.name} (${formatFileSize(file.size)})`;
                
                // Auto-populate code input
                document.getElementById('debugCodeInput').value = debugFileContent;
                
            } catch (e) {
                addMessage(`❌ Could not read file: ${e.message}`, false);
            }
        }
        
        // Clear debug file
        function clearDebugFile() {
            debugFileContent = null;
            debugFileName = null;
            document.getElementById('debugFileInfo').style.display = 'none';
            document.getElementById('debugFileInput').value = '';
        }
        
        // Quick debug prompt
        function quickDebugPrompt(prompt) {
            document.getElementById('debugErrorInput').value = prompt;
            runAIDebugger();
        }
        
        // Run the AI Debugger
        async function runAIDebugger() {
            const codeInput = document.getElementById('debugCodeInput').value.trim();
            const errorInput = document.getElementById('debugErrorInput').value.trim();
            const explainFix = document.getElementById('debugExplainFix').checked;
            const showFixed = document.getElementById('debugShowFixed').checked;
            const bestPractices = document.getElementById('debugBestPractices').checked;
            
            if (!codeInput && !debugFileContent) {
                addMessage('❌ Please paste code or upload a file to debug.', false);
                return;
            }
            
            const code = codeInput || debugFileContent;
            const fileName = debugFileName || 'code snippet';
            
            // Build the debug analysis prompt
            let analysisType = '';
            switch (selectedDebugType) {
                case 'bugs':
                    analysisType = 'Focus on finding BUGS, ERRORS, and LOGIC ISSUES.';
                    break;
                case 'security':
                    analysisType = 'Focus on SECURITY VULNERABILITIES, including OWASP Top 10, injection flaws, authentication issues, data exposure, etc.';
                    break;
                case 'all':
                default:
                    analysisType = 'Perform COMPREHENSIVE analysis: bugs, security vulnerabilities, performance issues, code quality problems, and potential improvements.';
            }
            
            let requirements = [];
            if (explainFix) requirements.push('Explain each issue and fix in plain English that anyone can understand');
            if (showFixed) requirements.push('Provide the COMPLETE fixed code at the end (not just snippets)');
            if (bestPractices) requirements.push('Include best practices and recommendations for improvement');
            
            const debugPrompt = `
🐛 **AI DEBUGGER REQUEST**

**File:** ${fileName}
**Analysis Type:** ${selectedDebugType.toUpperCase()}

${errorInput ? `**Error/Issue Description:**
\`\`\`
${errorInput}
\`\`\`

` : ''}**Code to Analyze:**
\`\`\`
${code.slice(0, 50000)}${code.length > 50000 ? '\n... (truncated)' : ''}
\`\`\`

**Instructions:**
${analysisType}

**Requirements:**
${requirements.map(r => `• ${r}`).join('\n')}

**Please provide your analysis in this format:**

## 🔍 Issues Found

For each issue:
### [SEVERITY EMOJI] Issue #N: [Issue Title]
- **Type:** Bug / Security / Performance / Code Quality
- **Line(s):** [line numbers if applicable]
- **Problem:** [Clear explanation of what's wrong]
- **Impact:** [What could go wrong if not fixed]
- **Fix:** [How to fix it]

## 🔧 Quick Fixes Summary
[Bullet list of all fixes needed]

${showFixed ? `## ✅ Complete Fixed Code
[The entire code with all issues fixed]` : ''}

${bestPractices ? `## 💡 Best Practices & Recommendations
[Additional tips for improvement]` : ''}
`;

            // Show user message
            addMessage(`🐛 <strong>AI Debugger:</strong> Analyzing ${fileName}...<br>
                <span style="color: #888; font-size: 0.9em;">Analysis type: ${selectedDebugType.toUpperCase()}</span>`, true);
            
            // Send to chat
            document.getElementById('userInput').value = debugPrompt;
            
            // Trigger send
            const sendBtn = document.getElementById('sendBtn');
            sendBtn.click();
            
            // Clear inputs after sending
            document.getElementById('debugCodeInput').value = '';
            document.getElementById('debugErrorInput').value = '';
            clearDebugFile();
        }

        function updateToolList(tools) {
            const list = document.getElementById('toolList');
            list.innerHTML = tools.map(t => {
                const name = t.name || t.tool || t;
                const isAI = t.ai || false;
                const status = t.status || 'pending';
                return `
                    <div class="tool-item ${isAI ? 'ai-powered' : ''}">
                        <div class="tool-status ${status}"></div>
                        <span>${name}</span>
                        ${isAI ? '<span class="ai-badge">AI</span>' : ''}
                    </div>
                `;
            }).join('');
            document.getElementById('toolCount').textContent = tools.length;
        }

        function updateRisk(level) {
            const panel = document.getElementById('riskPanel');
            const indicator = document.getElementById('riskIndicator');
            panel.style.display = 'block';
            indicator.className = `risk-indicator ${level}`;
            indicator.textContent = level.toUpperCase() + ' RISK';
        }

        async function startScan() {
            const input = document.getElementById('userInput');
            const request = input.value.trim();
            if (!request) return;

            const btn = document.getElementById('sendBtn');
            btn.disabled = true;
            btn.textContent = 'SCANNING...';

            addMessage(request, true);
            input.value = '';

            // Extract target from request
            const urlMatch = request.match(/(https?:\/\/[^\s]+|[a-z0-9][-a-z0-9]*\.[a-z]{2,})/i);
            const target = urlMatch ? urlMatch[0] : request.split(' ').pop();

            try {
                const response = await fetch('/api/scan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ request, target })
                });
                
                const data = await response.json();
                currentScanId = data.scanId;

                // Show progress panel, hide report panel
                document.getElementById('scanProgressPanel').style.display = 'block';
                document.getElementById('aiReportPanel').style.display = 'none';
                document.getElementById('scanToolsProgress').textContent = `0/${data.totalTools} tools`;
                document.getElementById('scanProgressBar').style.width = '0%';
                window.scanStartTime = Date.now();
                window.scanTotalTools = data.totalTools;

                currentScanMessageId = addMessage(`
                    <strong>🎯 Target:</strong> ${target}<br>
                    <strong>🔧 Tools:</strong> ${data.totalTools} selected (${data.aiToolCount} AI-powered)<br>
                    <strong>🧠 Strategy:</strong> ${data.reason}<br>
                    <strong>📊 Scan Type:</strong> ${data.scanType.toUpperCase()}<br><br>
                    <div class="loading">
                        <span>AI-Powered Scan in Progress</span>
                        <div class="loading-bar"><div class="loading-progress"></div></div>
                    </div>
                `);

                // Map tools with AI info
                const toolsWithInfo = data.tools.map(t => {
                    const aiTools = ['snyk', 'semgrep', 'gitguardian', 'socket', 'codeql', 'bearer'];
                    return { tool: t, ai: aiTools.includes(t), status: 'running' };
                });
                updateToolList(toolsWithInfo);
                updateRisk(data.riskLevel);
                document.getElementById('aiToolCount').textContent = data.aiToolCount;

                // Start polling
                pollInterval = setInterval(pollScanStatus, 2000);
            } catch (err) {
                addMessage(`❌ Error: ${err.message}`);
                btn.disabled = false;
                btn.textContent = 'SCAN';
            }
        }

        async function pollScanStatus() {
            if (!currentScanId) return;

            try {
                const response = await fetch(`/api/scan/${currentScanId}`);
                const data = await response.json();

                updateToolList(data.results.length ? data.results : data.tools.map(t => ({ tool: t, status: 'running' })));

                // Update progress panel
                const completedTools = data.results ? data.results.filter(r => r.status === 'complete' || r.status === 'error').length : 0;
                const totalTools = window.scanTotalTools || data.tools?.length || 1;
                const progress = Math.round((completedTools / totalTools) * 100);
                document.getElementById('scanProgressBar').style.width = `${progress}%`;
                document.getElementById('scanToolsProgress').textContent = `${completedTools}/${totalTools} tools`;
                const elapsed = Math.round((Date.now() - (window.scanStartTime || Date.now())) / 1000);
                document.getElementById('scanElapsedTime').textContent = `${elapsed}s`;
                document.getElementById('scanProgressStatus').textContent = data.results?.length > 0 
                    ? `Running: ${data.results.filter(r => r.status === 'running').map(r => r.tool).join(', ') || 'Finalizing...'}`
                    : 'Starting security tools...';

                if (data.status === 'complete') {
                    clearInterval(pollInterval);
                    
                    // Hide progress, show report panel
                    document.getElementById('scanProgressPanel').style.display = 'none';
                    document.getElementById('aiReportPanel').style.display = 'block';
                    
                    // Count findings
                    let totalFindings = 0;
                    data.results.forEach(r => {
                        if (r.findingsCount) totalFindings += r.findingsCount;
                    });
                    document.getElementById('findingCount').textContent = totalFindings;
                    document.getElementById('scanTime').textContent = `${Math.round(data.duration)}s`;

                    // Build comprehensive results with AI analysis
                    let resultHtml = '';
                    
                    // AI Analysis Summary (if available)
                    if (data.analysis) {
                        const a = data.analysis;
                        const riskColors = {
                            'CRITICAL': '#ff0040',
                            'HIGH': '#ff4444',
                            'MEDIUM': '#ffaa00',
                            'LOW': '#00ff41'
                        };
                        const riskColor = riskColors[a.riskLevel] || '#00ff41';
                        
                        resultHtml += `<div style="background: linear-gradient(135deg, rgba(0,0,0,0.4), rgba(${a.riskLevel === 'CRITICAL' ? '255,0,64' : a.riskLevel === 'HIGH' ? '255,68,68' : a.riskLevel === 'MEDIUM' ? '255,170,0' : '0,255,65'},0.1)); border: 1px solid ${riskColor}; border-radius: 12px; padding: 15px; margin-bottom: 15px;">`;
                        
                        // Risk Score Header
                        resultHtml += `<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">`;
                        resultHtml += `<span style="font-size: 1.2em; font-weight: bold;">🤖 AI Security Analysis</span>`;
                        resultHtml += `<span style="background: ${riskColor}; color: #000; padding: 5px 15px; border-radius: 20px; font-weight: bold; font-size: 0.9em;">${a.riskLevel} RISK</span>`;
                        resultHtml += `</div>`;
                        
                        // Risk Score Bar
                        resultHtml += `<div style="background: rgba(0,0,0,0.3); border-radius: 10px; height: 20px; margin: 10px 0; overflow: hidden;">`;
                        resultHtml += `<div style="background: linear-gradient(90deg, #00ff41, #ffaa00, #ff0040); width: ${a.riskScore}%; height: 100%; transition: width 0.5s;"></div>`;
                        resultHtml += `</div>`;
                        resultHtml += `<div style="text-align: center; font-size: 0.8em; color: #888;">Risk Score: ${a.riskScore}/100</div>`;
                        
                        // Summary
                        resultHtml += `<div style="margin: 15px 0; padding: 10px; background: rgba(0,0,0,0.2); border-radius: 8px;">`;
                        resultHtml += `<strong>${a.summary}</strong>`;
                        resultHtml += `</div>`;
                        
                        // Critical Findings
                        if (a.criticalFindings && a.criticalFindings.length > 0) {
                            resultHtml += `<div style="margin-top: 15px;"><strong style="color: #ff0040;">🚨 Critical Findings:</strong></div>`;
                            for (const finding of a.criticalFindings.slice(0, 8)) {
                                const fColor = finding.severity === 'CRITICAL' ? '#ff0040' : finding.severity === 'HIGH' ? '#ff4444' : finding.severity === 'INFO' ? '#0abdc6' : '#ffaa00';
                                resultHtml += `<div style="margin: 5px 0; padding: 8px; background: rgba(0,0,0,0.2); border-left: 3px solid ${fColor}; border-radius: 4px;">`;
                                resultHtml += `<span style="color: ${fColor}; font-size: 0.75em; font-weight: bold;">[${finding.severity}]</span> `;
                                resultHtml += `<strong>${finding.finding}</strong>`;
                                if (finding.details && Array.isArray(finding.details) && finding.details.length > 0) {
                                    resultHtml += `<div style="color: #888; font-size: 0.8em; margin-top: 3px;">`;
                                    resultHtml += finding.details.slice(0, 3).join('<br>');
                                    if (finding.details.length > 3) resultHtml += `<br>... and ${finding.details.length - 3} more`;
                                    resultHtml += `</div>`;
                                }
                                resultHtml += `</div>`;
                            }
                        }
                        
                        // Recommendations
                        if (a.recommendations && a.recommendations.length > 0) {
                            resultHtml += `<div style="margin-top: 15px;"><strong style="color: #0abdc6;">💡 Recommendations:</strong></div>`;
                            resultHtml += `<ul style="margin: 5px 0; padding-left: 20px; color: #aaa;">`;
                            for (const rec of a.recommendations) {
                                resultHtml += `<li>${rec}</li>`;
                            }
                            resultHtml += `</ul>`;
                        }
                        
                        // Stats
                        resultHtml += `<div style="display: flex; justify-content: space-around; margin-top: 15px; padding-top: 10px; border-top: 1px solid #333;">`;
                        resultHtml += `<div style="text-align: center;"><div style="font-size: 1.2em; color: #00ff41;">${a.stats.successful}</div><div style="font-size: 0.7em; color: #666;">Passed</div></div>`;
                        resultHtml += `<div style="text-align: center;"><div style="font-size: 1.2em; color: #ffaa00;">${a.stats.warnings}</div><div style="font-size: 0.7em; color: #666;">Warnings</div></div>`;
                        resultHtml += `<div style="text-align: center;"><div style="font-size: 1.2em; color: #ff0040;">${a.stats.findings}</div><div style="font-size: 0.7em; color: #666;">Findings</div></div>`;
                        resultHtml += `<div style="text-align: center;"><div style="font-size: 1.2em; color: #0abdc6;">${Math.round(data.duration)}s</div><div style="font-size: 0.7em; color: #666;">Duration</div></div>`;
                        resultHtml += `</div>`;
                        
                        resultHtml += `</div>`;
                    }
                    
                    // Tool Results Summary
                    resultHtml += `<div style="margin-top: 15px;"><strong>📊 Tool Results:</strong></div>`;
                    resultHtml += `<div style="background: rgba(0,0,0,0.2); border-radius: 8px; padding: 10px; margin-top: 5px;">`;
                    
                    for (const result of data.results) {
                        const icon = result.status === 'success' ? '✅' : result.status === 'warning' ? '⚠️' : '❌';
                        const aiLabel = result.ai ? ' 🧠' : '';
                        const findings = result.findingsCount ? ` • ${result.findingsCount} findings` : '';
                        const statusColor = result.status === 'success' ? '#00ff41' : result.status === 'warning' ? '#ffaa00' : '#ff0040';
                        resultHtml += `<div style="padding: 5px 0; border-bottom: 1px solid #222;">`;
                        resultHtml += `${icon} <strong>${result.name || result.tool}${aiLabel}</strong>`;
                        resultHtml += `<span style="color: ${statusColor}; float: right;">${result.status}${findings}</span>`;
                        resultHtml += `</div>`;
                    }
                    resultHtml += `</div>`;
                    
                    // Detailed Raw Results (collapsible)
                    resultHtml += `<details style="margin-top: 15px;">`;
                    resultHtml += `<summary style="cursor: pointer; color: #0abdc6;">📋 Show Detailed Raw Output</summary>`;
                    resultHtml += `<div style="max-height: 400px; overflow-y: auto; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 8px; margin-top: 10px; font-size: 0.8em;">`;
                    
                    for (const result of data.results) {
                        if (result.output && result.output.trim()) {
                            resultHtml += `<div style="margin-bottom: 15px; padding: 10px; background: rgba(0,0,0,0.2); border-radius: 6px;">`;
                            resultHtml += `<strong style="color: #0abdc6;">${result.name || result.tool}</strong><br>`;
                            const output = result.output.trim().substring(0, 1000);
                            resultHtml += `<pre style="white-space: pre-wrap; color: #aaa; font-size: 0.85em; margin: 5px 0; overflow-x: auto;">${output}${result.output.length > 1000 ? '\n...(truncated)' : ''}</pre>`;
                            if (result.error) {
                                resultHtml += `<div style="color: #ff0040; font-size: 0.8em; margin-top: 5px;">⚠️ ${result.error.substring(0, 300)}</div>`;
                            }
                            resultHtml += `</div>`;
                        }
                    }
                    resultHtml += `</div></details>`;
                    
                    // Update the existing scan message instead of adding new one
                    addMessage(resultHtml, false, currentScanMessageId);
                    currentScanMessageId = null;

                    const btn = document.getElementById('sendBtn');
                    btn.disabled = false;
                    btn.textContent = 'SCAN';
                }
            } catch (err) {
                console.error('Poll error:', err);
            }
        }

        function quickScan(type) {
            const prompts = {
                web: 'Full scan https://example.com',
                recon: 'Full reconnaissance on example.com',
                secrets: 'Hunt for secrets in current directory',
                code: 'Full code security analysis on ./my-project',
                mobile: 'Analyze mobile app for security issues',
                full: 'Comprehensive security scan on target',
                github: 'Scan GitHub repo https://github.com/user/repo for secrets',
                dork_aws: 'Search GitHub for exposed AWS keys',
                dork_stripe: 'Search GitHub for exposed Stripe keys',
                dork_openai: 'Search GitHub for exposed OpenAI keys'
            };
            document.getElementById('userInput').value = prompts[type];
            document.getElementById('userInput').focus();
        }

        function quickAttack(type) {
            const prompts = {
                sqli: 'https://example.com',
                xss: 'https://example.com',
                bruteforce: 'https://example.com/login',
                fuzz: 'https://example.com',
                full_attack: 'https://example.com',
                deep_scan: 'https://example.com',
                exploit: 'https://example.com'
            };
            document.getElementById('userInput').value = prompts[type];
            document.getElementById('userInput').focus();
            document.getElementById('userInput').dataset.attackType = type;
        }

        // Run scan with specific mode (Quick or Deep)
        async function runScanMode(mode) {
            const input = document.getElementById('userInput');
            let target = input.value.trim();
            
            // If no URL entered, prompt user
            if (!target || !target.match(/[a-z0-9][-a-z0-9]*\.[a-z]{2,}/i)) {
                const url = prompt(`Enter target URL for ${mode === 'deep_scan' ? 'Deep' : 'Quick'} Scan:`, 'https://example.com');
                if (!url) return;
                target = url;
            }
            
            // Ensure URL has protocol
            if (!target.startsWith('http')) {
                target = 'https://' + target;
            }

            const modeInfo = {
                full_attack: { name: 'Quick Scan ⚡', tools: 4, time: '~60s' },
                deep_scan: { name: 'Deep Scan 🔬', tools: 7, time: '~3min' }
            };
            const info = modeInfo[mode] || modeInfo.full_attack;

            addMessage(`🔍 Starting **${info.name}** on ${target}...\n\n_${info.tools} tools • ${info.time} estimated_`, true);
            input.value = '';

            // Run the scan with selected mode
            try {
                const response = await fetch('/api/attack', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ target, attackType: mode })
                });

                const data = await response.json();
                currentScanId = data.scanId;

                // Update stats
                document.getElementById('toolCount').textContent = data.toolCount || data.tools.length;
                document.getElementById('aiToolCount').textContent = data.aiToolCount || 0;

                // Update Active Tools panel
                const toolsWithInfo = data.tools.map(t => ({ tool: t, ai: false, status: 'running' }));
                updateToolList(toolsWithInfo);

                // Show risk panel
                document.getElementById('riskPanel').style.display = 'block';
                document.getElementById('riskIndicator').className = 'risk-indicator medium';
                document.getElementById('riskIndicator').textContent = 'SCANNING';

                // Store progress message
                scanProgressMessageId = addMessage(`
                    <div style="border-left: 3px solid #0abdc6; padding-left: 15px;" id="scan-progress-content">
                        <strong style="color: #0abdc6;">🛡️ ${info.name.toUpperCase()} IN PROGRESS</strong><br><br>
                        <strong>🎯 Target:</strong> ${target}<br>
                        <strong>🔧 Tools:</strong> ${data.toolCount || data.tools.length} selected<br>
                        <strong>⏱️ Estimated:</strong> ${info.time}<br>
                        <strong>⏳ Status:</strong> <span id="scan-status-text">Running tools...</span><br><br>
                        <div class="typing-indicator" id="scan-typing-indicator">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                `, false);

                // Poll for completion
                await pollScanAndChat(data.scanId, target, data.toolCount || data.tools.length);

            } catch (error) {
                addMessage(`❌ Scan Error: ${error.message}`, false);
            }
        }

        async function scanGitHubRepo() {
            const input = document.getElementById('githubRepoUrl');
            if (!input) {
                console.error('githubRepoUrl input not found');
                return alert('Error: Input not found');
            }
            
            let repoUrl = input.value.trim();
            console.log('GitHub repo URL:', repoUrl);
            
            if (!repoUrl) {
                return alert('Please enter a GitHub repository URL or owner/repo');
            }
            
            // Extract owner/repo from various formats
            // Handles: github.com/user/repo, https://github.com/user/repo, user/repo
            let repo = repoUrl
                .replace(/^https?:\/\/(www\.)?/, '')
                .replace(/^github\.com\//, '')
                .replace(/\/tree\/.*$/, '')  // Remove /tree/branch/...
                .replace(/\/blob\/.*$/, '')  // Remove /blob/branch/...
                .replace(/\.git$/, '')
                .replace(/\/$/, '')
                .split('/').slice(0, 2).join('/');  // Only keep owner/repo
            
            console.log('Extracted repo:', repo);
            
            // Validate format
            if (!repo || !repo.includes('/') || repo.split('/').length !== 2 || repo.split('/')[1] === '') {
                const isOrgOnly = repo && !repo.includes('/');
                let errorMsg = 'Invalid format. Need: owner/repo\n\n';
                if (isOrgOnly) {
                    errorMsg += `You entered "${repo}" which is a GitHub user/org, not a repo.\n\n`;
                    errorMsg += `Try: ${repo}/REPO_NAME\n\n`;
                }
                errorMsg += 'Examples:\n• facebook/react\n• github.com/microsoft/vscode\n• https://github.com/vercel/next.js';
                return alert(errorMsg);
            }
            
            const btn = document.getElementById('sendBtn');
            const sendBtn = document.getElementById('sendBtn');
            btn.disabled = true;
            sendBtn.disabled = true;
            btn.textContent = 'SCANNING...';
            input.value = '';  // Clear immediately
            
            addMessage(`🔍 <strong>Scanning GitHub Repo:</strong> <a href="https://github.com/${repo}" target="_blank" style="color: #0abdc6;">${repo}</a>`, true);
            
            try {
                const response = await fetch('/api/github-repo-scan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ repo })
                });
                
                const data = await response.json();
                console.log('Scan response:', data);
                
                if (data.error) {
                    addMessage(`❌ Error: ${data.error}`);
                    btn.disabled = false;
                    sendBtn.disabled = false;
                    btn.textContent = 'SCAN';
                } else {
                    currentScanId = data.scanId;
                    
                    currentScanMessageId = addMessage(`
                        <div style="border-left: 3px solid #8b5cf6; padding-left: 15px;">
                            <strong style="color: #8b5cf6;">🔍 GITHUB REPO SCAN</strong><br><br>
                            <strong>📁 Repository:</strong> <a href="https://github.com/${repo}" target="_blank" style="color: #0abdc6;">${repo}</a><br>
                            <strong>🔧 Scanning for:</strong> Secrets, API keys, passwords, tokens<br><br>
                            <div class="loading">
                                <span style="color: #8b5cf6;">Scanning repository...</span>
                                <div class="loading-bar"><div class="loading-progress" style="background: linear-gradient(90deg, #8b5cf6, #a855f7);"></div></div>
                            </div>
                        </div>
                    `);
                    
                    // Poll for results
                    pollInterval = setInterval(() => pollGitHubHunt(), 2000);
                }
            } catch (err) {
                console.error('Scan error:', err);
                addMessage(`❌ Error: ${err.message}`);
                btn.disabled = false;
                sendBtn.disabled = false;
                btn.textContent = 'SCAN';
            }
        }
        
        // Allow Enter key to trigger GitHub repo scan
        document.addEventListener('DOMContentLoaded', () => {
            const githubInput = document.getElementById('githubRepoUrl');
            if (githubInput) {
                githubInput.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        scanGitHubRepo();
                    }
                });
            }
        });

        async function githubHunt(secretType) {
            const btn = document.getElementById('sendBtn');
            const sendBtn = document.getElementById('sendBtn');
            btn.disabled = true;
            sendBtn.disabled = true;
            btn.textContent = 'HUNTING...';

            const labels = {
                aws: 'AWS Access Keys (AKIA...)',
                aws_secret: 'AWS Secret Keys',
                stripe: 'Stripe Live Keys (sk_live_)',
                openai: 'OpenAI API Keys (sk-...)',
                anthropic: 'Anthropic API Keys (sk-ant-)',
                google_api: 'Google API Keys (AIza...)',
                firebase: 'Firebase Configs',
                github_token: 'GitHub Tokens (ghp_)',
                slack: 'Slack Bot Tokens (xoxb-)',
                discord: 'Discord Tokens',
                twilio: 'Twilio Credentials',
                sendgrid: 'SendGrid API Keys',
                mongodb: 'MongoDB Connection Strings',
                postgres: 'PostgreSQL Credentials',
                keys: 'ALL API Keys & Secrets'
            };

            addMessage(`🔍 <strong>GitHub Secret Hunt:</strong> ${labels[secretType] || secretType}`, true);

            try {
                const response = await fetch('/api/github-hunt', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ secretType })
                });
                
                const data = await response.json();
                currentScanId = data.scanId;

                currentScanMessageId = addMessage(`
                    <div style="border-left: 3px solid #8b5cf6; padding-left: 15px;">
                        <strong style="color: #8b5cf6;">🔍 GITHUB SECRET HUNT</strong><br><br>
                        <strong>🎯 Target:</strong> All of GitHub<br>
                        <strong>🔑 Secret Type:</strong> ${labels[secretType] || secretType}<br>
                        <strong>🔧 Tool:</strong> GitHub Code Search API<br><br>
                        <div class="loading">
                            <span style="color: #8b5cf6;">Searching GitHub...</span>
                            <div class="loading-bar"><div class="loading-progress" style="background: linear-gradient(90deg, #8b5cf6, #a855f7);"></div></div>
                        </div>
                    </div>
                `);

                // Poll for results
                pollInterval = setInterval(() => pollGitHubHunt(), 2000);
            } catch (err) {
                addMessage(`❌ Hunt Error: ${err.message}`);
                btn.disabled = false;
                sendBtn.disabled = false;
                btn.textContent = 'SCAN';
            }
        }

        async function pollGitHubHunt() {
            if (!currentScanId) return;

            try {
                const response = await fetch(`/api/github-hunt/${currentScanId}`);
                const data = await response.json();

                if (data.status === 'complete') {
                    clearInterval(pollInterval);
                    
                    let resultHtml = buildGitHubHuntReport(data);
                    addMessage(resultHtml, false, currentScanMessageId);
                    currentScanMessageId = null;

                    document.getElementById('sendBtn').disabled = false;
                    document.getElementById('sendBtn').disabled = false;
                    document.getElementById('sendBtn').textContent = 'SCAN';
                    document.getElementById('findingCount').textContent = data.totalSecrets || 0;
                }
            } catch (err) {
                console.error('Hunt poll error:', err);
            }
        }

        function buildGitHubHuntReport(data) {
            let html = `<div style="background: linear-gradient(135deg, rgba(0,0,0,0.5), rgba(139,92,246,0.1)); border: 2px solid #8b5cf6; border-radius: 12px; padding: 20px;">`;
            
            // Header
            html += `<div style="text-align: center; margin-bottom: 20px;">`;
            html += `<div style="font-family: 'Orbitron', sans-serif; font-size: 1.5em; color: #8b5cf6; margin-bottom: 10px;">🔍 GITHUB SECRET HUNT REPORT</div>`;
            if (data.repo) {
                html += `<div style="color: #0abdc6;"><a href="https://github.com/${data.repo}" target="_blank" style="color: #0abdc6; text-decoration: none;">📁 ${data.repo}</a></div>`;
            } else {
                html += `<div style="color: #888;">Secret Type: ${data.secretType}</div>`;
            }
            html += `</div>`;

            // Summary
            const secretCount = data.secrets?.length || 0;
            const color = secretCount > 0 ? '#ff0040' : '#00ff41';
            html += `<div style="background: rgba(0,0,0,0.3); border-radius: 10px; padding: 15px; margin-bottom: 15px; text-align: center;">`;
            html += `<div style="font-size: 2em; color: ${color};">${secretCount}</div>`;
            html += `<div style="color: #888;">Exposed Secrets Found</div>`;
            html += `</div>`;

            // Findings
            if (data.secrets && data.secrets.length > 0) {
                html += `<div style="background: rgba(255,0,64,0.1); border-radius: 8px; padding: 15px; margin-bottom: 15px;">`;
                html += `<div style="color: #ff0040; font-weight: bold; margin-bottom: 10px;">🚨 EXPOSED SECRETS</div>`;
                
                for (const secret of data.secrets.slice(0, 20)) {
                    const repoName = secret.repository?.fullName || secret.repository || 'Unknown Repo';
                    const filePath = secret.path || 'Unknown path';
                    const repoUrl = `https://github.com/${repoName}`;
                    const fileUrl = secret.htmlUrl || `https://github.com/${repoName}/blob/main/${filePath}`;
                    
                    html += `<div style="background: rgba(0,0,0,0.3); border-left: 3px solid #ff0040; padding: 10px; margin: 8px 0; border-radius: 4px; cursor: pointer;" onclick="window.open('${fileUrl}', '_blank')">`;
                    html += `<div><a href="${repoUrl}" target="_blank" onclick="event.stopPropagation()" style="color: #8b5cf6; text-decoration: none;"><strong>📁 ${repoName}</strong></a></div>`;
                    html += `<div style="color: #888; font-size: 0.85em;"><a href="${fileUrl}" target="_blank" onclick="event.stopPropagation()" style="color: #0abdc6; text-decoration: none;">📄 ${filePath}</a></div>`;
                    if (secret.textMatches && secret.textMatches.length > 0) {
                        html += `<div style="color: #ff6666; font-size: 0.8em; margin-top: 5px; font-family: monospace; background: rgba(0,0,0,0.3); padding: 5px; border-radius: 4px; overflow-x: auto;">`;
                        html += secret.textMatches[0]?.fragment?.substring(0, 200) || '';
                        html += `</div>`;
                    }
                    html += `<div style="font-size: 10px; color: #666; margin-top: 5px;">Click to view file →</div>`;
                    html += `</div>`;
                }
                
                if (data.secrets.length > 20) {
                    html += `<div style="color: #888; text-align: center; margin-top: 10px;">...and ${data.secrets.length - 20} more</div>`;
                }
                html += `</div>`;
            } else {
                html += `<div style="background: rgba(0,255,65,0.1); border-radius: 8px; padding: 15px; text-align: center; margin-bottom: 15px;">`;
                html += `<div style="color: #00ff41;">✅ No exposed secrets found for this search</div>`;
                html += `</div>`;
            }

            // Recommendations
            html += `<div style="background: rgba(10,189,198,0.1); border-radius: 8px; padding: 15px;">`;
            html += `<div style="color: #0abdc6; font-weight: bold; margin-bottom: 10px;">💡 Recommendations</div>`;
            html += `<ul style="margin: 0; padding-left: 20px; color: #aaa;">`;
            if (secretCount > 0) {
                html += `<li>Contact affected repository owners about exposed credentials</li>`;
                html += `<li>Check if your organization's secrets appear in results</li>`;
                html += `<li>Rotate any credentials that may have been exposed</li>`;
            }
            html += `<li>Use GitHub secret scanning in your repositories</li>`;
            html += `<li>Implement pre-commit hooks to prevent secret commits</li>`;
            html += `</ul>`;
            html += `</div>`;

            // Duration
            html += `<div style="text-align: center; margin-top: 15px; color: #666; font-size: 0.8em;">`;
            html += `Scan completed in ${Math.round(data.duration || 0)}s`;
            html += `</div>`;

            html += `</div>`;
            return html;
        }

        async function startSecurityCheck() {
            const input = document.getElementById('userInput');
            let rawInput = input.value.trim();
            if (!rawInput) return;

            // Extract URL from input (handles "full scan https://..." or just URLs)
            const urlMatch = rawInput.match(/(https?:\/\/[^\s]+)/i);
            let target = urlMatch ? urlMatch[1] : rawInput;
            
            // If no protocol, try to extract domain and add https
            if (!target.startsWith('http')) {
                const domainMatch = rawInput.match(/([a-z0-9][-a-z0-9]*\.[-a-z0-9.]+)/i);
                target = domainMatch ? 'https://' + domainMatch[1] : 'https://' + target;
            }
            
            // Clean up target - remove any trailing text after the URL
            target = target.split(/\s/)[0];

            const attackType = input.dataset.attackType || 'full_attack';
            delete input.dataset.attackType;

            const btn = document.getElementById('securityBtn');
            btn.disabled = true;
            btn.textContent = '🛡️ CHECKING...';

            addMessage(`🛡️ <strong>SECURITY CHECK:</strong> ${target}<br>Check Type: ${attackType.toUpperCase()}`, true);
            input.value = '';

            try {
                const response = await fetch('/api/attack', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ target, attackType })
                });
                
                const data = await response.json();
                currentScanId = data.scanId;

                // Update stats immediately with accurate tool counts
                document.getElementById('toolCount').textContent = data.toolCount || data.tools.length;
                document.getElementById('aiToolCount').textContent = data.aiToolCount || 0;
                
                currentScanMessageId = addMessage(`
                    <div style="border-left: 3px solid #0abdc6; padding-left: 15px;">
                        <strong style="color: #0abdc6;">🛡️ SECURITY SCAN INITIATED</strong><br><br>
                        <strong>🎯 Target:</strong> ${target}<br>
                        <strong>📋 Scan Type:</strong> ${data.scanName || data.attackType.toUpperCase()}<br>
                        <strong>🔧 Tools Selected:</strong> ${data.toolCount || data.tools.length} (${data.aiToolCount || 0} AI-powered)<br>
                        <strong>⏳ Status:</strong> Analyzing target...<br><br>
                        <div class="loading">
                            <span style="color: #0abdc6;">Security Analysis in Progress...</span>
                            <div class="loading-bar"><div class="loading-progress" style="background: linear-gradient(90deg, #0abdc6, #00ff41);"></div></div>
                        </div>
                    </div>
                `);

                const toolsWithInfo = data.tools.map(t => ({ tool: t, ai: false, status: 'running' }));
                updateToolList(toolsWithInfo);
                document.getElementById('riskPanel').style.display = 'block';
                document.getElementById('riskIndicator').className = 'risk-indicator medium';
                document.getElementById('riskIndicator').textContent = 'ANALYZING';

                // Start polling
                pollInterval = setInterval(() => pollAttackStatus(), 2000);
            } catch (err) {
                addMessage(`❌ Security Check Error: ${err.message}`);
                btn.disabled = false;
                btn.textContent = '🛡️ SECURITY CHECK';
            }
        }

        async function pollAttackStatus() {
            if (!currentScanId) return;

            try {
                const response = await fetch(`/api/attack/${currentScanId}`);
                const data = await response.json();

                updateToolList(data.results.length ? data.results : data.tools.map(t => ({ tool: t, status: 'running' })));

                if (data.status === 'complete') {
                    clearInterval(pollInterval);
                    
                    // Update all stats from actual results
                    document.getElementById('toolCount').textContent = data.toolCount || data.results?.length || 0;
                    document.getElementById('aiToolCount').textContent = data.aiToolCount || data.results?.filter(r => r.ai).length || 0;
                    document.getElementById('findingCount').textContent = data.totalVulns || 0;
                    document.getElementById('scanTime').textContent = `${Math.round(data.duration)}s`;

                    // Build security report
                    let resultHtml = buildAttackReport(data);
                    
                    addMessage(resultHtml, false, currentScanMessageId);
                    currentScanMessageId = null;

                    const btn = document.getElementById('securityBtn');
                    btn.disabled = false;
                    btn.textContent = '🛡️ SECURITY CHECK';
                }
            } catch (err) {
                console.error('Security check poll error:', err);
            }
        }

        function buildAttackReport(data) {
            const a = data.analysis || {};
            const riskColor = a.riskLevel === 'CRITICAL' ? '#ff0040' : a.riskLevel === 'HIGH' ? '#ff4444' : a.riskLevel === 'MEDIUM' ? '#ffaa00' : '#00ff41';
            
            let html = `<div style="background: linear-gradient(135deg, rgba(0,0,0,0.5), rgba(255,0,64,0.1)); border: 2px solid ${riskColor}; border-radius: 12px; padding: 20px;">`;
            
            // Header
            html += `<div style="text-align: center; margin-bottom: 20px;">`;
            html += `<div style="font-family: 'Orbitron', sans-serif; font-size: 1.5em; color: #0abdc6; margin-bottom: 10px;">🛡️ SECURITY SCAN REPORT</div>`;
            html += `<div style="color: #888;">Target: ${data.target}</div>`;
            html += `<div style="color: #666; font-size: 0.8em;">Tools Used: ${data.toolCount || data.results?.length || 0} | Generated: ${new Date().toISOString()}</div>`;
            html += `</div>`;

            // Risk Score
            html += `<div style="background: rgba(0,0,0,0.3); border-radius: 10px; padding: 15px; margin-bottom: 15px;">`;
            html += `<div style="display: flex; justify-content: space-between; align-items: center;">`;
            html += `<span style="font-size: 1.2em;">🎯 Security Assessment</span>`;
            html += `<span style="background: ${riskColor}; color: #000; padding: 8px 20px; border-radius: 20px; font-weight: bold;">${a.riskLevel || 'UNKNOWN'}</span>`;
            html += `</div>`;
            html += `<div style="background: rgba(0,0,0,0.3); border-radius: 10px; height: 20px; margin: 15px 0; overflow: hidden;">`;
            html += `<div style="background: linear-gradient(90deg, #00ff41 0%, #ffaa00 50%, #ff0040 100%); width: ${a.riskScore || 0}%; height: 100%;"></div>`;
            html += `</div>`;
            html += `<div style="text-align: center; color: #888;">Vulnerability Score: ${a.riskScore || 0}/100</div>`;
            html += `</div>`;

            // Executive Summary
            html += `<div style="background: rgba(0,0,0,0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px;">`;
            html += `<div style="color: #0abdc6; font-weight: bold; margin-bottom: 10px;">📋 Executive Summary</div>`;
            html += `<p style="color: #ccc; line-height: 1.6;">${a.summary || 'Security scan completed. See findings below.'}</p>`;
            html += `</div>`;

            // Vulnerabilities Found
            if (a.criticalFindings && a.criticalFindings.length > 0) {
                html += `<div style="background: rgba(255,0,64,0.1); border-radius: 8px; padding: 15px; margin-bottom: 15px;">`;
                html += `<div style="color: #ff0040; font-weight: bold; margin-bottom: 10px;">🚨 Vulnerabilities Found</div>`;
                
                for (const finding of a.criticalFindings) {
                    const fColor = finding.severity === 'CRITICAL' ? '#ff0040' : finding.severity === 'HIGH' ? '#ff4444' : finding.severity === 'MEDIUM' ? '#ffaa00' : '#0abdc6';
                    html += `<div style="background: rgba(0,0,0,0.3); border-left: 3px solid ${fColor}; padding: 10px; margin: 8px 0; border-radius: 4px;">`;
                    html += `<div style="display: flex; justify-content: space-between; align-items: center;">`;
                    html += `<strong>${finding.finding}</strong>`;
                    html += `<span style="background: ${fColor}; color: #000; padding: 2px 8px; border-radius: 10px; font-size: 0.7em;">${finding.severity}</span>`;
                    html += `</div>`;
                    if (finding.details) {
                        const details = Array.isArray(finding.details) ? finding.details : [finding.details];
                        html += `<div style="color: #888; font-size: 0.85em; margin-top: 5px;">`;
                        html += details.slice(0, 3).join('<br>');
                        html += `</div>`;
                    }
                    if (finding.tool) {
                        html += `<div style="color: #666; font-size: 0.75em; margin-top: 5px;">Tool: ${finding.tool}</div>`;
                    }
                    html += `</div>`;
                }
                html += `</div>`;
            }

            // Recommendations
            if (a.recommendations && a.recommendations.length > 0) {
                html += `<div style="background: rgba(10,189,198,0.1); border-radius: 8px; padding: 15px; margin-bottom: 15px;">`;
                html += `<div style="color: #0abdc6; font-weight: bold; margin-bottom: 10px;">💡 Remediation Recommendations</div>`;
                html += `<ul style="margin: 0; padding-left: 20px; color: #aaa;">`;
                for (const rec of a.recommendations) {
                    html += `<li style="margin: 5px 0;">${rec}</li>`;
                }
                html += `</ul>`;
                html += `</div>`;
            }

            // Tool Results
            html += `<div style="background: rgba(0,0,0,0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px;">`;
            html += `<div style="color: #888; font-weight: bold; margin-bottom: 10px;">🔧 Security Tools Used</div>`;
            for (const result of (data.results || [])) {
                const icon = result.status === 'success' ? '✅' : result.status === 'warning' ? '⚠️' : result.status === 'vuln_found' ? '💀' : '❌';
                const statusColor = result.status === 'vuln_found' ? '#ff0040' : result.status === 'success' ? '#00ff41' : result.status === 'warning' ? '#ffaa00' : '#666';
                html += `<div style="display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #222;">`;
                html += `<span>${icon} ${result.name || result.tool}</span>`;
                html += `<span style="color: ${statusColor};">${result.status}${result.findingsCount ? ` (${result.findingsCount} vulns)` : ''}</span>`;
                html += `</div>`;
            }
            html += `</div>`;

            // Stats Footer
            html += `<div style="display: flex; justify-content: space-around; padding: 15px; background: rgba(0,0,0,0.2); border-radius: 8px;">`;
            html += `<div style="text-align: center;"><div style="font-size: 1.5em; color: #ff0040;">${data.totalVulns || 0}</div><div style="font-size: 0.7em; color: #666;">Vulns Found</div></div>`;
            html += `<div style="text-align: center;"><div style="font-size: 1.5em; color: #ffaa00;">${(data.results || []).length}</div><div style="font-size: 0.7em; color: #666;">Tools Run</div></div>`;
            html += `<div style="text-align: center;"><div style="font-size: 1.5em; color: #0abdc6;">${Math.round(data.duration || 0)}s</div><div style="font-size: 0.7em; color: #666;">Duration</div></div>`;
            html += `</div>`;

            // Detailed Tool Results (expanded by default for full report)
            html += `<details open style="margin-top: 15px;">`;
            html += `<summary style="cursor: pointer; color: #ff0040; font-weight: bold;">📋 Detailed Tool Output (${(data.results || []).length} tools)</summary>`;
            html += `<div style="max-height: 600px; overflow-y: auto; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 8px; margin-top: 10px;">`;
            for (const result of (data.results || [])) {
                const statusIcon = result.status === 'vuln_found' ? '💀' : result.status === 'success' ? '✅' : result.status === 'error' ? '❌' : '⚠️';
                const borderColor = result.status === 'vuln_found' ? '#ff0040' : result.status === 'success' ? '#00ff41' : '#ffaa00';
                
                html += `<div style="margin-bottom: 15px; padding: 12px; background: rgba(0,0,0,0.2); border-left: 3px solid ${borderColor}; border-radius: 4px;">`;
                html += `<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">`;
                html += `<strong style="color: #fff; font-size: 1em;">${statusIcon} ${result.name || result.tool}</strong>`;
                html += `<span style="color: ${borderColor}; font-size: 0.8em;">${result.findingsCount ? result.findingsCount + ' findings' : result.status}</span>`;
                html += `</div>`;
                
                if (result.output && result.output.trim()) {
                    html += `<div style="background: rgba(0,0,0,0.3); padding: 8px; border-radius: 4px; margin-top: 8px;">`;
                    html += `<pre style="white-space: pre-wrap; color: #aaa; margin: 0; font-size: 0.8em; max-height: 300px; overflow-y: auto;">${escapeHtml(result.output.substring(0, 5000))}${result.output.length > 5000 ? '\n\n... (showing first 5000 chars)' : ''}</pre>`;
                    html += `</div>`;
                }
                
                if (result.error) {
                    html += `<div style="color: #ff6666; font-size: 0.8em; margin-top: 5px;">⚠️ Error: ${escapeHtml(result.error.substring(0, 500))}</div>`;
                }
                html += `</div>`;
            }
            html += `</div></details>`;
            
            // Helper function for HTML escaping
            function escapeHtml(text) {
                return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
            }

            html += `</div>`;
            return html;
        }

        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        });

        // ═══════════════════════════════════════════════════════════════
        // MONITORING FUNCTIONS (UptimeRobot Integration)
        // ═══════════════════════════════════════════════════════════════
        
        function showAddMonitoring() {
            document.getElementById('addMonitoringForm').style.display = 'block';
        }
        
        function hideAddMonitoring() {
            document.getElementById('addMonitoringForm').style.display = 'none';
        }
        
        async function addMonitoringSite() {
            const url = document.getElementById('monitorUrl').value;
            if (!url) return alert('Please enter a URL');
            
            try {
                const res = await fetch('/api/uptimerobot/monitors', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url, name: url })
                });
                const data = await res.json();
                if (data.success) {
                    document.getElementById('monitorUrl').value = '';
                    hideAddMonitoring();
                    loadMonitoringSites();
                } else if (data.error?.includes('API key')) {
                    alert('⚠️ UptimeRobot not configured.\\n\\nGo to https://uptimerobot.com to get your API key, then run:\\ncurl -X POST http://localhost:3333/api/uptimerobot/setup -H "Content-Type: application/json" -d \'{"apiKey": "YOUR_KEY"}\'');
                } else {
                    alert('Error: ' + (data.error || 'Failed to add monitor'));
                }
            } catch (e) {
                alert('Error: ' + e.message);
            }
        }
        
        async function loadMonitoringSites() {
            const container = document.getElementById('monitoringList');
            
            try {
                const res = await fetch('/api/uptimerobot/monitors');
                const data = await res.json();
                
                if (!data.configured) {
                    container.innerHTML = `<div class="tool-item" style="flex-direction: column; align-items: flex-start; gap: 8px;">
                        <span style="color: #ffaa00;">⚠️ UptimeRobot not configured</span>
                        <span style="color: #666; font-size: 11px;">Get API key from uptimerobot.com</span>
                        <button class="quick-btn" onclick="showAddMonitoring()" style="font-size: 10px; padding: 4px 8px;">+ Add Site Anyway</button>
                    </div>`;
                    return;
                }
                
                if (!data.monitors || data.monitors.length === 0) {
                    container.innerHTML = `<div class="tool-item" style="justify-content: space-between;">
                        <span style="color: #666;">No sites monitored</span>
                        <button class="quick-btn" onclick="showAddMonitoring()" style="font-size: 10px; padding: 4px 8px;">+ Add</button>
                    </div>`;
                    return;
                }
                
                let html = '';
                for (const monitor of data.monitors) {
                    const statusColor = monitor.status === 'online' ? '#00ff41' : monitor.status === 'down' ? '#ff0040' : '#ffaa00';
                    const statusIcon = monitor.status === 'online' ? '🟢' : monitor.status === 'down' ? '🔴' : '🟡';
                    const responseTime = monitor.responseTime ? `${monitor.responseTime}ms` : '-';
                    const avgTime = monitor.avgResponseTime ? `avg ${monitor.avgResponseTime}ms` : '';
                    const uptime24h = monitor.uptime?.day ? `${monitor.uptime.day}%` : '-';
                    const uptime7d = monitor.uptime?.week ? `${monitor.uptime.week}%` : '-';
                    const uptime30d = monitor.uptime?.month ? `${monitor.uptime.month}%` : '-';
                    const lastChecked = monitor.lastChecked ? new Date(monitor.lastChecked).toLocaleTimeString() : '-';
                    
                    // SSL info (only show if we have valid expiry data)
                    let sslInfo = '';
                    if (monitor.ssl && monitor.ssl.daysUntilExpiry !== null && monitor.ssl.daysUntilExpiry !== undefined) {
                        const sslColor = monitor.ssl.daysUntilExpiry > 30 ? '#00ff41' : monitor.ssl.daysUntilExpiry > 7 ? '#ffaa00' : '#ff0040';
                        sslInfo = `<div style="font-size: 9px; color: ${sslColor};">🔒 SSL: ${monitor.ssl.daysUntilExpiry}d left</div>`;
                    }
                    
                    // Recent incidents
                    let incidentInfo = '';
                    const downLogs = monitor.logs?.filter(l => l.type === 'down') || [];
                    if (downLogs.length > 0) {
                        incidentInfo = `<div style="font-size: 9px; color: #ff0040;">⚠️ ${downLogs.length} incident(s)</div>`;
                    }
                    
                    html += `<div class="tool-item" style="flex-direction: column; padding: 10px 0; border-bottom: 1px solid #222; gap: 6px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                            <span style="font-size: 12px; font-weight: bold;">${statusIcon} ${monitor.friendlyName}</span>
                            <div style="display: flex; align-items: center; gap: 6px;">
                                <span style="color: ${statusColor}; font-size: 11px; font-weight: bold;">${monitor.status.toUpperCase()}</span>
                                <button onclick="deleteMonitor(${monitor.id}, '${monitor.friendlyName}')" style="background: transparent; border: none; color: #ff0040; cursor: pointer; font-size: 12px; padding: 2px;" title="Delete">🗑️</button>
                            </div>
                        </div>
                        <div style="font-size: 10px; color: #666; word-break: break-all;">${monitor.url}</div>
                        <div style="display: flex; justify-content: space-between; font-size: 10px; color: #888; margin-top: 4px;">
                            <span>⚡ ${responseTime} ${avgTime ? `(${avgTime})` : ''}</span>
                            <span>🕐 ${lastChecked}</span>
                        </div>
                        <div style="display: flex; gap: 10px; font-size: 9px; color: #0abdc6;">
                            <span title="24h uptime">24h: ${uptime24h}</span>
                            <span title="7 day uptime">7d: ${uptime7d}</span>
                            <span title="30 day uptime">30d: ${uptime30d}</span>
                        </div>
                        ${sslInfo}
                        ${incidentInfo}
                    </div>`;
                }
                html += `<button class="quick-btn" onclick="showAddMonitoring()" style="width: 100%; margin-top: 8px; font-size: 10px;">+ Add Site</button>`;
                container.innerHTML = html;
            } catch (e) {
                container.innerHTML = `<div class="tool-item" style="color: #ff0040;">Error loading monitors: ${e.message}</div>`;
            }
        }
        
        async function checkAllMonitoring() {
            const btn = event.target;
            btn.textContent = '⏳ Refreshing...';
            btn.disabled = true;
            
            // UptimeRobot handles checking automatically, we just refresh the display
            await loadMonitoringSites();
            
            btn.textContent = '🔄 Refresh';
            btn.disabled = false;
        }
        
        async function deleteMonitor(id, name) {
            if (!confirm(`Delete monitor "${name}"?`)) return;
            
            try {
                const res = await fetch(`/api/uptimerobot/monitors/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    loadMonitoringSites();
                } else {
                    alert('Error: ' + (data.error || 'Failed to delete'));
                }
            } catch (e) {
                alert('Error: ' + e.message);
            }
        }
        
        // Load monitoring on page load
        loadMonitoringSites();
        
        // ═══════════════════════════════════════════════════════════════
        // NETWORK GUARDIAN - WiFi Intrusion Detection Functions
        // ═══════════════════════════════════════════════════════════════
        
        let networkGuardianData = { devices: [], whitelist: [], alerts: [] };
        
        // Initialize Network Guardian
        async function initNetworkGuardian() {
            try {
                const response = await fetch('/api/network-guardian/info');
                const info = await response.json();
                if (info.localIP) {
                    document.getElementById('networkName').textContent = `${info.localIP} (${info.interface})`;
                } else {
                    document.getElementById('networkName').textContent = 'Unknown';
                }
            } catch (e) {
                document.getElementById('networkName').textContent = 'Error';
            }
        }
        
        // Quick network scan (ARP only)
        async function scanNetworkQuick() {
            addMessage('⚡ <strong>Network Guardian:</strong> Running quick ARP scan...', true);
            document.getElementById('deviceCount').textContent = 'Scanning...';
            
            try {
                const response = await fetch('/api/network-guardian/arp-scan');
                const result = await response.json();
                
                if (result.error) {
                    addMessage(`❌ Scan error: ${result.error}`, false);
                    return;
                }
                
                networkGuardianData.devices = result.devices || [];
                document.getElementById('deviceCount').textContent = `${result.devices?.length || 0} devices`;
                
                // Show results
                let html = `<strong>📡 ${result.devices?.length || 0} devices found on ${result.networkInfo?.networkRange || 'network'}:</strong><br><br>`;
                html += '<table style="width: 100%; font-size: 12px; border-collapse: collapse;">';
                html += '<tr style="color: #00ff41;"><th style="text-align: left;">IP</th><th style="text-align: left;">MAC</th><th style="text-align: left;">Vendor</th><th>Actions</th></tr>';
                
                result.devices?.forEach(d => {
                    const isWhitelisted = networkGuardianData.whitelist?.some(w => w.mac === d.mac);
                    html += `<tr style="border-bottom: 1px solid #2a2a3a;">
                        <td style="padding: 5px 0;">${d.ip}</td>
                        <td style="font-family: monospace; color: ${isWhitelisted ? '#00ff41' : '#ff9900'};">${d.mac}</td>
                        <td style="color: #666;">${d.vendor || 'Unknown'}</td>
                        <td>
                            ${isWhitelisted 
                                ? '<span style="color: #00ff41;">✓</span>' 
                                : `<button onclick="whitelistDevice('${d.mac}', '${d.ip}', '${d.vendor || ''}')" style="background: none; border: 1px solid #00ff41; color: #00ff41; cursor: pointer; padding: 2px 5px; border-radius: 3px; font-size: 10px;">+</button>
                                   <button onclick="investigateDevice('${d.mac}', '${d.ip}')" style="background: none; border: 1px solid #ff9900; color: #ff9900; cursor: pointer; padding: 2px 5px; border-radius: 3px; font-size: 10px;">🔍</button>`
                            }
                        </td>
                    </tr>`;
                });
                html += '</table>';
                
                const unknownCount = result.devices?.filter(d => !networkGuardianData.whitelist?.some(w => w.mac === d.mac)).length || 0;
                if (unknownCount > 0) {
                    html += `<br><div style="color: #ff9900;">⚠️ ${unknownCount} unknown device(s) - click + to whitelist or 🔍 to investigate</div>`;
                }
                
                addMessage(html, false);
            } catch (e) {
                addMessage(`❌ Network scan failed: ${e.message}`, false);
            }
        }
        
        // Full AI-powered scan
        async function scanNetworkFull() {
            addMessage('🤖 <strong>Network Guardian:</strong> Running AI-powered security scan...', true);
            document.getElementById('deviceCount').textContent = 'AI Analyzing...';
            
            try {
                const response = await fetch('/api/network-guardian/full-scan', { method: 'POST' });
                const result = await response.json();
                
                if (result.error) {
                    addMessage(`❌ Scan error: ${result.error}`, false);
                    return;
                }
                
                networkGuardianData = { ...networkGuardianData, ...result };
                document.getElementById('deviceCount').textContent = `${result.summary?.totalDevices || 0} devices`;
                
                // Show AI analysis
                let html = `<strong>🛡️ Network Guardian AI Analysis</strong><br>`;
                html += `<div style="margin: 10px 0; padding: 10px; background: #1a1a25; border-radius: 5px;">`;
                html += `📊 <strong>Summary:</strong> ${result.summary?.totalDevices || 0} total, ${result.summary?.whitelistedDevices || 0} trusted, ${result.summary?.unknownDevices || 0} unknown, ${result.summary?.threats || 0} potential threats<br>`;
                
                if (result.aiAnalysis?.summary) {
                    html += `<br>🤖 <strong>AI Assessment:</strong> ${result.aiAnalysis.summary}`;
                }
                html += '</div>';
                
                // Show device analysis
                if (result.aiAnalysis?.devices) {
                    html += '<table style="width: 100%; font-size: 11px; border-collapse: collapse; margin-top: 10px;">';
                    html += '<tr style="color: #00ff41;"><th style="text-align: left;">Device</th><th>Threat</th><th style="text-align: left;">Analysis</th></tr>';
                    
                    result.aiAnalysis.devices.forEach(d => {
                        const threatColors = { safe: '#00ff41', low: '#0abdc6', medium: '#ff9900', high: '#ff0040', critical: '#ff0040' };
                        const threatIcons = { safe: '✅', low: '🟢', medium: '🟡', high: '🟠', critical: '🔴' };
                        
                        html += `<tr style="border-bottom: 1px solid #2a2a3a;">
                            <td style="padding: 5px 0;">
                                <strong>${d.deviceType || 'Unknown'}</strong><br>
                                <span style="font-family: monospace; font-size: 10px; color: #666;">${d.ip} / ${d.mac}</span>
                            </td>
                            <td style="text-align: center; color: ${threatColors[d.threatLevel] || '#666'};">
                                ${threatIcons[d.threatLevel] || '❓'}<br>${d.threatLevel?.toUpperCase() || 'UNKNOWN'}
                            </td>
                            <td style="padding: 5px; color: #999; font-size: 10px;">
                                ${d.analysis || ''}
                                ${d.recommendation ? `<br><em style="color: #0abdc6;">${d.recommendation}</em>` : ''}
                            </td>
                        </tr>`;
                    });
                    html += '</table>';
                }
                
                // Show alerts if any
                if (result.alerts?.length > 0) {
                    html += '<div style="margin-top: 15px; padding: 10px; background: #2a1a1a; border: 1px solid #ff0040; border-radius: 5px;">';
                    html += '<strong style="color: #ff0040;">🚨 ALERTS:</strong><br>';
                    result.alerts.forEach(a => {
                        html += `<div style="margin-top: 5px;">
                            <strong>${a.severity?.toUpperCase()}</strong>: ${a.message}<br>
                            <em style="color: #ff9900;">${a.recommendation}</em>
                        </div>`;
                    });
                    html += '</div>';
                    
                    // Update sidebar alerts
                    updateNetworkAlerts(result.alerts);
                }
                
                // Show recommendations
                if (result.aiAnalysis?.recommendations?.length > 0) {
                    html += '<div style="margin-top: 15px; padding: 10px; background: #1a2a1a; border: 1px solid #00ff41; border-radius: 5px;">';
                    html += '<strong style="color: #00ff41;">💡 Recommendations:</strong><ul style="margin: 5px 0; padding-left: 20px;">';
                    result.aiAnalysis.recommendations.forEach(r => {
                        html += `<li style="margin: 3px 0;">${r}</li>`;
                    });
                    html += '</ul></div>';
                }
                
                addMessage(html, false);
            } catch (e) {
                addMessage(`❌ AI scan failed: ${e.message}`, false);
                document.getElementById('deviceCount').textContent = 'Error';
            }
        }
        
        // Update alerts in sidebar
        function updateNetworkAlerts(alerts) {
            const container = document.getElementById('networkGuardianAlerts');
            if (!alerts || alerts.length === 0) {
                container.innerHTML = '';
                return;
            }
            
            let html = '';
            alerts.slice(0, 3).forEach(a => {
                const color = a.severity === 'critical' ? '#ff0040' : a.severity === 'high' ? '#ff9900' : '#ffcc00';
                html += `<div style="font-size: 10px; padding: 3px 5px; background: ${color}22; border-left: 2px solid ${color}; margin-bottom: 3px;">
                    ${a.severity?.toUpperCase()}: ${a.mac?.substr(-8) || 'Device'}
                </div>`;
            });
            container.innerHTML = html;
        }
        
        // Whitelist a device
        async function whitelistDevice(mac, ip, vendor) {
            const name = prompt(`Name this device (${mac}):`, vendor || 'My Device');
            if (!name) return;
            
            try {
                const response = await fetch('/api/network-guardian/whitelist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mac, ip, vendor, name })
                });
                const result = await response.json();
                
                if (result.success) {
                    addMessage(`✅ Device <strong>${name}</strong> (${mac}) added to whitelist`, false);
                    // Refresh whitelist
                    loadWhitelist();
                    // Re-run quick scan to update display
                    scanNetworkQuick();
                } else {
                    addMessage(`⚠️ ${result.message}`, false);
                }
            } catch (e) {
                addMessage(`❌ Failed to whitelist: ${e.message}`, false);
            }
        }
        
        // Investigate suspicious device with AI
        async function investigateDevice(mac, ip) {
            addMessage(`🔍 <strong>AI Investigating device ${ip} (${mac})...</strong>`, true);
            
            try {
                // First get AI identification
                const aiResponse = await fetch('/api/network-guardian/identify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mac, ip })
                });
                const aiResult = await aiResponse.json();
                
                // Also try nmap for ports
                let nmapResult = { devices: [] };
                try {
                    const nmapResponse = await fetch('/api/network-guardian/nmap-scan', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ deep: false, range: ip })
                    });
                    nmapResult = await nmapResponse.json();
                } catch (e) { /* ignore nmap errors */ }
                
                const device = nmapResult.devices?.[0] || {};
                
                // Build investigation report
                let html = `<strong>🔬 AI Device Investigation: ${ip}</strong><br><br>`;
                
                // AI Identification result
                if (aiResult.deviceType) {
                    const threatColors = { none: '#00ff41', low: '#0abdc6', medium: '#ff9900', high: '#ff0040' };
                    const threatColor = threatColors[aiResult.threatLevel] || '#666';
                    
                    html += `<div style="padding: 12px; background: linear-gradient(135deg, #1a1a25, #0a0a0f); border: 1px solid ${threatColor}; border-radius: 8px; margin-bottom: 15px;">`;
                    html += `<div style="font-size: 16px; margin-bottom: 8px;">🤖 <strong>AI Identification:</strong> ${aiResult.deviceType}</div>`;
                    html += `<div style="display: flex; gap: 20px; font-size: 12px;">`;
                    html += `<span>Confidence: <strong>${aiResult.confidence || 'medium'}</strong></span>`;
                    html += `<span>Threat: <strong style="color: ${threatColor};">${(aiResult.threatLevel || 'unknown').toUpperCase()}</strong></span>`;
                    html += `<span>Suspicious: <strong style="color: ${aiResult.isSuspicious ? '#ff0040' : '#00ff41'};">${aiResult.isSuspicious ? 'YES' : 'NO'}</strong></span>`;
                    html += `</div>`;
                    if (aiResult.explanation) {
                        html += `<div style="margin-top: 10px; color: #999; font-size: 11px;">${aiResult.explanation}</div>`;
                    }
                    if (aiResult.recommendation) {
                        html += `<div style="margin-top: 8px; color: #0abdc6; font-size: 11px;">💡 ${aiResult.recommendation}</div>`;
                    }
                    html += '</div>';
                }
                
                // Device details
                html += `<table style="font-size: 12px; margin-bottom: 15px;">
                    <tr><td style="color: #666; padding-right: 15px;">MAC Address:</td><td style="font-family: monospace;">${mac}</td></tr>
                    <tr><td style="color: #666; padding-right: 15px;">IP Address:</td><td>${ip} ${aiResult.isLinkLocal ? '<span style="color: #ff9900;">(Link-Local)</span>' : ''}</td></tr>
                    <tr><td style="color: #666; padding-right: 15px;">Vendor:</td><td>${aiResult.vendorInfo?.vendor || device.vendor || 'Unknown'} ${aiResult.vendorInfo?.isRandomized ? '<span style="color: #ff9900;">(Randomized MAC)</span>' : ''}</td></tr>
                    <tr><td style="color: #666; padding-right: 15px;">Hostname:</td><td>${device.hostname || 'None detected'}</td></tr>
                </table>`;
                
                // Ports if found
                if (device.ports?.length > 0) {
                    html += '<strong>Open Ports:</strong><br>';
                    html += '<table style="font-size: 11px; margin: 5px 0 15px 0;">';
                    device.ports.forEach(p => {
                        html += `<tr><td style="color: #00ff41; padding-right: 15px;">${p.port}/${p.protocol}</td><td>${p.service || 'unknown'}</td></tr>`;
                    });
                    html += '</table>';
                }
                
                // Action buttons
                html += `<div style="display: flex; gap: 10px; flex-wrap: wrap;">`;
                if (!aiResult.isSuspicious && aiResult.threatLevel !== 'high') {
                    html += `<button onclick="whitelistDevice('${mac}', '${ip}', '${aiResult.deviceType || ''}')" style="background: #00ff41; color: #0a0a0f; border: none; padding: 10px 20px; cursor: pointer; border-radius: 5px; font-weight: bold;">✓ Trust This Device</button>`;
                }
                html += `<button onclick="kickDevice('${mac}')" style="background: ${aiResult.isSuspicious ? '#ff0040' : '#ff9900'}; color: white; border: none; padding: 10px 20px; cursor: pointer; border-radius: 5px; font-weight: bold;">⛔ Block/Kick Device</button>`;
                html += `<button onclick="startDeviceMonitoring('${ip}', '${mac}', '${aiResult.deviceType || 'Device'}')" style="background: #8b5cf6; color: white; border: none; padding: 10px 20px; cursor: pointer; border-radius: 5px; font-weight: bold;">📊 Monitor Activity</button>`;
                html += `</div>`;
                
                // Warning for randomized MACs
                if (aiResult.vendorInfo?.isRandomized) {
                    html += `<div style="margin-top: 15px; padding: 10px; background: #2a2a1a; border: 1px solid #ff9900; border-radius: 5px; font-size: 11px;">
                        ⚠️ <strong>Randomized MAC detected!</strong> This device uses MAC privacy (common on iPhones, Android, Windows 11). 
                        Blocking by MAC may not be permanent. Consider changing your WiFi password instead.
                    </div>`;
                }
                
                addMessage(html, false);
            } catch (e) {
                addMessage(`❌ Investigation failed: ${e.message}`, false);
            }
        }
        
        // Kick/deauth device with detailed instructions
        async function kickDevice(mac) {
            addMessage(`⛔ <strong>Getting block instructions for ${mac}...</strong>`, true);
            
            try {
                const response = await fetch('/api/network-guardian/deauth', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mac, confirm: true })
                });
                const result = await response.json();
                
                let html = `<strong>⛔ How to Block/Kick Device: ${mac}</strong><br><br>`;
                
                // Vendor info
                if (result.vendorInfo) {
                    html += `<div style="margin-bottom: 15px; font-size: 12px;">`;
                    html += `Device: <strong>${result.vendorInfo.vendor}</strong>`;
                    if (result.vendorInfo.isRandomized) {
                        html += ` <span style="color: #ff9900;">(Randomized MAC)</span>`;
                    }
                    html += `</div>`;
                }
                
                // Warning for randomized MACs
                if (result.warning) {
                    html += `<div style="padding: 10px; background: #2a2a1a; border: 1px solid #ff9900; border-radius: 5px; margin-bottom: 15px; font-size: 11px;">
                        ⚠️ ${result.warning}
                    </div>`;
                }
                
                // Quick method (nuclear option)
                if (result.methods?.quick) {
                    html += `<div style="padding: 12px; background: linear-gradient(135deg, #2a1a1a, #1a0a0a); border: 2px solid #ff0040; border-radius: 8px; margin-bottom: 15px;">`;
                    html += `<div style="font-size: 14px; color: #ff0040; margin-bottom: 8px;">${result.methods.quick.title}: ${result.methods.quick.action}</div>`;
                    html += `<div style="font-size: 11px; color: #999; margin-bottom: 8px;">${result.methods.quick.why}</div>`;
                    html += `<ol style="margin: 0; padding-left: 20px; font-size: 11px;">`;
                    result.methods.quick.steps.forEach(step => {
                        html += `<li style="margin: 3px 0;">${step}</li>`;
                    });
                    html += `</ol></div>`;
                }
                
                // Router-specific instructions
                if (result.methods?.router?.options) {
                    html += `<div style="padding: 12px; background: #1a1a25; border: 1px solid #0abdc6; border-radius: 8px; margin-bottom: 15px;">`;
                    html += `<div style="font-size: 14px; color: #0abdc6; margin-bottom: 10px;">🔧 Router-Specific Instructions</div>`;
                    
                    const options = result.methods.router.options;
                    html += `<div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px;">`;
                    Object.keys(options).filter(k => k !== 'nuclear').forEach(key => {
                        html += `<button onclick="showRouterInstructions('${key}', '${mac}')" style="background: #2a2a3a; border: 1px solid #0abdc6; color: #0abdc6; padding: 5px 10px; cursor: pointer; border-radius: 4px; font-size: 11px;">${options[key].title}</button>`;
                    });
                    html += `</div>`;
                    html += `<div id="routerInstructions"></div>`;
                    html += `</div>`;
                    
                    // Store instructions globally
                    window.routerBlockInstructions = options;
                }
                
                // Open router button
                if (result.routerIP) {
                    html += `<button onclick="window.open('http://${result.routerIP}', '_blank')" style="background: linear-gradient(135deg, #ff9900, #ff6600); color: #0a0a0f; border: none; padding: 12px 25px; cursor: pointer; border-radius: 5px; font-weight: bold; font-size: 14px;">🌐 Open Router Admin (${result.routerIP})</button>`;
                }
                
                addMessage(html, false);
            } catch (e) {
                addMessage(`❌ Failed to get block instructions: ${e.message}`, false);
            }
        }
        
        // Show router-specific instructions
        function showRouterInstructions(routerType, mac) {
            const instructions = window.routerBlockInstructions?.[routerType];
            if (!instructions) return;
            
            const container = document.getElementById('routerInstructions');
            if (!container) return;
            
            let html = `<div style="margin-top: 10px; padding: 10px; background: #0a0a0f; border-radius: 5px;">`;
            html += `<strong style="color: #00ff41;">${instructions.title}</strong>`;
            html += `<ol style="margin: 8px 0 0 0; padding-left: 20px; font-size: 11px;">`;
            instructions.steps.forEach(step => {
                html += `<li style="margin: 4px 0;">${step}</li>`;
            });
            html += `</ol></div>`;
            
            container.innerHTML = html;
        }
        
        // Load whitelist
        async function loadWhitelist() {
            try {
                const response = await fetch('/api/network-guardian/whitelist');
                const whitelist = await response.json();
                networkGuardianData.whitelist = whitelist.devices || [];
                return whitelist;
            } catch (e) {
                console.error('Failed to load whitelist:', e);
                return { devices: [] };
            }
        }
        
        // Show whitelist modal/panel
        async function showWhitelist() {
            const whitelist = await loadWhitelist();
            
            let html = '<strong>📋 Whitelisted Devices (Trusted)</strong><br><br>';
            
            if (!whitelist.devices || whitelist.devices.length === 0) {
                html += '<span style="color: #666;">No devices whitelisted yet. Run a scan and click + to add devices.</span>';
            } else {
                html += '<table style="width: 100%; font-size: 12px; border-collapse: collapse;">';
                html += '<tr style="color: #00ff41;"><th style="text-align: left;">Name</th><th style="text-align: left;">MAC</th><th style="text-align: left;">Added</th><th>Remove</th></tr>';
                
                whitelist.devices.forEach(d => {
                    html += `<tr style="border-bottom: 1px solid #2a2a3a;">
                        <td style="padding: 5px 0;">${d.name}</td>
                        <td style="font-family: monospace; color: #00ff41; font-size: 10px;">${d.mac}</td>
                        <td style="color: #666; font-size: 10px;">${new Date(d.addedAt).toLocaleDateString()}</td>
                        <td><button onclick="removeFromWhitelist('${d.mac}')" style="background: none; border: 1px solid #ff0040; color: #ff0040; cursor: pointer; padding: 2px 8px; border-radius: 3px; font-size: 10px;">✕</button></td>
                    </tr>`;
                });
                html += '</table>';
            }
            
            addMessage(html, false);
        }
        
        // Remove from whitelist
        async function removeFromWhitelist(mac) {
            if (!confirm(`Remove ${mac} from whitelist?`)) return;
            
            try {
                const response = await fetch(`/api/network-guardian/whitelist/${encodeURIComponent(mac)}`, { method: 'DELETE' });
                const result = await response.json();
                
                if (result.success) {
                    addMessage(`✅ Device removed from whitelist`, false);
                    showWhitelist();
                } else {
                    addMessage(`⚠️ ${result.message}`, false);
                }
            } catch (e) {
                addMessage(`❌ Failed to remove: ${e.message}`, false);
            }
        }
        
        // Show scan history
        async function showNetworkHistory() {
            try {
                const response = await fetch('/api/network-guardian/history?limit=5');
                const history = await response.json();
                
                if (!history || history.length === 0) {
                    addMessage('<strong>📊 Scan History</strong><br><br><span style="color: #666;">No scan history yet. Run your first scan!</span>', false);
                    return;
                }
                
                let html = '<strong>📊 Network Scan History</strong><br><br>';
                
                history.forEach((scan, i) => {
                    const time = new Date(scan.scanTime).toLocaleString();
                    const threats = scan.aiAnalysis?.devices?.filter(d => d.threatLevel !== 'safe').length || 0;
                    
                    html += `<div style="margin-bottom: 10px; padding: 8px; background: #1a1a25; border-radius: 5px; border-left: 3px solid ${threats > 0 ? '#ff9900' : '#00ff41'};">
                        <strong>${time}</strong><br>
                        <span style="font-size: 11px; color: #666;">
                            ${scan.devices?.length || 0} devices found | ${scan.unknownCount || 0} unknown | ${threats} threats
                        </span>
                    </div>`;
                });
                
                addMessage(html, false);
            } catch (e) {
                addMessage(`❌ Failed to load history: ${e.message}`, false);
            }
        }
        
        // Initialize Network Guardian on page load
        initNetworkGuardian();
        loadWhitelist();
        
        // ═══════════════════════════════════════════════════════════════
        // DEVICE ACTIVITY MONITOR - Real-Time AI-Powered Tracking
        // ═══════════════════════════════════════════════════════════════
        
        let activeDeviceMonitors = new Map();
        let activityEventSource = null;
        
        // Start monitoring a device
        async function startDeviceMonitoring(ip, mac, name) {
            addMessage(`📊 <strong>Starting activity monitoring for ${name} (${ip})...</strong>`, true);
            
            try {
                const response = await fetch('/api/device-monitor/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ip, mac, name })
                });
                const result = await response.json();
                
                if (result.success) {
                    activeDeviceMonitors.set(ip, { name, mac, sessionId: result.sessionId });
                    
                    // Start real-time activity stream
                    startActivityStream(ip, name);
                    
                    // Show monitoring panel
                    showDeviceMonitorPanel(ip, name, mac);
                    
                    addMessage(`✅ <strong>Now monitoring ${name}</strong><br>Real-time activity will appear below. Click "Stop" to end monitoring.`, false);
                } else if (result.sessionId) {
                    // Already monitoring
                    showDeviceMonitorPanel(ip, name, mac);
                    startActivityStream(ip, name);
                    addMessage(`ℹ️ Already monitoring ${name}. Showing activity panel.`, false);
                } else {
                    addMessage(`❌ Failed to start monitoring: ${result.error}`, false);
                }
            } catch (e) {
                addMessage(`❌ Monitoring failed: ${e.message}`, false);
            }
        }
        
        // Stop monitoring a device
        async function stopDeviceMonitoring(ip) {
            try {
                const response = await fetch('/api/device-monitor/stop', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ip })
                });
                const result = await response.json();
                
                activeDeviceMonitors.delete(ip);
                
                if (activityEventSource) {
                    activityEventSource.close();
                    activityEventSource = null;
                }
                
                // Hide monitoring panel
                const panel = document.getElementById('deviceMonitorPanel');
                if (panel) panel.remove();
                
                if (result.success) {
                    addMessage(`🛑 <strong>Stopped monitoring</strong><br>Total queries: ${result.stats?.totalQueries || 0}`, false);
                }
            } catch (e) {
                addMessage(`❌ Failed to stop: ${e.message}`, false);
            }
        }
        
        // Start real-time activity stream
        function startActivityStream(ip, name) {
            if (activityEventSource) {
                activityEventSource.close();
            }
            
            activityEventSource = new EventSource(`/api/device-monitor/stream/${encodeURIComponent(ip)}`);
            
            activityEventSource.onmessage = (event) => {
                try {
                    const activity = JSON.parse(event.data);
                    updateActivityFeed(activity);
                } catch (e) {}
            };
            
            activityEventSource.onerror = () => {
                // Reconnect on error
                setTimeout(() => {
                    if (activeDeviceMonitors.has(ip)) {
                        startActivityStream(ip, name);
                    }
                }, 5000);
            };
        }
        
        // Show device monitoring panel
        function showDeviceMonitorPanel(ip, name, mac) {
            // Remove existing panel if any
            const existing = document.getElementById('deviceMonitorPanel');
            if (existing) existing.remove();
            
            const panel = document.createElement('div');
            panel.id = 'deviceMonitorPanel';
            panel.style.cssText = `
                position: fixed;
                bottom: 20px;
                right: 20px;
                width: 400px;
                max-height: 500px;
                background: linear-gradient(135deg, #1a1a25, #0a0a0f);
                border: 2px solid #8b5cf6;
                border-radius: 12px;
                padding: 15px;
                z-index: 1000;
                box-shadow: 0 10px 40px rgba(139, 92, 246, 0.3);
                overflow: hidden;
            `;
            
            panel.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                    <div>
                        <span style="color: #8b5cf6; font-weight: bold;">📊 Live Activity Monitor</span><br>
                        <span style="font-size: 11px; color: #666;">${name} (${ip})</span>
                    </div>
                    <div>
                        <button onclick="analyzeDeviceActivity('${ip}')" style="background: #0abdc6; border: none; color: #0a0a0f; padding: 5px 10px; border-radius: 4px; cursor: pointer; margin-right: 5px;">🤖 AI Analyze</button>
                        <button onclick="stopDeviceMonitoring('${ip}')" style="background: #ff0040; border: none; color: white; padding: 5px 10px; border-radius: 4px; cursor: pointer;">✕ Stop</button>
                    </div>
                </div>
                
                <div id="activityStats" style="display: flex; gap: 10px; margin-bottom: 10px; font-size: 11px;">
                    <div style="flex: 1; padding: 8px; background: #0a0a0f; border-radius: 6px; text-align: center;">
                        <div style="color: #8b5cf6; font-size: 18px;" id="totalQueries">0</div>
                        <div style="color: #666;">Queries</div>
                    </div>
                    <div style="flex: 1; padding: 8px; background: #0a0a0f; border-radius: 6px; text-align: center;">
                        <div style="color: #00ff41; font-size: 14px;" id="topApp">-</div>
                        <div style="color: #666;">Top App</div>
                    </div>
                    <div style="flex: 1; padding: 8px; background: #0a0a0f; border-radius: 6px; text-align: center;">
                        <div style="color: #ff9900; font-size: 14px;" id="topCategory">-</div>
                        <div style="color: #666;">Category</div>
                    </div>
                </div>
                
                <div style="font-size: 11px; color: #666; margin-bottom: 5px;">Recent Activity:</div>
                <div id="activityFeed" style="max-height: 250px; overflow-y: auto; font-size: 11px;">
                    <div style="color: #666; text-align: center; padding: 20px;">Waiting for activity...</div>
                </div>
            `;
            
            document.body.appendChild(panel);
            
            // Poll for activity updates
            pollDeviceActivity(ip);
        }
        
        // Poll for activity (fallback if SSE doesn't work)
        async function pollDeviceActivity(ip) {
            if (!activeDeviceMonitors.has(ip)) return;
            
            try {
                const response = await fetch(`/api/device-monitor/activity/${encodeURIComponent(ip)}`);
                const data = await response.json();
                
                if (!data.error) {
                    // Update stats
                    document.getElementById('totalQueries').textContent = data.stats?.totalQueries || 0;
                    
                    if (data.topApps?.[0]) {
                        document.getElementById('topApp').textContent = data.topApps[0].app;
                    }
                    if (data.topCategories?.[0]) {
                        document.getElementById('topCategory').textContent = data.topCategories[0].category;
                    }
                    
                    // Update feed
                    if (data.activity?.length > 0) {
                        const feed = document.getElementById('activityFeed');
                        let html = '';
                        data.activity.slice(0, 30).forEach(a => {
                            const time = new Date(a.timestamp).toLocaleTimeString();
                            html += `<div style="padding: 4px 0; border-bottom: 1px solid #1a1a25;">
                                <span style="color: #666;">${time}</span>
                                <span style="margin: 0 5px;">${a.icon || '🌐'}</span>
                                <span style="color: #0abdc6;">${a.app}</span>
                                <span style="color: #444; font-size: 10px; margin-left: 5px;">${a.domain}</span>
                            </div>`;
                        });
                        feed.innerHTML = html;
                    }
                }
            } catch (e) {}
            
            // Continue polling if still monitoring
            if (activeDeviceMonitors.has(ip)) {
                setTimeout(() => pollDeviceActivity(ip), 3000);
            }
        }
        
        // Update activity feed with new entry
        function updateActivityFeed(activity) {
            const feed = document.getElementById('activityFeed');
            if (!feed) return;
            
            const time = new Date(activity.timestamp).toLocaleTimeString();
            const entry = document.createElement('div');
            entry.style.cssText = 'padding: 4px 0; border-bottom: 1px solid #1a1a25; animation: fadeIn 0.3s;';
            entry.innerHTML = `
                <span style="color: #666;">${time}</span>
                <span style="margin: 0 5px;">${activity.icon || '🌐'}</span>
                <span style="color: #0abdc6;">${activity.app}</span>
                <span style="color: #444; font-size: 10px; margin-left: 5px;">${activity.domain}</span>
            `;
            
            feed.insertBefore(entry, feed.firstChild);
            
            // Keep only last 30 entries
            while (feed.children.length > 30) {
                feed.removeChild(feed.lastChild);
            }
            
            // Update query count
            const countEl = document.getElementById('totalQueries');
            if (countEl) {
                countEl.textContent = parseInt(countEl.textContent) + 1;
            }
        }
        
        // AI analyze device activity
        async function analyzeDeviceActivity(ip) {
            addMessage(`🤖 <strong>AI analyzing activity for ${ip}...</strong>`, true);
            
            try {
                const response = await fetch(`/api/device-monitor/analyze/${encodeURIComponent(ip)}`);
                const analysis = await response.json();
                
                if (analysis.error) {
                    addMessage(`❌ Analysis failed: ${analysis.error}`, false);
                    return;
                }
                
                let html = `<strong>🤖 AI Activity Analysis</strong><br><br>`;
                
                html += `<div style="padding: 12px; background: linear-gradient(135deg, #1a1a25, #0a0a0f); border: 1px solid #8b5cf6; border-radius: 8px; margin-bottom: 15px;">`;
                html += `<div style="font-size: 16px; margin-bottom: 8px;">📱 <strong>Device Type:</strong> ${analysis.deviceType}</div>`;
                html += `<div style="font-size: 14px; margin-bottom: 8px;">🎯 <strong>Primary Usage:</strong> ${analysis.primaryUsage}</div>`;
                html += `<div style="font-size: 12px; color: #999;">${analysis.summary}</div>`;
                html += `</div>`;
                
                // Privacy score
                const privacyColor = analysis.privacyScore >= 7 ? '#00ff41' : analysis.privacyScore >= 4 ? '#ff9900' : '#ff0040';
                html += `<div style="margin-bottom: 15px;">`;
                html += `<strong>🔒 Privacy Score:</strong> <span style="color: ${privacyColor}; font-size: 20px;">${analysis.privacyScore}/10</span>`;
                html += `</div>`;
                
                // Insights
                if (analysis.insights?.length > 0) {
                    html += `<div style="margin-bottom: 15px;">`;
                    html += `<strong>💡 Insights:</strong><ul style="margin: 5px 0; padding-left: 20px;">`;
                    analysis.insights.forEach(i => {
                        html += `<li style="margin: 3px 0;">${i}</li>`;
                    });
                    html += `</ul></div>`;
                }
                
                // Concerns
                if (analysis.concerns?.length > 0) {
                    html += `<div style="padding: 10px; background: #2a1a1a; border: 1px solid #ff0040; border-radius: 5px;">`;
                    html += `<strong style="color: #ff0040;">⚠️ Concerns:</strong><ul style="margin: 5px 0; padding-left: 20px;">`;
                    analysis.concerns.forEach(c => {
                        html += `<li style="margin: 3px 0;">${c}</li>`;
                    });
                    html += `</ul></div>`;
                }
                
                html += `<div style="margin-top: 10px; font-size: 10px; color: #666;">`;
                html += analysis.aiPowered ? '🤖 AI-powered analysis' : '📊 Heuristic analysis';
                html += `</div>`;
                
                addMessage(html, false);
            } catch (e) {
                addMessage(`❌ Analysis failed: ${e.message}`, false);
            }
        }
        
        // ═══════════════════════════════════════════════════════════════
        // NETWORK TRAFFIC SNIFFER FUNCTIONS
        // ═══════════════════════════════════════════════════════════════
        
        let activeNetworkCapture = null;
        
        function showNetworkStatus(message, isActive = true) {
            const statusDiv = document.getElementById('networkStatus');
            const statusText = document.getElementById('networkStatusText');
            statusDiv.style.display = 'block';
            statusText.textContent = message;
            statusDiv.querySelector('span').style.color = isActive ? '#00ff41' : '#ff0040';
        }
        
        async function startNetworkCapture(captureType) {
            const target = document.getElementById('networkTarget').value.trim() || 'local';
            
            showNetworkStatus(`Starting ${captureType.toUpperCase()} capture...`);
            addMessage(`📡 <strong>Network Capture:</strong> ${captureType.toUpperCase()} traffic on ${target}`, true);
            
            try {
                const response = await fetch('/api/network/capture', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ target, captureType })
                });
                
                const data = await response.json();
                
                if (data.error) {
                    showNetworkStatus(data.error, false);
                    addMessage(`❌ ${data.error}`);
                    return;
                }
                
                activeNetworkCapture = data.captureId;
                showNetworkStatus(`Capturing ${captureType} traffic...`);
                
                // Poll for results
                setTimeout(() => pollNetworkCapture(data.captureId, captureType), 3000);
                
            } catch (err) {
                showNetworkStatus('Capture failed', false);
                addMessage(`❌ Network Error: ${err.message}`);
            }
        }
        
        async function pollNetworkCapture(captureId, captureType) {
            try {
                const response = await fetch(`/api/network/capture/${captureId}`);
                const data = await response.json();
                
                if (data.status === 'complete') {
                    showNetworkStatus('Capture complete', true);
                    displayNetworkResults(data, captureType);
                } else if (data.status === 'running') {
                    setTimeout(() => pollNetworkCapture(captureId, captureType), 2000);
                }
            } catch (err) {
                showNetworkStatus('Error fetching results', false);
            }
        }
        
        async function displayNetworkResults(data, captureType) {
            let html = `<div style="background: linear-gradient(135deg, rgba(0,0,0,0.5), rgba(255,0,255,0.1)); border: 2px solid #ff00ff; border-radius: 12px; padding: 20px;">`;
            html += `<div style="text-align: center; margin-bottom: 15px;">`;
            html += `<div style="font-family: 'Orbitron', sans-serif; font-size: 1.3em; color: #ff00ff;">📡 NETWORK CAPTURE RESULTS</div>`;
            html += `<div style="color: #888;">${captureType.toUpperCase()} Traffic</div>`;
            html += `</div>`;
            
            html += `<div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px;">`;
            html += `<pre style="color: #00ff41; font-size: 11px; overflow-x: auto; white-space: pre-wrap;">${data.output || 'No traffic captured'}</pre>`;
            html += `</div>`;
            
            if (data.aiAnalysis) {
                html += `<div style="margin-top: 15px; padding: 15px; background: rgba(10,189,198,0.1); border-radius: 8px;">`;
                html += `<div style="color: #0abdc6; font-weight: bold; margin-bottom: 10px;">🧠 AI Analysis</div>`;
                html += `<div style="color: #e0e0e0; white-space: pre-wrap;">${data.aiAnalysis}</div>`;
                html += `</div>`;
            }
            
            html += `</div>`;
            addMessage(html);
            
            // 🔧 FIX: Attach network capture results to chat context so Neo can reference them
            try {
                await fetch('/api/chat/attach-context', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        sessionId,
                        contextType: `Network Capture (${captureType.toUpperCase()})`,
                        context: data.output || 'No traffic captured'
                    })
                });
                console.log('Network capture context attached to session');
            } catch (e) {
                console.warn('Failed to attach network capture context:', e);
            }
        }
        
        async function startPortScan(scanType) {
            const target = document.getElementById('networkTarget').value.trim();
            
            if (!target || target === 'local') {
                alert('Please enter a target IP or domain for port scanning');
                return;
            }
            
            showNetworkStatus(`Starting ${scanType} port scan...`);
            addMessage(`🔍 <strong>Port Scan:</strong> ${scanType.toUpperCase()} scan on ${target}`, true);
            
            try {
                const response = await fetch('/api/network/portscan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ target, scanType })
                });
                
                const data = await response.json();
                
                if (data.error) {
                    showNetworkStatus(data.error, false);
                    addMessage(`❌ ${data.error}`);
                    return;
                }
                
                showNetworkStatus(`Port scan running...`);
                
                // Poll for results
                const pollScan = setInterval(async () => {
                    const res = await fetch(`/api/network/portscan/${data.scanId}`);
                    const result = await res.json();
                    
                    if (result.status === 'complete') {
                        clearInterval(pollScan);
                        showNetworkStatus('Scan complete', true);
                        displayPortScanResults(result);
                    }
                }, 3000);
                
            } catch (err) {
                showNetworkStatus('Scan failed', false);
                addMessage(`❌ Port Scan Error: ${err.message}`);
            }
        }
        
        async function displayPortScanResults(data) {
            let html = `<div style="background: linear-gradient(135deg, rgba(0,0,0,0.5), rgba(0,255,65,0.1)); border: 2px solid #00ff41; border-radius: 12px; padding: 20px;">`;
            html += `<div style="text-align: center; margin-bottom: 15px;">`;
            html += `<div style="font-family: 'Orbitron', sans-serif; font-size: 1.3em; color: #00ff41;">🔍 PORT SCAN RESULTS</div>`;
            html += `<div style="color: #888;">${data.target}</div>`;
            html += `</div>`;
            
            if (data.openPorts && data.openPorts.length > 0) {
                html += `<div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; margin-bottom: 15px;">`;
                html += `<div style="color: #ff0040; font-weight: bold; margin-bottom: 10px;">🚨 Open Ports (${data.openPorts.length})</div>`;
                html += `<table style="width: 100%; color: #e0e0e0; font-size: 12px;">`;
                html += `<tr style="color: #0abdc6;"><th>Port</th><th>Service</th><th>Version</th></tr>`;
                data.openPorts.forEach(p => {
                    html += `<tr><td>${p.port}</td><td>${p.service || '-'}</td><td>${p.version || '-'}</td></tr>`;
                });
                html += `</table></div>`;
            }
            
            html += `<div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px;">`;
            html += `<pre style="color: #00ff41; font-size: 10px; overflow-x: auto; white-space: pre-wrap;">${data.rawOutput || ''}</pre>`;
            html += `</div>`;
            
            if (data.aiAnalysis) {
                html += `<div style="margin-top: 15px; padding: 15px; background: rgba(10,189,198,0.1); border-radius: 8px;">`;
                html += `<div style="color: #0abdc6; font-weight: bold; margin-bottom: 10px;">🧠 AI Security Analysis</div>`;
                html += `<div style="color: #e0e0e0; white-space: pre-wrap;">${data.aiAnalysis}</div>`;
                html += `</div>`;
            }
            
            html += `</div>`;
            addMessage(html);
            
            // 🔧 FIX: Attach port scan results to chat context so Neo can reference them
            try {
                const contextData = {
                    target: data.target,
                    openPorts: data.openPorts || [],
                    rawOutput: data.rawOutput,
                    aiAnalysis: data.aiAnalysis
                };
                await fetch('/api/chat/attach-context', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        sessionId,
                        contextType: 'Port Scan',
                        context: JSON.stringify(contextData, null, 2)
                    })
                });
                console.log('Port scan context attached to session');
            } catch (e) {
                console.warn('Failed to attach port scan context:', e);
            }
        }
        
        async function startMobileProxy() {
            showNetworkStatus('Starting MITM Proxy on port 8080...');
            addMessage(`📱 <strong>Mobile Traffic Interceptor:</strong> Starting MITM Proxy...`, true);
            
            try {
                const response = await fetch('/api/network/mitmproxy', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'start' })
                });
                
                const data = await response.json();
                
                if (data.error) {
                    showNetworkStatus(data.error, false);
                    addMessage(`❌ ${data.error}`);
                    return;
                }
                
                showNetworkStatus('MITM Proxy running on :8080');
                
                let html = `<div style="background: linear-gradient(135deg, rgba(0,0,0,0.5), rgba(10,189,198,0.1)); border: 2px solid #0abdc6; border-radius: 12px; padding: 20px;">`;
                html += `<div style="text-align: center; margin-bottom: 15px;">`;
                html += `<div style="font-family: 'Orbitron', sans-serif; font-size: 1.3em; color: #0abdc6;">📱 MITM PROXY ACTIVE</div>`;
                html += `</div>`;
                html += `<div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px;">`;
                html += `<p style="color: #00ff41; margin-bottom: 10px;">✅ Proxy running on port 8080</p>`;
                html += `<p style="color: #e0e0e0; font-size: 12px;"><strong>To intercept mobile traffic:</strong></p>`;
                html += `<ol style="color: #888; font-size: 11px; margin-left: 20px;">`;
                html += `<li>Connect your device to the same WiFi</li>`;
                html += `<li>Set HTTP Proxy to: <span style="color: #00ff41;">${data.localIP || 'YOUR_MAC_IP'}:8080</span></li>`;
                html += `<li>Visit <span style="color: #0abdc6;">mitm.it</span> to install the CA certificate</li>`;
                html += `<li>Traffic will appear in the console</li>`;
                html += `</ol>`;
                html += `</div>`;
                html += `<button onclick="stopMobileProxy()" style="width: 100%; margin-top: 15px; padding: 10px; background: #ff0040; border: none; border-radius: 6px; color: white; cursor: pointer;">🛑 Stop Proxy</button>`;
                html += `</div>`;
                
                addMessage(html);
                
            } catch (err) {
                showNetworkStatus('Failed to start proxy', false);
                addMessage(`❌ MITM Proxy Error: ${err.message}`);
            }
        }
        
        async function stopMobileProxy() {
            try {
                await fetch('/api/network/mitmproxy', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'stop' })
                });
                showNetworkStatus('Proxy stopped', false);
                addMessage(`🛑 MITM Proxy stopped`);
            } catch (err) {
                console.error('Stop proxy error:', err);
            }
        }
        
        // ═══════════════════════════════════════════════════════════════
        // AI REPORT FUNCTIONS (Dedicated Report Section)
        // ═══════════════════════════════════════════════════════════════
        
        let currentReportData = null;
        
        async function generateAIReport() {
            if (!currentScanId) return alert('No scan to generate report for');
            
            const btn = document.getElementById('generateReportBtn');
            const statusEl = document.getElementById('aiReportStatus');
            btn.textContent = '⏳ Generating...';
            btn.disabled = true;
            statusEl.innerHTML = '🔄 AI is analyzing your scan results...';
            
            // Show report section with loading state
            document.getElementById('reportSection').style.display = 'block';
            document.getElementById('reportContent').innerHTML = `
                <div style="text-align: center; padding: 60px; color: #0abdc6;">
                    <div style="font-size: 4em; margin-bottom: 20px; animation: pulse 2s infinite;">🧠</div>
                    <p style="font-size: 1.2em;">AI is generating your security assessment...</p>
                    <p style="color: #666; margin-top: 10px;">This may take 15-30 seconds</p>
                </div>
            `;
            
            // Scroll to report section
            document.getElementById('reportSection').scrollIntoView({ behavior: 'smooth' });
            
            try {
                const res = await fetch(`/api/scan/${currentScanId}/report`);
                const data = await res.json();
                currentReportData = data;
                
                // Update status
                if (data.aiPowered) {
                    statusEl.innerHTML = '✅ AI Report Generated!';
                } else {
                    statusEl.innerHTML = '⚠️ Basic report (configure Claude API for AI)';
                }
                
                // Get scan info for header
                const scanRes = await fetch(`/api/scan/${currentScanId}`);
                const scanData = await scanRes.json();
                
                document.getElementById('reportTarget').textContent = `Target: ${scanData.target || 'Unknown'}`;
                document.getElementById('reportTimestamp').textContent = `Generated: ${new Date().toLocaleString()}`;
                
                // Format and display report
                const formattedReport = formatReportContent(data.report, data.aiPowered);
                document.getElementById('reportContent').innerHTML = formattedReport;
                
            } catch (error) {
                document.getElementById('reportContent').innerHTML = `
                    <div style="text-align: center; padding: 40px; color: #ff0040;">
                        <div style="font-size: 3em; margin-bottom: 20px;">❌</div>
                        <p>Failed to generate report: ${error.message}</p>
                    </div>
                `;
            }
            
            btn.textContent = '📋 Generate Scan Results';
            btn.disabled = false;
        }
        
        function formatReportContent(report, aiPowered) {
            if (!report) return '<p style="color: #666;">No report content available.</p>';
            
            // Convert markdown-like formatting to HTML
            let html = report
                // Headers
                .replace(/### (.*?)(?:\n|$)/g, '<h4 style="color: #ffaa00; margin: 20px 0 10px; font-size: 1.1em;">$1</h4>')
                .replace(/## (.*?)(?:\n|$)/g, '<h3 style="color: #0abdc6; margin: 25px 0 15px; font-size: 1.3em; border-bottom: 1px solid #2a2a3a; padding-bottom: 10px;">$1</h3>')
                .replace(/# (.*?)(?:\n|$)/g, '<h2 style="color: #00ff41; margin: 30px 0 20px; font-size: 1.5em;">$1</h2>')
                // Bold
                .replace(/\*\*(.*?)\*\*/g, '<strong style="color: #fff;">$1</strong>')
                // Lists
                .replace(/^- (.*?)$/gm, '<li style="margin: 5px 0; margin-left: 20px;">$1</li>')
                .replace(/^\d+\. (.*?)$/gm, '<li style="margin: 5px 0; margin-left: 20px;">$1</li>')
                // Code blocks
                .replace(/`([^`]+)`/g, '<code style="background: #1a1a25; padding: 2px 6px; border-radius: 3px; color: #00ff41;">$1</code>')
                // Line breaks
                .replace(/\n\n/g, '</p><p style="margin: 15px 0;">')
                .replace(/\n/g, '<br>');
            
            // Wrap in paragraph
            html = '<p style="margin: 15px 0;">' + html + '</p>';
            
            // Add AI badge
            const badge = aiPowered 
                ? '<div style="display: inline-block; background: linear-gradient(135deg, #00ff41, #0abdc6); color: #0a0a0f; padding: 5px 15px; border-radius: 20px; font-weight: bold; margin-bottom: 20px;">🤖 AI-Powered Analysis</div>'
                : '<div style="display: inline-block; background: #333; color: #ffaa00; padding: 5px 15px; border-radius: 20px; font-weight: bold; margin-bottom: 20px;">⚠️ Basic Analysis (Configure Claude API for AI)</div>';
            
            return badge + html;
        }
        
        function closeReportSection() {
            document.getElementById('reportSection').style.display = 'none';
        }
        
        async function exportPDF() {
            if (!currentScanId) return alert('No scan to export');
            
            // For now, open HTML export (can be printed to PDF)
            // Later: integrate proper PDF generation
            const win = window.open(`/api/scan/${currentScanId}/export/html`, '_blank');
            
            // Show instructions
            alert('📄 HTML Report opened in new tab.\\n\\nTo save as PDF:\\n1. Press Ctrl+P (or Cmd+P on Mac)\\n2. Select "Save as PDF"\\n3. Click Save');
        }
        
        async function exportHTML() {
            if (!currentScanId) return alert('No scan to export');
            window.open(`/api/scan/${currentScanId}/export/html`, '_blank');
        }
        
        // Show AI report panel when scan completes
        function showAIReportPanel() {
            document.getElementById('aiReportPanel').style.display = 'block';
        }
        
        // Hook into scan completion
        const originalUpdateScanUI = typeof updateScanUI === 'function' ? updateScanUI : null;
        if (originalUpdateScanUI) {
            updateScanUI = function(data) {
                originalUpdateScanUI(data);
                if (data.status === 'complete') {
                    showAIReportPanel();
                }
            };
        }

        // ═══════════════════════════════════════════════════════════════
        // 🛡️ DEVICE DASHBOARD - Interactive Network Device Management
        // ═══════════════════════════════════════════════════════════════
        
        let deviceDashboardData = {
            devices: [],
            lastScan: null,
            selectedDevice: null,
            activeMonitors: new Map(),
            currentFilter: 'all'
        };
        
        // Open device dashboard with scan results
        function openDeviceDashboard(scanResult) {
            if (!scanResult || !scanResult.devices) {
                console.error('No scan data to display');
                return;
            }
            
            deviceDashboardData.devices = scanResult.devices || [];
            deviceDashboardData.lastScan = scanResult.scanTime || new Date().toISOString();
            deviceDashboardData.aiAnalysis = scanResult.aiAnalysis || null;
            
            // Update stats
            const threats = deviceDashboardData.devices.filter(d => 
                d.threatLevel === 'high' || d.threatLevel === 'critical' || d.isSuspicious
            ).length;
            
            document.getElementById('dashDeviceCount').textContent = deviceDashboardData.devices.length;
            document.getElementById('dashThreatCount').textContent = threats;
            document.getElementById('dashboardLastScan').textContent = `Last scan: ${new Date(deviceDashboardData.lastScan).toLocaleTimeString()}`;
            
            // Render device list
            renderDeviceList();
            
            // Show dashboard
            document.getElementById('deviceDashboard').style.display = 'block';
            document.getElementById('deviceDashboard').scrollIntoView({ behavior: 'smooth' });
        }
        
        // Render device list
        function renderDeviceList() {
            const container = document.getElementById('deviceListContainer');
            const devices = deviceDashboardData.devices;
            const filter = deviceDashboardData.currentFilter;
            const searchTerm = (document.getElementById('deviceSearchInput')?.value || '').toLowerCase();
            
            // Filter devices
            let filtered = devices.filter(d => {
                // Search filter
                const searchMatch = !searchTerm || 
                    d.ip?.toLowerCase().includes(searchTerm) ||
                    d.mac?.toLowerCase().includes(searchTerm) ||
                    d.vendor?.toLowerCase().includes(searchTerm) ||
                    d.hostname?.toLowerCase().includes(searchTerm) ||
                    d.deviceType?.toLowerCase().includes(searchTerm) ||
                    d.whitelistName?.toLowerCase().includes(searchTerm);
                
                if (!searchMatch) return false;
                
                // Status filter
                if (filter === 'all') return true;
                if (filter === 'trusted') return d.whitelisted;
                if (filter === 'unknown') return !d.whitelisted && !d.isSuspicious;
                if (filter === 'threat') return d.isSuspicious || d.threatLevel === 'high' || d.threatLevel === 'critical';
                return true;
            });
            
            if (filtered.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 40px; color: #666;">
                        <div style="font-size: 2em; margin-bottom: 10px;">🔍</div>
                        <p>No devices match your filter</p>
                    </div>
                `;
                return;
            }
            
            container.innerHTML = filtered.map((device, index) => {
                const isSelected = deviceDashboardData.selectedDevice?.mac === device.mac;
                const hasAiAnalysis = !!device.aiAnalysis;
                const statusColor = device.whitelisted ? '#00ff41' : 
                                   (device.isSuspicious || device.threatLevel === 'high' || device.threatLevel === 'critical') ? '#ff0040' : 
                                   (device.threatLevel === 'medium') ? '#ffaa00' :
                                   hasAiAnalysis ? '#0abdc6' : '#666';
                const statusIcon = device.whitelisted ? '✓' : 
                                  (device.isSuspicious || device.threatLevel === 'high') ? '⚠' : 
                                  hasAiAnalysis ? '✓' : '?';
                const statusText = device.whitelisted ? 'Trusted' : 
                                  (device.isSuspicious || device.threatLevel === 'high') ? 'Threat' : 
                                  hasAiAnalysis ? 'Safe' : 'Click to analyze';
                const deviceIcon = getDeviceIcon(device);
                const deviceName = device.whitelistName || device.aiAnalysis?.deviceType || device.deviceType || device.hostname || 'Unknown Device';
                
                return `
                    <div class="device-list-item" onclick="selectDevice(${index})" 
                         style="padding: 12px; margin-bottom: 8px; background: ${isSelected ? '#1a2a1a' : '#1a1a25'}; 
                                border: 1px solid ${isSelected ? '#00ff41' : '#2a2a3a'}; border-radius: 8px; cursor: pointer;
                                transition: all 0.2s; ${isSelected ? 'box-shadow: 0 0 15px rgba(0,255,65,0.2);' : ''}">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <span style="font-size: 1.5em;">${deviceIcon}</span>
                            <div style="flex: 1; min-width: 0;">
                                <div style="font-weight: bold; color: #e0e0e0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    ${deviceName}
                                </div>
                                <div style="font-size: 11px; color: #888;">
                                    ${device.ip} • ${device.vendor || 'Unknown'}
                                </div>
                            </div>
                            <span style="background: ${statusColor}20; color: ${statusColor}; padding: 4px 8px; border-radius: 12px; font-size: 10px; font-weight: bold;">
                                ${statusIcon} ${statusText}
                            </span>
                        </div>
                        ${hasAiAnalysis ? `<div style="margin-top: 8px; font-size: 10px; color: #8b5cf6;">🤖 AI analyzed</div>` : ''}
                    </div>
                `;
            }).join('');
        }
        
        // Get device icon based on type/vendor
        function getDeviceIcon(device) {
            const vendor = (device.vendor || '').toLowerCase();
            const deviceType = (device.deviceType || '').toLowerCase();
            
            if (vendor.includes('apple') || deviceType.includes('apple') || deviceType.includes('iphone') || deviceType.includes('mac')) return '🍎';
            if (vendor.includes('samsung') || deviceType.includes('samsung')) return '📱';
            if (vendor.includes('amazon') || deviceType.includes('echo') || deviceType.includes('ring')) return '📦';
            if (vendor.includes('google') || deviceType.includes('nest') || deviceType.includes('chromecast')) return '🔷';
            if (vendor.includes('roku') || deviceType.includes('roku')) return '📺';
            if (vendor.includes('sonos') || deviceType.includes('speaker')) return '🔊';
            if (vendor.includes('intel') || deviceType.includes('pc') || deviceType.includes('computer')) return '💻';
            if (vendor.includes('tp-link') || vendor.includes('netgear') || deviceType.includes('router')) return '📡';
            if (vendor.includes('espressif') || deviceType.includes('iot') || deviceType.includes('smart')) return '🏠';
            if (device.vendorInfo?.isRandomized || deviceType.includes('private')) return '📱';
            if (device.isSuspicious) return '⚠️';
            return '🔌';
        }
        
        // Select a device and show details - Auto AI identification
        async function selectDevice(index) {
            const device = deviceDashboardData.devices[index];
            if (!device) return;
            
            deviceDashboardData.selectedDevice = device;
            renderDeviceList(); // Re-render to show selection
            
            const panel = document.getElementById('deviceDetailPanel');
            
            // Show loading state first
            panel.innerHTML = `
                <div style="text-align: center; padding: 60px;">
                    <div style="font-size: 3em; margin-bottom: 20px; animation: pulse 1s infinite;">🤖</div>
                    <p style="color: #8b5cf6; font-size: 1.2em;">Analyzing device...</p>
                    <p style="color: #666; margin-top: 10px;">AI is identifying this device</p>
                </div>
            `;
            
            // Auto-run AI identification if not already analyzed
            let aiAnalysis = device.aiAnalysis;
            if (!aiAnalysis) {
                try {
                    const response = await fetch('/api/network-guardian/identify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(device)
                    });
                    aiAnalysis = await response.json();
                    
                    // Cache the analysis on the device
                    device.aiAnalysis = aiAnalysis;
                    device.deviceType = aiAnalysis.deviceType;
                    device.threatLevel = aiAnalysis.threatLevel;
                    device.isSuspicious = aiAnalysis.isSuspicious;
                    
                    // Update device list to show new info
                    renderDeviceList();
                } catch (e) {
                    console.error('AI analysis failed:', e);
                    aiAnalysis = {
                        deviceType: device.vendor || 'Unknown Device',
                        threatLevel: 'low',
                        confidence: 'low',
                        explanation: 'Could not analyze device. Check network connection.',
                        recommendation: 'If you recognize this device, add it to trusted devices.'
                    };
                }
            }
            
            const threatColor = device.whitelisted ? '#00ff41' : 
                               (device.isSuspicious || device.threatLevel === 'high' || device.threatLevel === 'critical') ? '#ff0040' : 
                               (device.threatLevel === 'medium') ? '#ffaa00' : '#0abdc6';
            
            const threatBadge = device.whitelisted ? '✓ TRUSTED' : 
                               (device.isSuspicious || device.threatLevel === 'high') ? '⚠ THREAT' : 
                               (device.threatLevel === 'medium') ? '? REVIEW' : '✓ SAFE';
            
            // Render full detail view
            panel.innerHTML = `
                <!-- Device Header -->
                <div style="background: linear-gradient(135deg, ${threatColor}15, transparent); padding: 20px; border-radius: 12px; border: 1px solid ${threatColor}50; margin-bottom: 20px;">
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <span style="font-size: 3.5em;">${getDeviceIcon(device)}</span>
                        <div style="flex: 1;">
                            <h3 style="margin: 0; color: #e0e0e0; font-size: 1.6em;" id="deviceName-${device.ip.replace(/\./g, '-')}">${device.whitelistName || aiAnalysis.deviceType || device.hostname || 'Unknown Device'}</h3>
                            <p style="margin: 8px 0 0; color: #888; font-size: 0.95em;">${device.vendor || 'Unknown manufacturer'}</p>
                            <div style="margin-top: 10px; display: flex; gap: 8px; flex-wrap: wrap;">
                                <span style="background: ${threatColor}; color: #0a0a0f; padding: 4px 12px; border-radius: 12px; font-size: 11px; font-weight: bold;">
                                    ${threatBadge}
                                </span>
                                <span style="background: #2a2a3a; color: #888; padding: 4px 12px; border-radius: 12px; font-size: 11px;">
                                    ${aiAnalysis.confidence || 'medium'} confidence
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Device Info Grid -->
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 20px;">
                    <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #2a2a3a;">
                        <div style="color: #666; font-size: 10px; text-transform: uppercase; margin-bottom: 5px;">IP Address</div>
                        <div style="color: #00ff41; font-size: 1.1em; font-family: 'JetBrains Mono', monospace;">${device.ip}</div>
                    </div>
                    <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #2a2a3a;">
                        <div style="color: #666; font-size: 10px; text-transform: uppercase; margin-bottom: 5px;">MAC Address</div>
                        <div style="color: #0abdc6; font-size: 0.95em; font-family: 'JetBrains Mono', monospace;">${device.mac}</div>
                    </div>
                </div>
                
                <!-- AI Analysis Section -->
                <div style="background: linear-gradient(135deg, #1a1a25, #0f0f18); padding: 20px; border-radius: 12px; border: 1px solid #8b5cf6; margin-bottom: 20px;">
                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 15px;">
                        <span style="font-size: 1.3em;">🤖</span>
                        <span style="color: #8b5cf6; font-weight: bold; font-size: 1.1em;">AI ANALYSIS</span>
                        <span style="margin-left: auto; color: #666; font-size: 10px;">${aiAnalysis.aiSource || 'heuristic'}</span>
                    </div>
                    
                    <!-- Threat Level Bar -->
                    <div style="margin-bottom: 20px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                            <span style="color: #888; font-size: 12px;">Threat Level</span>
                            <span style="color: ${getThreatColor(aiAnalysis.threatLevel)}; font-weight: bold; text-transform: uppercase;">${aiAnalysis.threatLevel || 'unknown'}</span>
                        </div>
                        <div style="height: 8px; background: #2a2a3a; border-radius: 4px; overflow: hidden;">
                            <div style="height: 100%; width: ${getThreatWidth(aiAnalysis.threatLevel)}%; background: linear-gradient(90deg, #00ff41, ${getThreatColor(aiAnalysis.threatLevel)}); transition: width 0.5s;"></div>
                        </div>
                    </div>
                    
                    <!-- Analysis Text -->
                    <div style="background: #0a0a0f; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                        <p style="color: #e0e0e0; font-size: 13px; line-height: 1.7; margin: 0;">${aiAnalysis.explanation || 'Device identified based on network signature.'}</p>
                    </div>
                    
                    <!-- Recommendation -->
                    ${aiAnalysis.recommendation ? `
                    <div style="padding: 12px 15px; background: linear-gradient(135deg, #00ff4110, transparent); border-radius: 8px; border-left: 3px solid #00ff41;">
                        <div style="color: #00ff41; font-size: 10px; text-transform: uppercase; margin-bottom: 5px;">💡 Recommendation</div>
                        <div style="color: #e0e0e0; font-size: 12px;">${aiAnalysis.recommendation}</div>
                    </div>
                    ` : ''}
                </div>
                
                <!-- Real-Time Network Activity -->
                <div style="background: #1a1a25; padding: 20px; border-radius: 12px; border: 1px solid #0abdc6; margin-bottom: 20px;">
                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 15px;">
                        <span style="font-size: 1.3em;">📡</span>
                        <span style="color: #0abdc6; font-weight: bold;">REAL-TIME NETWORK ACTIVITY</span>
                        <span id="monitorStatus-${device.ip.replace(/\./g, '-')}" style="margin-left: auto; font-size: 10px; color: #666;">Starting...</span>
                    </div>
                    <div id="activityFeed-${device.ip.replace(/\./g, '-')}" style="max-height: 250px; overflow-y: auto;">
                        <div style="text-align: center; padding: 30px; color: #666;">
                            <div class="typing-indicator" style="justify-content: center; margin-bottom: 15px;">
                                <span></span><span></span><span></span>
                            </div>
                            <p>Starting network monitor...</p>
                        </div>
                    </div>
                </div>
            `;
            
            // Start real-time monitoring for this device
            startRealTimeMonitor(device.ip, device.mac);
        }
        
        // ═══════════════════════════════════════════════════════════════
        // 📡 REAL-TIME NETWORK MONITORING
        // ═══════════════════════════════════════════════════════════════
        
        // Track active monitors
        const realTimeMonitors = new Map();
        
        // Start real-time monitoring for a device
        async function startRealTimeMonitor(ip, mac) {
            const safeIp = ip.replace(/\./g, '-');
            const feedEl = document.getElementById(`activityFeed-${safeIp}`);
            const statusEl = document.getElementById(`monitorStatus-${safeIp}`);
            
            // Stop any existing monitor for this IP
            if (realTimeMonitors.has(ip)) {
                clearInterval(realTimeMonitors.get(ip));
            }
            
            // Show loading state
            statusEl.innerHTML = '<span style="color: #0abdc6;">● Connecting...</span>';
            feedEl.innerHTML = `
                <div style="text-align: center; padding: 20px; color: #666;">
                    <div class="typing-indicator" style="justify-content: center; margin-bottom: 10px;">
                        <span></span><span></span><span></span>
                    </div>
                    <p>📡 Loading network activity for ${ip}...</p>
                </div>
            `;
            
            // Poll for activity every 2 seconds using the global network monitor
            const pollId = setInterval(() => pollRealTimeActivity(ip), 2000);
            realTimeMonitors.set(ip, pollId);
            
            // Initial poll
            setTimeout(() => pollRealTimeActivity(ip), 300);
        }
        
        // Poll for real-time activity
        async function pollRealTimeActivity(ip) {
            const safeIp = ip.replace(/\./g, '-');
            const feedEl = document.getElementById(`activityFeed-${safeIp}`);
            const statusEl = document.getElementById(`monitorStatus-${safeIp}`);
            
            if (!feedEl) {
                // Element no longer exists, stop polling
                if (realTimeMonitors.has(ip)) {
                    clearInterval(realTimeMonitors.get(ip));
                    realTimeMonitors.delete(ip);
                }
                return;
            }
            
            try {
                // Use the global network summary which captures all device activity
                const response = await fetch('/api/network/summary');
                const summary = await response.json();
                
                if (!summary.isMonitoring) {
                    showMonitorSetupRequired(feedEl, statusEl);
                    return;
                }
                
                // Find this device in the summary
                const deviceData = summary.deviceActivity?.find(d => d.ip === ip);
                
                if (deviceData && deviceData.totalQueries > 0) {
                    // Update status
                    statusEl.innerHTML = `<span style="color: #00ff41;">● LIVE</span> <span style="color: #888; margin-left: 5px;">${deviceData.totalQueries} queries</span>`;
                    
                    // Render activity
                    let html = '';
                    deviceData.recentActivity?.slice(0, 50).forEach(a => {
                        const time = new Date(a.timestamp).toLocaleTimeString();
                        const categoryColor = getCategoryColor(a.category);
                        html += `
                            <div style="padding: 10px; background: #0f0f15; border-radius: 6px; margin-bottom: 6px; display: flex; align-items: center; gap: 10px; animation: fadeIn 0.3s;">
                                <span style="font-size: 1.3em;">${a.icon || '🌐'}</span>
                                <div style="flex: 1; min-width: 0;">
                                    <div style="color: #e0e0e0; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${a.app || a.domain}</div>
                                    <div style="color: #666; font-size: 10px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${a.domain}</div>
                                </div>
                                <div style="text-align: right; flex-shrink: 0;">
                                    <div style="color: ${categoryColor}; font-size: 10px;">${a.category}</div>
                                    <div style="color: #666; font-size: 10px;">${time}</div>
                                </div>
                            </div>
                        `;
                    });
                    
                    // Add top apps summary
                    if (deviceData.topApps?.length > 0) {
                        html = `
                            <div style="padding: 10px; background: #0abdc610; border-radius: 8px; margin-bottom: 12px;">
                                <div style="color: #0abdc6; font-size: 11px; margin-bottom: 8px; font-weight: bold;">📊 Top Activity</div>
                                <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                                    ${deviceData.topApps.slice(0, 5).map(app => `
                                        <span style="background: #1a1a25; padding: 4px 10px; border-radius: 12px; font-size: 10px; color: #e0e0e0;">
                                            ${app.app} <span style="color: #666;">(${app.count})</span>
                                        </span>
                                    `).join('')}
                                </div>
                            </div>
                        ` + html;
                    }
                    
                    feedEl.innerHTML = html;
                } else {
                    // Show global network activity when this device has no activity
                    statusEl.innerHTML = `<span style="color: #ffaa00;">● No Activity</span>`;
                    
                    // Show what other devices ARE doing
                    let html = `
                        <div style="padding: 15px; background: #1a1510; border: 1px solid #ffaa00; border-radius: 8px; margin-bottom: 15px;">
                            <div style="color: #ffaa00; font-weight: bold; margin-bottom: 8px;">📵 This device is idle</div>
                            <p style="color: #888; font-size: 12px; margin: 0;">
                                No DNS queries detected from ${ip}. The device may be asleep, not connected, or using a VPN/different DNS.
                            </p>
                        </div>
                    `;
                    
                    // Show other active devices
                    if (summary.deviceActivity && summary.deviceActivity.length > 0) {
                        html += `
                            <div style="color: #0abdc6; font-size: 12px; font-weight: bold; margin-bottom: 10px;">
                                🌐 Other Active Devices (${summary.activeDevices})
                            </div>
                        `;
                        
                        summary.deviceActivity.slice(0, 3).forEach(d => {
                            const topApp = d.topApps?.[0]?.app || 'Unknown';
                            html += `
                                <div style="padding: 10px; background: #0f0f15; border-radius: 6px; margin-bottom: 6px; display: flex; align-items: center; gap: 10px;">
                                    <span style="font-size: 1.2em;">📱</span>
                                    <div style="flex: 1;">
                                        <div style="color: #e0e0e0; font-weight: 500;">${d.ip}</div>
                                        <div style="color: #666; font-size: 10px;">Top: ${topApp} • ${d.totalQueries} queries</div>
                                    </div>
                                </div>
                            `;
                        });
                        
                        // Show top apps across all devices
                        if (summary.topApps && summary.topApps.length > 0) {
                            html += `
                                <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #2a2a3a;">
                                    <div style="color: #666; font-size: 10px; margin-bottom: 8px;">🔥 Top Network Activity:</div>
                                    <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                                        ${summary.topApps.slice(0, 6).map(([app, count]) => `
                                            <span style="background: #1a1a25; padding: 3px 8px; border-radius: 10px; font-size: 9px; color: #888;">
                                                ${app} (${count})
                                            </span>
                                        `).join('')}
                                    </div>
                                </div>
                            `;
                        }
                    }
                    
                    feedEl.innerHTML = html;
                }
                
            } catch (e) {
                console.error('Activity poll error:', e);
            }
        }
        
        // Show setup required message
        function showMonitorSetupRequired(feedEl, statusEl) {
            statusEl.innerHTML = '<span style="color: #ff6600;">⚠ Setup Required</span>';
            feedEl.innerHTML = `
                <div style="padding: 20px; background: #1a1510; border: 1px solid #ff6600; border-radius: 8px;">
                    <div style="color: #ff6600; font-weight: bold; margin-bottom: 10px;">⚠️ Network Monitor Setup Required</div>
                    <p style="color: #888; font-size: 12px; margin-bottom: 15px;">
                        Real-time network monitoring requires elevated permissions to capture DNS traffic.
                    </p>
                    <div style="background: #0a0a0f; padding: 12px; border-radius: 6px; margin-bottom: 15px;">
                        <p style="color: #0abdc6; font-size: 11px; margin-bottom: 8px;">Run this command in Terminal:</p>
                        <code style="color: #00ff41; font-size: 12px; word-break: break-all;">cd ${window.location.origin.replace('http://localhost:3333', '/Users/jimmysmacstudio/clawd-main/hexstrike-ai')} && ./setup-network-monitor.sh</code>
                    </div>
                    <p style="color: #666; font-size: 10px;">
                        This enables tcpdump to capture network packets. You'll need to enter your password once during setup.
                    </p>
                </div>
            `;
        }
        
        // Show error message
        function showMonitorError(feedEl, statusEl, error) {
            statusEl.innerHTML = '<span style="color: #ff0040;">● Error</span>';
            feedEl.innerHTML = `
                <div style="padding: 20px; background: #1a1015; border: 1px solid #ff0040; border-radius: 8px; text-align: center;">
                    <div style="color: #ff0040; font-weight: bold; margin-bottom: 10px;">❌ Monitoring Error</div>
                    <p style="color: #888; font-size: 12px;">${error}</p>
                </div>
            `;
        }
        
        // Stop monitoring when device is deselected or dashboard is closed
        function stopAllMonitors() {
            activeDeviceMonitors.forEach((pollId, ip) => {
                clearInterval(pollId);
                // Stop server-side monitoring
                fetch(`/api/device-monitor/stop/${encodeURIComponent(ip)}`, { method: 'POST' }).catch(() => {});
            });
            activeDeviceMonitors.clear();
        }
        
        // Helper functions for threat visualization
        function getThreatWidth(level) {
            const levels = { 'safe': 10, 'low': 25, 'medium': 50, 'high': 75, 'critical': 100 };
            return levels[level] || 25;
        }
        
        function getThreatColor(level) {
            const colors = { 'safe': '#00ff41', 'low': '#00ff41', 'medium': '#ffaa00', 'high': '#ff6600', 'critical': '#ff0040' };
            return colors[level] || '#ffaa00';
        }
        
        // Filter devices by status
        function filterByStatus(status) {
            deviceDashboardData.currentFilter = status;
            
            // Update filter button styles
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.style.background = btn.dataset.filter === status ? '#00ff41' : '#1a1a25';
                btn.style.color = btn.dataset.filter === status ? '#0a0a0f' : '#888';
            });
            
            renderDeviceList();
        }
        
        // Filter devices by search
        function filterDevices() {
            renderDeviceList();
        }
        
        // Get category color (kept for compatibility)
        function getCategoryColor(category) {
            const colors = {
                'Social Media': '#e91e63',
                'Streaming': '#9c27b0',
                'Gaming': '#673ab7',
                'Productivity': '#2196f3',
                'Shopping': '#ff9800',
                'News': '#607d8b',
                'Advertising': '#f44336',
                'Tracking': '#f44336'
            };
            return colors[category] || '#0abdc6';
        }
        
        // Add device to whitelist from dashboard
        async function addToWhitelistUI(mac, ip, vendor) {
            const name = prompt('Give this device a name:', vendor || 'My Device');
            if (!name) return;
            
            try {
                const response = await fetch('/api/network-guardian/whitelist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mac, ip, vendor, name })
                });
                const result = await response.json();
                
                if (result.success) {
                    // Update local data
                    const device = deviceDashboardData.devices.find(d => d.mac === mac);
                    if (device) {
                        device.whitelisted = true;
                        device.whitelistName = name;
                    }
                    renderDeviceList();
                    selectDevice(deviceDashboardData.devices.findIndex(d => d.mac === mac));
                    addMessage(`✅ Device "${name}" added to trusted devices.`);
                } else {
                    alert(result.message || 'Failed to add device');
                }
            } catch (e) {
                alert('Error adding device: ' + e.message);
            }
        }
        
        // Remove device from whitelist
        async function removeFromWhitelistUI(mac) {
            if (!confirm('Remove this device from trusted list?')) return;
            
            try {
                const response = await fetch(`/api/network-guardian/whitelist/${encodeURIComponent(mac)}`, {
                    method: 'DELETE'
                });
                const result = await response.json();
                
                if (result.success) {
                    const device = deviceDashboardData.devices.find(d => d.mac === mac);
                    if (device) {
                        device.whitelisted = false;
                        device.whitelistName = null;
                    }
                    renderDeviceList();
                    selectDevice(deviceDashboardData.devices.findIndex(d => d.mac === mac));
                    addMessage(`Device removed from trusted list.`);
                }
            } catch (e) {
                alert('Error removing device: ' + e.message);
            }
        }
        
        // AI analyze specific device
        async function analyzeDeviceAI(ip) {
            const device = deviceDashboardData.devices.find(d => d.ip === ip);
            if (!device) return;
            
            addMessage(`🤖 <strong>Analyzing device ${ip}...</strong>`, true);
            
            try {
                const response = await fetch('/api/network-guardian/identify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(device)
                });
                const analysis = await response.json();
                
                let html = `<div style="background: linear-gradient(135deg, #1a1a25, #0a0a15); border: 1px solid #8b5cf6; border-radius: 8px; padding: 20px;">`;
                html += `<div style="margin-bottom: 15px;"><strong style="color: #8b5cf6;">🤖 AI Device Analysis</strong></div>`;
                html += `<div style="margin-bottom: 10px;"><strong>Device:</strong> ${analysis.deviceType}</div>`;
                html += `<div style="margin-bottom: 10px;"><strong>Confidence:</strong> ${analysis.confidence}</div>`;
                html += `<div style="margin-bottom: 10px;"><strong>Threat Level:</strong> <span style="color: ${getThreatColor(analysis.threatLevel)};">${analysis.threatLevel?.toUpperCase()}</span></div>`;
                html += `<div style="margin-bottom: 10px;"><strong>Analysis:</strong> ${analysis.explanation}</div>`;
                html += `<div><strong>Recommendation:</strong> ${analysis.recommendation}</div>`;
                html += `</div>`;
                
                addMessage(html);
                
                // Update device in dashboard
                device.deviceType = analysis.deviceType;
                device.threatLevel = analysis.threatLevel;
                device.isSuspicious = analysis.isSuspicious;
                renderDeviceList();
                selectDevice(deviceDashboardData.devices.findIndex(d => d.ip === ip));
                
            } catch (e) {
                addMessage(`❌ Analysis failed: ${e.message}`);
            }
        }
        
        // Show block instructions modal
        async function showBlockInstructions(mac, ip) {
            try {
                const response = await fetch('/api/network-guardian/deauth', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ targetMac: mac })
                });
                const data = await response.json();
                
                const modal = document.getElementById('deviceModal');
                document.getElementById('modalDeviceName').textContent = '🚫 Block Device';
                document.getElementById('modalDeviceIP').textContent = `MAC: ${mac}`;
                
                let html = `
                    <div style="margin-bottom: 20px;">
                        <div style="background: #ff004020; border: 1px solid #ff0040; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                            <strong style="color: #ff0040;">⚡ Quickest Method: Change WiFi Password</strong>
                            <p style="color: #888; margin-top: 10px; font-size: 13px;">Instantly kicks ALL unauthorized devices. Then reconnect only your trusted devices with the new password.</p>
                        </div>
                    </div>
                    
                    <div style="margin-bottom: 20px;">
                        <h4 style="color: #0abdc6; margin-bottom: 15px;">🔧 Router-Specific Instructions</h4>
                `;
                
                for (const [key, router] of Object.entries(data.methods?.router || {})) {
                    html += `
                        <div style="background: #1a1a25; padding: 15px; border-radius: 8px; margin-bottom: 10px; border: 1px solid #2a2a3a;">
                            <strong style="color: #ffaa00;">${router.title}</strong>
                            <ol style="color: #888; margin: 10px 0 0 20px; font-size: 12px;">
                                ${router.steps.map(s => `<li style="margin: 5px 0;">${s}</li>`).join('')}
                            </ol>
                        </div>
                    `;
                }
                
                html += `</div>`;
                
                if (data.warning) {
                    html += `
                        <div style="background: #ffaa0020; border: 1px solid #ffaa00; padding: 15px; border-radius: 8px;">
                            <strong style="color: #ffaa00;">⚠️ Warning</strong>
                            <p style="color: #888; margin-top: 5px; font-size: 12px;">${data.warning}</p>
                        </div>
                    `;
                }
                
                document.getElementById('modalContent').innerHTML = html;
                modal.style.display = 'block';
                
            } catch (e) {
                alert('Error getting block instructions: ' + e.message);
            }
        }
        
        // Close device modal
        function closeDeviceModal() {
            document.getElementById('deviceModal').style.display = 'none';
        }
        
        // Close device dashboard
        function closeDeviceDashboard() {
            // Stop all real-time monitors
            stopAllMonitors();
            
            document.getElementById('deviceDashboard').style.display = 'none';
        }
        
        // Refresh device dashboard
        async function refreshDeviceDashboard() {
            addMessage('🔄 Refreshing network scan...');
            await scanNetworkFull();
        }
        
        // ═══════════════════════════════════════════════════════════════
        // OVERRIDE NETWORK SCAN FUNCTIONS TO USE DASHBOARD
        // ═══════════════════════════════════════════════════════════════
        
        // Store original functions
        const originalScanNetworkQuick = window.scanNetworkQuick;
        const originalScanNetworkFull = window.scanNetworkFull;
        
        // Override scanNetworkQuick
        window.scanNetworkQuick = async function() {
            addMessage('⚡ <strong>Quick Network Scan</strong> - Scanning for devices...', true);
            
            try {
                const response = await fetch('/api/network-guardian/arp-scan');
                const data = await response.json();
                
                if (data.error) {
                    addMessage(`❌ Scan failed: ${data.error}`);
                    return;
                }
                
                // Get whitelist to mark trusted devices
                const whitelistRes = await fetch('/api/network-guardian/whitelist');
                const whitelist = await whitelistRes.json();
                
                // Mark whitelisted devices
                data.devices.forEach(d => {
                    const trusted = whitelist.devices?.find(w => w.mac === d.mac);
                    if (trusted) {
                        d.whitelisted = true;
                        d.whitelistName = trusted.name;
                    }
                });
                
                // Show summary in chat
                const unknown = data.devices.filter(d => !d.whitelisted).length;
                const trusted = data.devices.filter(d => d.whitelisted).length;
                
                addMessage(`
                    <div style="background: linear-gradient(135deg, #1a1a25, #0a0a15); border: 1px solid #00ff41; border-radius: 8px; padding: 15px;">
                        <strong style="color: #00ff41;">🛡️ Network Guardian - Quick Scan Complete</strong><br><br>
                        <strong>📊 Summary:</strong> ${data.devices.length} total, ${trusted} trusted, ${unknown} unknown<br><br>
                        <button onclick="openDeviceDashboard(lastScanResult)" style="background: linear-gradient(135deg, #00ff41, #0abdc6); color: #0a0a0f; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                            📋 Open Device Dashboard
                        </button>
                    </div>
                `);
                
                // Store for dashboard
                window.lastScanResult = data;
                
                // Update sidebar count
                document.getElementById('deviceCount').textContent = `${data.devices.length} devices`;
                
                // 🔧 FIX: Attach network scan results to chat context
                try {
                    const contextData = {
                        summary: `${data.devices.length} devices found: ${trusted} trusted, ${unknown} unknown`,
                        devices: data.devices.map(d => ({
                            ip: d.ip,
                            mac: d.mac,
                            vendor: d.vendor,
                            whitelisted: d.whitelisted,
                            whitelistName: d.whitelistName
                        }))
                    };
                    await fetch('/api/chat/attach-context', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            sessionId,
                            contextType: 'Network Guardian Quick Scan',
                            context: JSON.stringify(contextData, null, 2)
                        })
                    });
                } catch (e) {
                    console.warn('Failed to attach network scan context:', e);
                }
                
            } catch (e) {
                addMessage(`❌ Scan error: ${e.message}`);
            }
        };
        
        // Override scanNetworkFull
        window.scanNetworkFull = async function() {
            addMessage('🤖 <strong>AI Network Scan</strong> - Deep analysis in progress...', true);
            
            try {
                const response = await fetch('/api/network-guardian/full-scan', { method: 'POST' });
                const data = await response.json();
                
                if (data.error) {
                    addMessage(`❌ Scan failed: ${data.error}`);
                    return;
                }
                
                // Merge AI analysis into devices
                const devices = data.scan?.devices || [];
                const aiDevices = data.aiAnalysis?.devices || [];
                
                devices.forEach(d => {
                    const aiDevice = aiDevices.find(a => a.mac === d.mac);
                    if (aiDevice) {
                        d.deviceType = aiDevice.deviceType;
                        d.threatLevel = aiDevice.threatLevel;
                        d.analysis = aiDevice.analysis;
                        d.recommendation = aiDevice.recommendation;
                        d.isSuspicious = aiDevice.threatLevel === 'high' || aiDevice.threatLevel === 'critical';
                    }
                });
                
                // Show summary in chat
                const threats = devices.filter(d => d.isSuspicious || d.threatLevel === 'high' || d.threatLevel === 'critical').length;
                const trusted = devices.filter(d => d.whitelisted).length;
                const unknown = devices.filter(d => !d.whitelisted && !d.isSuspicious).length;
                
                let summaryColor = threats > 0 ? '#ff0040' : '#00ff41';
                
                addMessage(`
                    <div style="background: linear-gradient(135deg, #1a1a25, #0a0a15); border: 1px solid ${summaryColor}; border-radius: 8px; padding: 15px;">
                        <strong style="color: ${summaryColor};">🛡️ Network Guardian AI Analysis Complete</strong><br><br>
                        <strong>📊 Summary:</strong> ${devices.length} total, ${trusted} trusted, ${unknown} unknown, ${threats > 0 ? `<span style="color: #ff0040;">${threats} potential threats</span>` : '0 threats'}<br><br>
                        ${data.aiAnalysis?.summary ? `<strong>🤖 AI Summary:</strong> ${data.aiAnalysis.summary}<br><br>` : ''}
                        <button onclick="openDeviceDashboard(lastScanResult)" style="background: linear-gradient(135deg, #00ff41, #0abdc6); color: #0a0a0f; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold;">
                            📋 Open Device Dashboard
                        </button>
                    </div>
                `);
                
                // Store for dashboard
                window.lastScanResult = {
                    devices: devices,
                    scanTime: data.scan?.scanTime,
                    aiAnalysis: data.aiAnalysis,
                    networkInfo: data.scan?.networkInfo
                };
                
                // Auto-open dashboard
                openDeviceDashboard(window.lastScanResult);
                
                // Update sidebar count
                document.getElementById('deviceCount').textContent = `${devices.length} devices`;
                
                // 🔧 FIX: Attach AI network scan results to chat context
                try {
                    const contextData = {
                        summary: `${devices.length} devices: ${trusted} trusted, ${unknown} unknown, ${threats} potential threats`,
                        aiSummary: data.aiAnalysis?.summary,
                        devices: devices.map(d => ({
                            ip: d.ip,
                            mac: d.mac,
                            vendor: d.vendor,
                            deviceType: d.deviceType,
                            threatLevel: d.threatLevel,
                            analysis: d.analysis,
                            recommendation: d.recommendation
                        }))
                    };
                    await fetch('/api/chat/attach-context', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            sessionId,
                            contextType: 'Network Guardian AI Scan',
                            context: JSON.stringify(contextData, null, 2)
                        })
                    });
                } catch (e) {
                    console.warn('Failed to attach AI network scan context:', e);
                }
                
            } catch (e) {
                addMessage(`❌ Scan error: ${e.message}`);
            }
        };
        
        // Close modal on escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeDeviceModal();
            }
        });
        
        // Close modal on background click
        document.getElementById('deviceModal')?.addEventListener('click', (e) => {
            if (e.target.id === 'deviceModal') {
                closeDeviceModal();
            }
        });
        
        // ═══════════════════════════════════════════════════════════════
        // 📁 TOOL CATEGORY TABS
        // ═══════════════════════════════════════════════════════════════
        
        function showToolCategory(category) {
            // Hide all categories
            document.querySelectorAll('.tool-category').forEach(el => el.style.display = 'none');
            // Show selected category
            const cat = document.getElementById(`category-${category}`);
            if (cat) cat.style.display = 'block';
            
            // Update tab styles
            document.querySelectorAll('.tool-tab').forEach(tab => {
                tab.style.borderColor = '#444';
                tab.style.color = '#888';
                tab.classList.remove('active');
            });
            const activeTab = document.getElementById(`tab-${category}`);
            if (activeTab) {
                const colors = { intel: '#ff6b6b', network: '#00ff41', scanners: '#0abdc6', mobile: '#ff6b35', more: '#8b5cf6' };
                activeTab.style.borderColor = colors[category] || '#0abdc6';
                activeTab.style.color = colors[category] || '#0abdc6';
                activeTab.classList.add('active');
            }
        }
        
        // ═══════════════════════════════════════════════════════════════
        // 🌐 DOMAIN INVESTIGATOR - White Hat Domain Intelligence Tool
        // ═══════════════════════════════════════════════════════════════
        
        async function investigateDomain() {
            const domain = document.getElementById('domainInvestigatorTarget').value.trim();
            if (!domain) {
                addMessage('❌ Please enter a domain to investigate.', true);
                return;
            }
            
            const statusEl = document.getElementById('domainInvestigatorStatus');
            statusEl.innerHTML = '<span style="color: #0abdc6;">🌐 Investigating...</span>';
            
            addMessage(`🌐 <strong>Starting Domain Investigation:</strong> ${domain}`, true);
            
            try {
                const response = await fetch('/api/domain-investigator/investigate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ domain })
                });
                
                const data = await response.json();
                
                if (data.error) {
                    addMessage(`❌ Error: ${data.error}`, true);
                    statusEl.innerHTML = `<span style="color: #ff0040;">Error</span>`;
                    return;
                }
                
                const whois = data.whois || {};
                const dns = data.dns || {};
                const ssl = data.ssl || {};
                const headers = data.headers || {};
                const summary = data.summary || {};
                
                let html = `
                    <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #0abdc6;">
                        <strong style="color: #0abdc6; font-size: 14px;">🌐 Domain Investigation: ${domain}</strong><br>
                        <span style="color: #666; font-size: 10px;">Completed in ${data.investigationTime}</span><br><br>
                        
                        <div style="background: #0a0a0f; padding: 10px; border-radius: 4px; margin-bottom: 10px;">
                            <strong style="font-size: 16px;">${summary.riskAssessment || 'Unknown'}</strong>
                        </div>
                        
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #ff6b6b;">🏛️ Registration</strong><br>
                            <span style="color: #e0e0e0;">Registrar: ${whois.registrar || 'Unknown'}</span><br>
                            <span style="color: #888;">Created: ${whois.creationDate || 'Unknown'}</span><br>
                            <span style="color: #888;">Expires: ${whois.expirationDate || 'Unknown'}</span><br>
                            ${whois.registrant?.organization ? `<span style="color: #888;">Owner: ${whois.registrant.organization}</span><br>` : ''}
                        </div>
                        
                        ${data.ip ? `
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #ff6b6b;">🌐 Hosting</strong><br>
                            <span style="color: #e0e0e0;">IP: ${data.ip}</span><br>
                            ${data.geolocation ? `<span style="color: #888;">Location: ${data.geolocation.city || ''}, ${data.geolocation.country || 'Unknown'}</span><br>
                            <span style="color: #888;">Provider: ${data.geolocation.isp || 'Unknown'}</span>` : ''}
                        </div>
                        ` : ''}
                        
                        ${ssl.subject ? `
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #ff6b6b;">🔒 SSL Certificate</strong><br>
                            <span style="color: #e0e0e0;">Issuer: ${ssl.issuer || 'Unknown'}</span><br>
                            <span style="color: ${ssl.isExpired ? '#ff6b6b' : '#00ff41'};">${ssl.isExpired ? '❌ EXPIRED' : '✅ Valid'} (${ssl.daysRemaining} days)</span>
                        </div>
                        ` : ''}
                        
                        ${headers.score ? `
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #ff6b6b;">🛡️ Security Headers</strong><br>
                            <span style="color: #e0e0e0;">Score: ${headers.score} (Grade ${headers.grade})</span>
                        </div>
                        ` : ''}
                        
                        ${dns.A?.length > 0 ? `
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #ff6b6b;">📋 DNS Records</strong><br>
                            <span style="color: #888;">A: ${dns.A.join(', ')}</span><br>
                            ${dns.MX?.length > 0 ? `<span style="color: #888;">MX: ${dns.MX.slice(0, 2).map(m => m.exchange).join(', ')}</span><br>` : ''}
                            ${dns.NS?.length > 0 ? `<span style="color: #888;">NS: ${dns.NS.slice(0, 2).join(', ')}</span>` : ''}
                        </div>
                        ` : ''}
                        
                        ${data.subdomains?.found?.length > 0 ? `
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #ff6b6b;">🔍 Subdomains (${data.subdomains.found.length})</strong><br>
                            ${data.subdomains.found.slice(0, 5).map(s => `<span style="background: #2a2a35; padding: 2px 6px; border-radius: 3px; margin: 2px; display: inline-block; font-size: 10px;">${s.subdomain}</span>`).join('')}
                        </div>
                        ` : ''}
                        
                        ${summary.concerns?.length > 0 ? `
                        <div style="margin-bottom: 10px; background: #2a1a1a; padding: 8px; border-radius: 4px;">
                            <strong style="color: #ff6b6b;">⚠️ Concerns</strong><br>
                            ${summary.concerns.map(c => `<span style="color: #e0e0e0; font-size: 11px;">${c}</span><br>`).join('')}
                        </div>
                        ` : ''}
                    </div>
                `;
                
                addMessage(html, true);
                statusEl.innerHTML = `<span style="color: #00ff41;">✅ ${summary.riskAssessment}</span>`;
                
            } catch (error) {
                addMessage(`❌ Investigation failed: ${error.message}`, true);
                statusEl.innerHTML = `<span style="color: #ff0040;">Failed</span>`;
            }
        }
        
        async function quickDNS() {
            const domain = document.getElementById('domainInvestigatorTarget').value.trim();
            if (!domain) { addMessage('❌ Please enter a domain.', true); return; }
            
            addMessage(`📋 <strong>DNS Lookup:</strong> ${domain}`, true);
            try {
                const response = await fetch(`/api/domain-investigator/dns/${domain}`);
                const dns = await response.json();
                
                addMessage(`
                    <div style="background: #1a1a25; padding: 12px; border-radius: 8px; border: 1px solid #0abdc6;">
                        <strong style="color: #0abdc6;">📋 DNS Records: ${domain}</strong><br><br>
                        <strong>A:</strong> ${dns.A?.join(', ') || 'None'}<br>
                        <strong>AAAA:</strong> ${dns.AAAA?.join(', ') || 'None'}<br>
                        <strong>MX:</strong> ${dns.MX?.map(m => m.exchange).join(', ') || 'None'}<br>
                        <strong>NS:</strong> ${dns.NS?.join(', ') || 'None'}<br>
                        <strong>TXT:</strong> ${dns.TXT?.slice(0, 2).join(' | ') || 'None'}
                    </div>
                `, true);
            } catch (error) {
                addMessage(`❌ DNS lookup failed: ${error.message}`, true);
            }
        }
        
        async function quickSSL() {
            const domain = document.getElementById('domainInvestigatorTarget').value.trim();
            if (!domain) { addMessage('❌ Please enter a domain.', true); return; }
            
            addMessage(`🔒 <strong>SSL Check:</strong> ${domain}`, true);
            try {
                const response = await fetch(`/api/domain-investigator/ssl/${domain}`);
                const ssl = await response.json();
                
                addMessage(`
                    <div style="background: #1a1a25; padding: 12px; border-radius: 8px; border: 1px solid ${ssl.isExpired ? '#ff6b6b' : '#00ff41'};">
                        <strong style="color: ${ssl.isExpired ? '#ff6b6b' : '#00ff41'};">🔒 SSL Certificate: ${domain}</strong><br><br>
                        <strong>Subject:</strong> ${ssl.subject || 'N/A'}<br>
                        <strong>Issuer:</strong> ${ssl.issuer || 'N/A'}<br>
                        <strong>Valid From:</strong> ${ssl.validFrom || 'N/A'}<br>
                        <strong>Valid To:</strong> ${ssl.validTo || 'N/A'}<br>
                        <strong>Days Remaining:</strong> ${ssl.daysRemaining || 'N/A'}<br>
                        <strong>Status:</strong> ${ssl.isExpired ? '❌ EXPIRED' : ssl.isValid ? '✅ Valid' : '⚠️ Invalid'}
                    </div>
                `, true);
            } catch (error) {
                addMessage(`❌ SSL check failed: ${error.message}`, true);
            }
        }
        
        // ═══════════════════════════════════════════════════════════════
        // 🔍 IP INVESTIGATOR - White Hat Intelligence Tool
        // ═══════════════════════════════════════════════════════════════
        
        async function investigateIP() {
            const ip = document.getElementById('ipInvestigatorTarget').value.trim();
            if (!ip) {
                addMessage('❌ Please enter an IP address to investigate.', true);
                return;
            }
            
            const statusEl = document.getElementById('ipInvestigatorStatus');
            statusEl.innerHTML = '<span style="color: #ff6b6b;">🔍 Investigating...</span>';
            
            addMessage(`🔍 <strong>Starting Full IP Investigation:</strong> ${ip}`, true);
            
            try {
                const response = await fetch('/api/ip-investigator/investigate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ip })
                });
                
                const data = await response.json();
                
                if (data.error) {
                    addMessage(`❌ Error: ${data.error}`, true);
                    statusEl.innerHTML = `<span style="color: #ff0040;">Error</span>`;
                    return;
                }
                
                const geo = data.geolocation || {};
                const whois = data.whois || {};
                const ports = data.ports || {};
                const threat = data.threatIntel || {};
                const summary = data.summary || {};
                
                let html = `
                    <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #ff6b6b;">
                        <strong style="color: #ff6b6b; font-size: 14px;">🔍 IP Investigation Report: ${ip}</strong><br>
                        <span style="color: #666; font-size: 10px;">Completed in ${data.investigationTime}</span><br><br>
                        
                        <div style="background: #0a0a0f; padding: 10px; border-radius: 4px; margin-bottom: 10px;">
                            <strong style="font-size: 16px;">${summary.riskAssessment || 'Unknown'}</strong>
                        </div>
                        
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #0abdc6;">📍 Location</strong><br>
                            <span style="color: #e0e0e0;">${geo.city || 'Unknown'}, ${geo.region || ''}, ${geo.country || 'Unknown'}</span><br>
                            <span style="color: #888;">ISP: ${geo.isp || 'Unknown'}</span><br>
                            <span style="color: #888;">Org: ${geo.organization || 'Unknown'}</span><br>
                            ${geo.isProxy ? '<span style="color: #ff6b6b;">⚠️ Proxy/VPN Detected</span><br>' : ''}
                            ${geo.isHosting ? '<span style="color: #ffa500;">🖥️ Hosting/Datacenter</span><br>' : ''}
                            ${geo.mapUrl ? `<a href="${geo.mapUrl}" target="_blank" style="color: #0abdc6; font-size: 11px;">📍 View on Map</a>` : ''}
                        </div>
                        
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #0abdc6;">🏛️ Ownership</strong><br>
                            <span style="color: #e0e0e0;">${whois.organization || 'Unknown'}</span><br>
                            <span style="color: #888;">Net: ${whois.netRange || 'N/A'}</span><br>
                            <span style="color: #888;">Name: ${whois.netName || 'N/A'}</span><br>
                            ${whois.abuseEmail ? `<span style="color: #888;">Abuse: ${whois.abuseEmail}</span>` : ''}
                        </div>
                        
                        ${data.reverseDns?.hostnames?.length > 0 ? `
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #0abdc6;">🌐 Hostname</strong><br>
                            <span style="color: #e0e0e0;">${data.reverseDns.hostnames.join(', ')}</span>
                        </div>
                        ` : ''}
                        
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #0abdc6;">🚪 Open Ports (${ports.totalOpen || 0})</strong><br>
                            ${ports.openPorts?.length > 0 ? 
                                ports.openPorts.slice(0, 10).map(p => 
                                    `<span style="background: #2a2a35; padding: 2px 6px; border-radius: 3px; margin: 2px; display: inline-block; font-size: 10px;">${p.port}/${p.service}</span>`
                                ).join('') + (ports.openPorts.length > 10 ? `<span style="color: #888;"> +${ports.openPorts.length - 10} more</span>` : '')
                                : '<span style="color: #888;">None found</span>'}
                        </div>
                        
                        ${threat.abuseConfidenceScore !== undefined ? `
                        <div style="margin-bottom: 10px;">
                            <strong style="color: #0abdc6;">🛡️ Threat Intel</strong><br>
                            <span style="color: ${threat.abuseConfidenceScore > 50 ? '#ff6b6b' : threat.abuseConfidenceScore > 25 ? '#ffa500' : '#00ff41'};">
                                Abuse Score: ${threat.abuseConfidenceScore}%
                            </span><br>
                            <span style="color: #888;">Reports: ${threat.totalReports || 0} from ${threat.numDistinctUsers || 0} users</span><br>
                            ${threat.isTor ? '<span style="color: #ff6b6b;">🧅 Tor Exit Node</span>' : ''}
                        </div>
                        ` : ''}
                        
                        ${summary.concerns?.length > 0 ? `
                        <div style="margin-bottom: 10px; background: #2a1a1a; padding: 8px; border-radius: 4px;">
                            <strong style="color: #ff6b6b;">⚠️ Concerns</strong><br>
                            ${summary.concerns.map(c => `<span style="color: #e0e0e0; font-size: 11px;">${c}</span><br>`).join('')}
                        </div>
                        ` : ''}
                        
                        <div style="margin-top: 10px; text-align: right;">
                            <button onclick="window.open('/api/ip-investigator/${data.id}/report', '_blank')" style="background: #2a2a35; border: 1px solid #ff6b6b; color: #ff6b6b; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 10px;">📄 Full Report</button>
                        </div>
                    </div>
                `;
                
                addMessage(html, true);
                statusEl.innerHTML = `<span style="color: #00ff41;">✅ ${summary.riskAssessment}</span>`;
                
            } catch (error) {
                addMessage(`❌ Investigation failed: ${error.message}`, true);
                statusEl.innerHTML = `<span style="color: #ff0040;">Failed</span>`;
            }
        }
        
        async function quickGeolocate() {
            const ip = document.getElementById('ipInvestigatorTarget').value.trim();
            if (!ip) {
                addMessage('❌ Please enter an IP address.', true);
                return;
