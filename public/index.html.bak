        // ═══════════════════════════════════════════════════════════════
        // DAST & SAST SCANNING
        // ═══════════════════════════════════════════════════════════════
        
        // DAST Scan (Dynamic Application Security Testing)
        async function runDASTScan(tool) {
            const target = document.getElementById('dastSastTarget').value.trim();
            
            if (!target) {
                addMessage(`
                    <div style="background: rgba(255,107,107,0.1); border: 1px solid #ff6b6b; border-radius: 8px; padding: 15px;">
                        <strong style="color: #ff6b6b;">🔴 DAST Scan</strong><br><br>
                        Please enter a <strong>URL</strong> in the target field above.<br>
                        Example: <code>https://example.com</code>
                    </div>
                `, false);
                document.getElementById('dastSastTarget').focus();
                return;
            }
            
            const toolNames = {
                'zap': '🕷️ OWASP ZAP (Full Web Scanner)',
                'nikto': '🔍 Nikto (Web Server Scanner)',
                'nuclei': '⚡ Nuclei (Vulnerability Templates)',
                'sqlmap': '💉 SQLMap (SQL Injection)',
                'xsstrike': '🔥 XSStrike (XSS Detection)',
                'full_dast': '⚡ Full DAST Suite (All Tools)'
            };
            
            addMessage(`
                <div style="background: rgba(255,107,107,0.1); border: 1px solid #ff6b6b; border-radius: 8px; padding: 15px;">
                    <strong style="color: #ff6b6b;">🔴 DAST Scan Started</strong><br><br>
                    <strong>Tool:</strong> ${toolNames[tool] || tool}<br>
                    <strong>Target:</strong> ${target}<br>
                    <strong>Type:</strong> Dynamic Analysis (Testing Running Application)<br><br>
                    <div class="typing-indicator"><span></span><span></span><span></span></div>
                </div>
            `, false);
            
            try {
                const response = await fetch('/api/dast-scan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ target, tool, scanType: 'dast' })
                });
                
                const result = await response.json();
                
                if (result.scanId) {
                    // Poll for results
                    pollDASTSASTResults(result.scanId, 'DAST', tool);
                } else if (result.error) {
                    addMessage(`❌ <strong>DAST Error:</strong> ${result.error}`, false);
                }
            } catch (error) {
                addMessage(`❌ <strong>DAST Error:</strong> ${error.message}`, false);
            }
        }
        
        // SAST Scan (Static Application Security Testing)
        async function runSASTScan(tool) {
            const target = document.getElementById('dastSastTarget').value.trim();
            
            if (!target) {
                addMessage(`
                    <div style="background: rgba(77,171,247,0.1); border: 1px solid #4dabf7; border-radius: 8px; padding: 15px;">
                        <strong style="color: #4dabf7;">🔵 SAST Scan</strong><br><br>
                        Please enter a <strong>path to source code</strong> or <strong>GitHub repo URL</strong>.<br>
                        Examples:<br>
                        • <code>/path/to/project</code><br>
                        • <code>https://github.com/user/repo</code><br>
                        • <code>.</code> (current directory)
                    </div>
                `, false);
                document.getElementById('dastSastTarget').focus();
                return;
            }
            
            const toolNames = {
                'semgrep': '🔬 Semgrep (AI Code Analysis)',
                'bandit': '🐍 Bandit (Python Security)',
                'bearer': '🔒 Bearer (Code Scanner)',
                'codeql': '🧬 CodeQL (Semantic Analysis)',
                'secrets': '🔑 Secret Detection (TruffleHog + GitLeaks)',
                'full_sast': '⚡ Full SAST Suite (All Tools)'
            };
            
            addMessage(`
                <div style="background: rgba(77,171,247,0.1); border: 1px solid #4dabf7; border-radius: 8px; padding: 15px;">
                    <strong style="color: #4dabf7;">🔵 SAST Scan Started</strong><br><br>
                    <strong>Tool:</strong> ${toolNames[tool] || tool}<br>
                    <strong>Target:</strong> ${target}<br>
                    <strong>Type:</strong> Static Analysis (Source Code Review)<br><br>
                    <div class="typing-indicator"><span></span><span></span><span></span></div>
                </div>
            `, false);
            
            try {
                const response = await fetch('/api/sast-scan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ target, tool, scanType: 'sast' })
                });
                
                const result = await response.json();
                
                if (result.scanId) {
                    // Poll for results
                    pollDASTSASTResults(result.scanId, 'SAST', tool);
                } else if (result.error) {
                    addMessage(`❌ <strong>SAST Error:</strong> ${result.error}`, false);
                }
            } catch (error) {
                addMessage(`❌ <strong>SAST Error:</strong> ${error.message}`, false);
            }
        }
        
        // Poll for DAST/SAST scan results
        async function pollDASTSASTResults(scanId, scanType, tool) {
            const endpoint = scanType === 'DAST' ? '/api/dast-scan' : '/api/sast-scan';
            const color = scanType === 'DAST' ? '#ff6b6b' : '#4dabf7';
            
            const poll = setInterval(async () => {
                try {
                    const response = await fetch(`${endpoint}/${scanId}`);
                    const result = await response.json();
                    
                    if (result.status === 'complete') {
                        clearInterval(poll);
                        
                        const findings = result.findings || [];
                        const critical = findings.filter(f => f.severity === 'CRITICAL' || f.severity === 'HIGH').length;
                        const medium = findings.filter(f => f.severity === 'MEDIUM').length;
                        const low = findings.filter(f => f.severity === 'LOW' || f.severity === 'INFO').length;
                        
                        let html = `
                            <div style="background: linear-gradient(135deg, #1a1a25, #0a0a15); border: 2px solid ${color}; border-radius: 12px; padding: 20px;">
                                <div style="font-size: 1.2em; color: ${color}; margin-bottom: 15px;">
                                    <strong>${scanType === 'DAST' ? '🔴' : '🔵'} ${scanType} Scan Complete</strong>
                                </div>
                                
                                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 15px;">
                                    <div style="background: rgba(255,0,64,0.2); padding: 10px; border-radius: 8px; text-align: center;">
                                        <div style="color: #ff0040; font-size: 1.5em; font-weight: bold;">${critical}</div>
                                        <div style="color: #888; font-size: 0.8em;">Critical/High</div>
                                    </div>
                                    <div style="background: rgba(255,170,0,0.2); padding: 10px; border-radius: 8px; text-align: center;">
                                        <div style="color: #ffaa00; font-size: 1.5em; font-weight: bold;">${medium}</div>
                                        <div style="color: #888; font-size: 0.8em;">Medium</div>
                                    </div>
                                    <div style="background: rgba(0,255,65,0.2); padding: 10px; border-radius: 8px; text-align: center;">
                                        <div style="color: #00ff41; font-size: 1.5em; font-weight: bold;">${low}</div>
                                        <div style="color: #888; font-size: 0.8em;">Low/Info</div>
                                    </div>
                                </div>
                        `;
                        
                        if (findings.length > 0) {
                            html += `<div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; max-height: 300px; overflow-y: auto;">`;
                            findings.slice(0, 10).forEach(f => {
                                const sevColor = f.severity === 'CRITICAL' ? '#ff0040' : f.severity === 'HIGH' ? '#ff4444' : f.severity === 'MEDIUM' ? '#ffaa00' : '#00ff41';
                                html += `
                                    <div style="margin-bottom: 10px; padding: 10px; background: rgba(0,0,0,0.3); border-left: 3px solid ${sevColor}; border-radius: 4px;">
                                        <div style="color: ${sevColor}; font-weight: bold;">${f.severity}: ${f.title || f.name || 'Finding'}</div>
                                        <div style="color: #888; font-size: 0.85em; margin-top: 5px;">${f.description || f.message || ''}</div>
                                        ${f.location ? `<div style="color: #666; font-size: 0.8em; margin-top: 5px;">📍 ${f.location}</div>` : ''}
                                    </div>
                                `;
                            });
                            if (findings.length > 10) {
                                html += `<div style="color: #888; text-align: center; margin-top: 10px;">... and ${findings.length - 10} more findings</div>`;
                            }
                            html += `</div>`;
                        } else {
                            html += `<div style="color: #00ff41; text-align: center; padding: 20px;">✅ No vulnerabilities found!</div>`;
                        }
                        
                        html += `</div>`;
                        addMessage(html, false);
                        
                        // Attach to chat context
                        try {
                            await fetch('/api/chat/attach-context', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    sessionId,
                                    contextType: `${scanType} Scan (${tool})`,
                                    context: JSON.stringify({ findings, scanType, tool }, null, 2)
                                })
                            });
                        } catch (e) {
                            console.warn('Failed to attach scan context:', e);
                        }
                        
                    } else if (result.status === 'error') {
                        clearInterval(poll);
                        addMessage(`❌ <strong>${scanType} Error:</strong> ${result.error}`, false);
                    }
                } catch (error) {
                    clearInterval(poll);
                    addMessage(`❌ <strong>${scanType} Error:</strong> ${error.message}`, false);
                }
            }, 3000);
        }
        
        // Port scan with chat integration
        function startPortScanWithChat(type) {
            const target = document.getElementById('networkTarget').value.trim();
            if (!target) {
                setInputMode('scan');
                insertPrompt('Scan ports on ');
                return;
            }
            
            addMessage(`🔍 <strong>Port Scan:</strong> ${type.toUpperCase()} scan on ${target}`, true);
            startPortScan(type);
        }
        
        // Network capture with chat integration  
        function startNetworkCaptureWithChat(type) {
            const target = document.getElementById('networkTarget').value.trim() || 'local';
            addMessage(`📡 <strong>Network Capture:</strong> Starting ${type.toUpperCase()} capture on ${target}`, true);
            startNetworkCapture(type);
        }
        
        // MITM proxy with chat integration
        function startMobileProxyWithChat() {
            addMessage(`📱 <strong>Mobile Traffic Interceptor:</strong> Starting MITM Proxy...`, true);
            startMobileProxy();
        }
        
        // ═══════════════════════════════════════════════════════════════
        // AI-POWERED FEATURES (Chat-based input)
        // ═══════════════════════════════════════════════════════════════
        
        // Store pending AI feature awaiting user input
        let pendingAIFeature = null;
        
        const aiFeatureConfig = {
            'phishing': {
                name: '🎣 AI Phishing Detection',
                endpoint: '/api/ai/phishing-detect',
                prompt: 'Paste the suspicious **email, URL, or message** below and press Enter:',
                placeholder: 'Paste suspicious content here...',
                inputRequired: true,
                buildBody: (input) => ({ content: input })
            },
            'password': {
                name: '🔐 AI Password Auditor',
                endpoint: '/api/ai/password-audit',
                prompt: 'Enter the **password** to analyze (we never store passwords):',
                placeholder: 'Enter password to audit...',
                inputRequired: true,
                buildBody: (input) => ({ password: input })
            },
            'threat': {
                name: '🔮 AI Threat Prediction',
                endpoint: '/api/ai/threat-predict',
                prompt: 'Analyzing your network for potential threats...',
                inputRequired: false
            },
            'compliance': {
                name: '📋 AI Compliance Checker',
                endpoint: '/api/ai/compliance-check',
                prompt: 'Enter compliance framework to check: **GDPR**, **HIPAA**, **SOC2**, **PCI**, or **all**:',
                placeholder: 'e.g., GDPR, HIPAA, SOC2, PCI, or all',
                inputRequired: true,
                buildBody: (input) => ({ framework: input })
            },
            'privacy': {
                name: '🔒 AI Privacy Audit',
                endpoint: '/api/ai/privacy-audit',
                prompt: 'Enter the **app name or URL** to audit for privacy concerns:',
                placeholder: 'e.g., facebook.com or TikTok',
                inputRequired: true,
                buildBody: (input) => ({ appInfo: { name: input } })
            },
            'logs': {
                name: '📊 AI Log Analysis',
                endpoint: '/api/ai/log-analyze',
                prompt: 'Paste the **log entries** to analyze (security logs, access logs, etc.):',
                placeholder: 'Paste log entries here...',
                inputRequired: true,
                buildBody: (input) => ({ logs: input })
            },
            'malware': {
                name: '🦠 AI Malware Analysis',
                endpoint: '/api/ai/malware-analyze',
                prompt: 'Enter the **file hash** (MD5/SHA256) or paste file metadata:',
                placeholder: 'e.g., d41d8cd98f00b204e9800998ecf8427e',
                inputRequired: true,
                buildBody: (input) => ({ fileInfo: { hash: input } })
            },
            'copilot': {
                name: '🛡️ AI Security Copilot',
                endpoint: '/api/ai/security-copilot',
                prompt: 'Getting personalized security recommendations...',
                inputRequired: false,
                method: 'GET'
            },
            'attack': {
                name: '⚔️ AI Attack Simulation',
                endpoint: '/api/ai/attack-simulate',
                prompt: 'Enter the **target domain or IP** for red team simulation:',
                placeholder: 'e.g., example.com or 192.168.1.1',
                inputRequired: true,
                buildBody: (input) => ({ target: input })
            },
            'prioritize': {
                name: '📈 AI Vulnerability Prioritizer',
                endpoint: '/api/ai/vuln-prioritize',
                prompt: 'Paste **vulnerability findings** (JSON or text description) to prioritize:',
                placeholder: 'Paste vulnerability data here...',
                inputRequired: true,
                buildBody: (input) => {
                    try {
                        return { findings: JSON.parse(input) };
                    } catch {
                        return { findings: [{ description: input }] };
                    }
                }
            },
            'code_review': {
                name: '👨‍💻 AI Tech Lead Code Review',
                endpoint: '/api/ai/code-review',
                prompt: `Paste your **code** for a senior engineer review.

**What you'll get:**
- Architecture & Design feedback
- Code quality assessment  
- Performance analysis
- Security review
- Best practices suggestions
- Refactoring recommendations

Paste your code below:`,
                placeholder: 'Paste your code here for tech lead review...',
                inputRequired: true,
                buildBody: (input) => ({ code: input, language: 'auto' })
            }
        };
        
        function runAIFeature(feature) {
            const config = aiFeatureConfig[feature];
            if (!config) {
                addMessage('❌ Unknown AI feature', false);
                return;
            }
            
            if (config.inputRequired) {
                // Show prompt in chat and wait for user input
                pendingAIFeature = { feature, config };
                
                addMessage(`
                    <div style="background: linear-gradient(135deg, #1a1a25, #0a0a15); border: 2px solid #0abdc6; border-radius: 12px; padding: 20px;">
                        <div style="font-size: 1.2em; color: #0abdc6; margin-bottom: 10px;"><strong>${config.name}</strong></div>
                        <div style="color: #e0e0e0; margin-bottom: 15px;">${config.prompt}</div>
                        <div style="color: #888; font-size: 0.85em;">💡 Type your input in the chat box below and press <strong>Enter</strong></div>
                    </div>
                `, false);
                
                // Update input placeholder
                const input = document.getElementById('userInput');
                input.placeholder = config.placeholder || 'Enter input...';
                input.focus();
                
                // Update context indicator
                const contextDiv = document.getElementById('inputContext');
                const contextIcon = document.getElementById('contextIcon');
                const contextText = document.getElementById('contextText');
                if (contextDiv) {
                    contextDiv.style.display = 'block';
                    contextDiv.style.borderColor = '#0abdc6';
                    contextIcon.textContent = '🤖';
                    contextText.textContent = `${config.name} - awaiting input`;
                }
            } else {
                // No input required - run immediately
                executeAIFeature(feature, config, null);
            }
        }
        
        async function executeAIFeature(feature, config, userInput) {
            addMessage(`🔄 Running <strong>${config.name}</strong>...`, false);
            
            try {
                const body = userInput && config.buildBody ? config.buildBody(userInput) : {};
                
                const response = await fetch(config.endpoint, {
                    method: config.method || 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: config.method === 'GET' ? undefined : JSON.stringify(body)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    const analysis = result.analysis || result.audit || result.prediction || 
                                     result.compliance || result.attackPlan || result.prioritized ||
                                     result.recommendations || result;
                    
                    let displayContent = typeof analysis === 'string' ? analysis : JSON.stringify(analysis, null, 2);
                    
                    addMessage(`
                        <div style="background: linear-gradient(135deg, #1a1a25, #0a0a15); border: 2px solid #00ff41; border-radius: 12px; padding: 20px;">
                            <div style="font-size: 1.1em; color: #00ff41; margin-bottom: 10px;"><strong>✅ ${config.name} Results</strong></div>
                            <pre style="white-space: pre-wrap; font-size: 11px; background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; color: #e0e0e0; overflow-x: auto;">${displayContent}</pre>
                        </div>
                    `, false);
                    
                    // Attach results to chat context
                    try {
                        await fetch('/api/chat/attach-context', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                sessionId,
                                contextType: config.name,
                                context: displayContent
                            })
                        });
                    } catch (e) {
                        console.warn('Failed to attach AI feature context:', e);
                    }
                } else {
                    addMessage(`❌ <strong>${config.name} Error:</strong> ${result.error || 'Analysis failed'}`, false);
                }
            } catch (error) {
                addMessage(`❌ <strong>${config.name} Error:</strong> ${error.message}`, false);
            }
            
            // Reset input placeholder
            document.getElementById('userInput').placeholder = 'Ask Neo anything or paste a URL to scan...';
        }
        
        // Check for pending AI feature input when user sends a message
        function checkPendingAIFeature(message) {
            if (pendingAIFeature) {
                const { feature, config } = pendingAIFeature;
                pendingAIFeature = null; // Clear pending state
                
                // Reset context indicator
                const contextDiv = document.getElementById('inputContext');
                if (contextDiv) {
                    contextDiv.style.display = 'none';
                }
                
                // Show user input
                addMessage(message, true);
                
                // Execute the feature with user input
                executeAIFeature(feature, config, message);
                return true; // Handled
            }
            return false; // Not handled, continue normal flow
        }
        
        // Add message helper that scrolls to bottom
        function scrollChatToBottom() {
            const messagesDiv = document.querySelector('.chat-messages');
            if (messagesDiv) {
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }
        }
        
        // Initialize the unified chat interface
        document.addEventListener('DOMContentLoaded', () => {
            // Set default mode
            clearInputContext();
            
            // Auto-scroll on new messages
            const observer = new MutationObserver(() => scrollChatToBottom());
            const messagesDiv = document.querySelector('.chat-messages');
            if (messagesDiv) {
                observer.observe(messagesDiv, { childList: true, subtree: true });
            }
            
            // Auto-fetch network status on page load
            fetchNetworkStatus();
            
            // Refresh network status every 30 seconds
            setInterval(fetchNetworkStatus, 30000);
        });
        
        // Fetch and display network status
        async function fetchNetworkStatus() {
            try {
                // Get network info
                const infoRes = await fetch('/api/network-guardian/info');
                const info = await infoRes.json();
                
                if (info.localIP) {
                    document.getElementById('networkName').textContent = info.networkRange || info.localIP;
                }
                
                // Get network summary (devices with activity)
                const summaryRes = await fetch('/api/network/summary');
                const summary = await summaryRes.json();
                
                if (summary.isMonitoring) {
                    document.getElementById('deviceCount').innerHTML = `<span style="color: #00ff41;">● ${summary.activeDevices}</span> active`;
                    
                    // Show activity alert if there's suspicious activity
                    const alertsDiv = document.getElementById('networkGuardianAlerts');
                    if (summary.activeDevices > 0 && alertsDiv) {
                        alertsDiv.innerHTML = `
                            <div style="font-size: 10px; color: #0abdc6; padding: 5px; background: #0abdc610; border-radius: 4px;">
                                📡 Monitoring ${summary.activeDevices} devices • ${summary.totalQueries} queries captured
                            </div>
                        `;
                    }
                } else {
                    // Try quick ARP scan to get device count
                    const arpRes = await fetch('/api/network-guardian/arp-scan');
                    const arpData = await arpRes.json();
                    
                    if (arpData.devices) {
                        document.getElementById('deviceCount').textContent = `${arpData.devices.length} devices`;
                    }
                }
            } catch (e) {
                console.log('Network status fetch error:', e);
            }
        }
        
        // ═══════════════════════════════════════════════════════════════
        // MOBILE APP SECURITY (MobSF)
        // ═══════════════════════════════════════════════════════════════
        
        let currentMobileScanId = null;
        
        // Handle file drop
        function handleMobileDrop(event) {
            event.preventDefault();
            const uploadArea = document.getElementById('mobileUploadArea');
            uploadArea.style.borderColor = '#ff6b35';
            uploadArea.style.background = 'transparent';
            
            const file = event.dataTransfer.files[0];
            if (file) {
                handleMobileUpload(file);
            }
        }
        
        // Handle file upload
        async function handleMobileUpload(file) {
            if (!file) return;
            
            const validExtensions = ['.apk', '.ipa', '.zip', '.appx'];
            const ext = file.name.toLowerCase().slice(file.name.lastIndexOf('.'));
            
            if (!validExtensions.includes(ext)) {
                addMessage(`❌ Invalid file type: ${ext}. Supported: APK, IPA, ZIP, APPX`, false);
                return;
            }
            
            // Show progress
            document.getElementById('mobileScanProgress').style.display = 'block';
            document.getElementById('mobileScanStatus').textContent = 'Uploading...';
            document.getElementById('mobileScanPercent').textContent = '0%';
            document.getElementById('mobileScanBar').style.width = '0%';
            
            addMessage(`📱 <strong>Mobile App Scan:</strong> Uploading ${file.name}...`, true);
            
            try {
                const formData = new FormData();
                formData.append('file', file);
                
                const response = await fetch('/api/mobsf/scan', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.error) {
                    addMessage(`❌ <strong>MobSF Error:</strong> ${result.error}${result.message ? '. ' + result.message : ''}`, false);
                    document.getElementById('mobileScanProgress').style.display = 'none';
                    return;
                }
                
                currentMobileScanId = result.scanId;
                addMessage(`🔄 <strong>Scanning ${file.name}</strong> with MobSF...`, false);
                
                // Poll for results
                pollMobileScan(result.scanId);
                
            } catch (error) {
                addMessage(`❌ <strong>Upload Error:</strong> ${error.message}`, false);
                document.getElementById('mobileScanProgress').style.display = 'none';
            }
        }
        
        // Poll for scan results
        function pollMobileScan(scanId) {
            const poll = setInterval(async () => {
                try {
                    const response = await fetch(`/api/mobsf/scan/${scanId}`);
                    const scan = await response.json();
                    
                    // Update progress
                    document.getElementById('mobileScanStatus').textContent = scan.status.charAt(0).toUpperCase() + scan.status.slice(1) + '...';
                    document.getElementById('mobileScanPercent').textContent = scan.progress + '%';
                    document.getElementById('mobileScanBar').style.width = scan.progress + '%';
                    
                    if (scan.status === 'complete') {
                        clearInterval(poll);
                        document.getElementById('mobileScanProgress').style.display = 'none';
                        displayMobileScanResults(scan);
                    } else if (scan.status === 'error') {
                        clearInterval(poll);
                        document.getElementById('mobileScanProgress').style.display = 'none';
                        addMessage(`❌ <strong>Scan Error:</strong> ${scan.error}`, false);
                    }
                } catch (error) {
                    clearInterval(poll);
                    document.getElementById('mobileScanProgress').style.display = 'none';
                    addMessage(`❌ <strong>Poll Error:</strong> ${error.message}`, false);
                }
            }, 2000);
        }
        
        // Display scan results
        function displayMobileScanResults(scan) {
            const s = scan.summary;
            const scoreColor = s.securityScore >= 70 ? '#00ff41' : s.securityScore >= 40 ? '#ffaa00' : '#ff0040';
            
            let html = `
                <div style="background: linear-gradient(135deg, #1a1a25, #0a0a15); border: 2px solid #ff6b35; border-radius: 12px; padding: 20px;">
                    <div style="text-align: center; margin-bottom: 15px;">
                        <div style="font-family: 'Orbitron', sans-serif; font-size: 1.3em; color: #ff6b35;">📱 MOBILE APP SECURITY REPORT</div>
                        <div style="color: #888; font-size: 0.85em;">${s.appName} • ${s.packageName}</div>
                    </div>
                    
                    <!-- Security Score -->
                    <div style="text-align: center; margin-bottom: 20px;">
                        <div style="font-size: 3em; color: ${scoreColor}; font-weight: bold;">${s.securityScore}</div>
                        <div style="color: #888;">Security Score</div>
                    </div>
                    
                    <!-- Severity Summary -->
                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 15px;">
                        <div style="background: rgba(255,0,64,0.2); padding: 10px; border-radius: 8px; text-align: center;">
                            <div style="color: #ff0040; font-size: 1.5em; font-weight: bold;">${s.high}</div>
                            <div style="color: #888; font-size: 0.75em;">High</div>
                        </div>
                        <div style="background: rgba(255,170,0,0.2); padding: 10px; border-radius: 8px; text-align: center;">
                            <div style="color: #ffaa00; font-size: 1.5em; font-weight: bold;">${s.medium}</div>
                            <div style="color: #888; font-size: 0.75em;">Medium</div>
                        </div>
                        <div style="background: rgba(0,255,65,0.2); padding: 10px; border-radius: 8px; text-align: center;">
                            <div style="color: #00ff41; font-size: 1.5em; font-weight: bold;">${s.low}</div>
                            <div style="color: #888; font-size: 0.75em;">Low</div>
                        </div>
                        <div style="background: rgba(10,189,198,0.2); padding: 10px; border-radius: 8px; text-align: center;">
                            <div style="color: #0abdc6; font-size: 1.5em; font-weight: bold;">${s.info}</div>
                            <div style="color: #888; font-size: 0.75em;">Info</div>
                        </div>
                    </div>
            `;
            
            // Dangerous Permissions
            if (s.dangerousPermissions && s.dangerousPermissions.length > 0) {
                html += `
                    <div style="margin-bottom: 15px;">
                        <div style="color: #ff6b35; font-weight: bold; margin-bottom: 8px;">⚠️ Dangerous Permissions (${s.dangerousPermissions.length})</div>
                        <div style="background: rgba(0,0,0,0.3); padding: 10px; border-radius: 6px; font-size: 0.8em;">
                            ${s.dangerousPermissions.map(p => `<span style="color: #ffaa00;">• ${p}</span>`).join('<br>')}
                        </div>
                    </div>
                `;
            }
            
            // Key Findings
            if (s.findings && s.findings.length > 0) {
                html += `
                    <div style="margin-bottom: 15px;">
                        <div style="color: #0abdc6; font-weight: bold; margin-bottom: 8px;">🔍 Key Findings</div>
                        <div style="max-height: 200px; overflow-y: auto;">
                `;
                
                s.findings.slice(0, 10).forEach(f => {
                    const sevColor = f.severity === 'HIGH' ? '#ff0040' : f.severity === 'MEDIUM' ? '#ffaa00' : '#00ff41';
                    html += `
                        <div style="background: rgba(0,0,0,0.3); padding: 10px; margin-bottom: 8px; border-left: 3px solid ${sevColor}; border-radius: 4px;">
                            <div style="color: ${sevColor}; font-size: 0.85em; font-weight: bold;">${f.severity}: ${f.title}</div>
                            <div style="color: #888; font-size: 0.75em; margin-top: 4px;">${f.description?.slice(0, 150) || ''}${f.description?.length > 150 ? '...' : ''}</div>
                        </div>
                    `;
                });
                
                if (s.findings.length > 10) {
                    html += `<div style="color: #666; text-align: center; font-size: 0.8em;">... and ${s.findings.length - 10} more findings</div>`;
                }
                
                html += `</div></div>`;
            }
            
            html += `
                    <div style="text-align: center; margin-top: 15px; display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
                        <button onclick="askAboutMobileScan()" class="quick-btn" style="background: linear-gradient(135deg, #00ff41, #0abdc6); color: #0a0a0f; padding: 10px 20px;">
                            💬 Ask Neo about these findings
                        </button>
                        <button onclick="downloadMobilePDF('${scan.scanId}')" class="quick-btn" style="border-color: #ff6b35; padding: 10px 20px;">
                            📄 Download PDF
                        </button>
                        <button onclick="downloadMobileJSON('${scan.scanId}')" class="quick-btn" style="border-color: #0abdc6; padding: 10px 20px;">
                            📋 Download JSON
                        </button>
                    </div>
                </div>
            `;
            
            addMessage(html, false);
            
            // Attach to chat context
            fetch('/api/chat/attach-context', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    sessionId,
                    contextType: 'Mobile App Security Scan (MobSF)',
                    context: JSON.stringify(s, null, 2)
                })
            }).catch(e => console.warn('Failed to attach mobile scan context:', e));
        }
        
        // Ask Neo about mobile scan
        function askAboutMobileScan() {
            document.getElementById('userInput').value = 'Explain the mobile app security findings and what are the most critical issues I should fix?';
            document.getElementById('userInput').focus();
        }
        
        // Download PDF report
        function downloadMobilePDF(scanId) {
            const link = document.createElement('a');
            link.href = `/api/mobsf/scan/${scanId}/pdf`;
            link.download = 'mobile-security-report.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            addMessage('📄 Downloading PDF report...', false);
        }
        
        // Download JSON report
        function downloadMobileJSON(scanId) {
            const link = document.createElement('a');
            link.href = `/api/mobsf/scan/${scanId}/json`;
            link.download = 'mobile-security-report.json';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            addMessage('📋 Downloading JSON report...', false);
        }
        
        // ═══════════════════════════════════════════════════════════════
        // FILE UPLOAD & ANALYSIS SYSTEM
        // ═══════════════════════════════════════════════════════════════
        
        let attachedFile = null;
        let attachedFileContent = null;
        let currentFileId = null;
        
        // File type icons and info
        const fileTypeInfo = {
            // Code files
            'js': { icon: '📜', type: 'JavaScript', lang: 'javascript' },
            'ts': { icon: '📘', type: 'TypeScript', lang: 'typescript' },
            'jsx': { icon: '⚛️', type: 'React JSX', lang: 'javascript' },
            'tsx': { icon: '⚛️', type: 'React TSX', lang: 'typescript' },
            'py': { icon: '🐍', type: 'Python', lang: 'python' },
            'java': { icon: '☕', type: 'Java', lang: 'java' },
            'c': { icon: '🔧', type: 'C', lang: 'c' },
            'cpp': { icon: '🔧', type: 'C++', lang: 'cpp' },
            'cs': { icon: '🎮', type: 'C#', lang: 'csharp' },
            'go': { icon: '🐹', type: 'Go', lang: 'go' },
            'rs': { icon: '🦀', type: 'Rust', lang: 'rust' },
            'rb': { icon: '💎', type: 'Ruby', lang: 'ruby' },
            'php': { icon: '🐘', type: 'PHP', lang: 'php' },
            'swift': { icon: '🍎', type: 'Swift', lang: 'swift' },
            'kt': { icon: '🎯', type: 'Kotlin', lang: 'kotlin' },
            'scala': { icon: '🔴', type: 'Scala', lang: 'scala' },
            'r': { icon: '📊', type: 'R', lang: 'r' },
            'sql': { icon: '🗃️', type: 'SQL', lang: 'sql' },
            'sh': { icon: '🖥️', type: 'Shell', lang: 'bash' },
            'bash': { icon: '🖥️', type: 'Bash', lang: 'bash' },
            'ps1': { icon: '💠', type: 'PowerShell', lang: 'powershell' },
            // Web files
            'html': { icon: '🌐', type: 'HTML', lang: 'html' },
            'htm': { icon: '🌐', type: 'HTML', lang: 'html' },
            'css': { icon: '🎨', type: 'CSS', lang: 'css' },
            'scss': { icon: '🎨', type: 'SCSS', lang: 'scss' },
            'sass': { icon: '🎨', type: 'Sass', lang: 'sass' },
            'less': { icon: '🎨', type: 'Less', lang: 'less' },
            'vue': { icon: '💚', type: 'Vue', lang: 'vue' },
            'svelte': { icon: '🧡', type: 'Svelte', lang: 'svelte' },
            // Config files
            'json': { icon: '📋', type: 'JSON', lang: 'json' },
            'yaml': { icon: '📋', type: 'YAML', lang: 'yaml' },
            'yml': { icon: '📋', type: 'YAML', lang: 'yaml' },
            'xml': { icon: '📋', type: 'XML', lang: 'xml' },
            'toml': { icon: '📋', type: 'TOML', lang: 'toml' },
            'ini': { icon: '⚙️', type: 'INI', lang: 'ini' },
            'env': { icon: '🔐', type: 'Environment', lang: 'env' },
            // Docs
            'md': { icon: '📝', type: 'Markdown', lang: 'markdown' },
            'txt': { icon: '📄', type: 'Text', lang: 'text' },
            'log': { icon: '📋', type: 'Log', lang: 'text' },
            'csv': { icon: '📊', type: 'CSV', lang: 'csv' },
            // Binary/special
            'apk': { icon: '📱', type: 'Android APK', lang: 'binary' },
            'ipa': { icon: '📱', type: 'iOS App', lang: 'binary' },
            'exe': { icon: '⚙️', type: 'Executable', lang: 'binary' },
            'dll': { icon: '📦', type: 'DLL', lang: 'binary' },
            'so': { icon: '📦', type: 'Shared Object', lang: 'binary' },
            'zip': { icon: '📦', type: 'ZIP Archive', lang: 'binary' },
            'tar': { icon: '📦', type: 'TAR Archive', lang: 'binary' },
            'gz': { icon: '📦', type: 'GZip', lang: 'binary' },
            'pdf': { icon: '📕', type: 'PDF', lang: 'binary' },
            'png': { icon: '🖼️', type: 'PNG Image', lang: 'binary' },
            'jpg': { icon: '🖼️', type: 'JPEG Image', lang: 'binary' },
            'jpeg': { icon: '🖼️', type: 'JPEG Image', lang: 'binary' },
            'gif': { icon: '🖼️', type: 'GIF Image', lang: 'binary' },
            'svg': { icon: '🎨', type: 'SVG', lang: 'xml' },
            'default': { icon: '📄', type: 'File', lang: 'text' }
        };
        
        function getFileInfo(filename) {
            const ext = filename.split('.').pop().toLowerCase();
            return fileTypeInfo[ext] || fileTypeInfo['default'];
        }
        
        function formatFileSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
        }
        
        // Handle file upload from chat input
        async function handleChatFileUpload(file) {
            if (!file) return;
            
            attachedFile = file;
            const info = getFileInfo(file.name);
            
            // Update UI
            document.getElementById('attachedFileIndicator').style.display = 'block';
            document.getElementById('attachedFileIcon').textContent = info.icon;
            document.getElementById('attachedFileName').textContent = file.name;
            document.getElementById('attachedFileInfo').textContent = `${info.type} • ${formatFileSize(file.size)}`;
            document.getElementById('fileActionChips').style.display = 'flex';
            
            // Read file content for text files
            if (info.lang !== 'binary' && file.size < 5 * 1024 * 1024) { // Under 5MB
                try {
                    attachedFileContent = await readFileAsText(file);
                    
                    // Show preview
                    const preview = document.getElementById('attachedFilePreview');
                    preview.style.display = 'block';
                    preview.querySelector('pre').textContent = attachedFileContent.slice(0, 500) + (attachedFileContent.length > 500 ? '\n...' : '');
                } catch (e) {
                    console.warn('Could not read file as text:', e);
                }
            }
            
            // Upload to server
            const formData = new FormData();
            formData.append('file', file);
            
            try {
                const response = await fetch('/api/files/upload', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                if (result.fileId) {
                    currentFileId = result.fileId;
                }
            } catch (e) {
                console.warn('File upload failed:', e);
            }
            
            // Focus input for user to type question
            document.getElementById('userInput').placeholder = `Ask about ${file.name}...`;
            document.getElementById('userInput').focus();
        }
        
        function readFileAsText(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = e => resolve(e.target.result);
                reader.onerror = reject;
                reader.readAsText(file);
            });
        }
        
        function removeAttachedFile() {
            attachedFile = null;
            attachedFileContent = null;
            currentFileId = null;
            
            document.getElementById('attachedFileIndicator').style.display = 'none';
            document.getElementById('attachedFilePreview').style.display = 'none';
            document.getElementById('fileActionChips').style.display = 'none';
            document.getElementById('userInput').placeholder = '💻 Paste code to explain, review, or continue...';
            document.getElementById('chatFileInput').value = '';
        }
        
        // Enhanced send function that includes file context
        const originalHandleSmartSend = window.handleSmartSend;
        window.handleSmartSend = async function() {
            const input = document.getElementById('userInput');
            let message = input.value.trim();
            
            // If there's an attached file, include its content in the message
            if (attachedFile && attachedFileContent) {
                const info = getFileInfo(attachedFile.name);
                const fileContext = `
[ATTACHED FILE: ${attachedFile.name}]
[TYPE: ${info.type}]
[SIZE: ${formatFileSize(attachedFile.size)}]

\`\`\`${info.lang}
${attachedFileContent.slice(0, 50000)}${attachedFileContent.length > 50000 ? '\n... (truncated)' : ''}
\`\`\`

USER QUESTION: ${message || 'What does this file do?'}`;
                
                // Set the enhanced message
                input.value = fileContext;
                
                // Add visual indicator that file was sent
                addMessage(`📎 <strong>Attached:</strong> ${attachedFile.name} (${formatFileSize(attachedFile.size)})`, true);
                
                // Clear attachment after sending
                setTimeout(removeAttachedFile, 100);
            }
            
            // Call original send function
            if (typeof originalHandleSmartSend === 'function') {
                return originalHandleSmartSend();
            }
        };
        
        // Download modified file from Neo's response
        function downloadModifiedFile(content, filename) {
            const blob = new Blob([content], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            addMessage(`📥 Downloaded: ${filename}`, false);
        }
        
        // Extract code from Neo's response and offer download
        function extractAndDownloadCode(codeBlock, suggestedName) {
            const filename = prompt('Save as:', suggestedName || 'modified-code.txt');
            if (filename) {
                downloadModifiedFile(codeBlock, filename);
            }
        }
        
        // Drag and drop support for the entire chat area
        const chatMessages = document.getElementById('chatMessages');
        if (chatMessages) {
            chatMessages.addEventListener('dragover', (e) => {
                e.preventDefault();
                chatMessages.style.background = 'rgba(0, 255, 65, 0.05)';
                chatMessages.style.border = '2px dashed #00ff41';
            });
            
            chatMessages.addEventListener('dragleave', (e) => {
                chatMessages.style.background = '';
                chatMessages.style.border = '';
            });
            
            chatMessages.addEventListener('drop', (e) => {
                e.preventDefault();
                chatMessages.style.background = '';
                chatMessages.style.border = '';
                
                const file = e.dataTransfer.files[0];
                if (file) {
                    handleChatFileUpload(file);
                }
            });
        }
        
        // ═══════════════════════════════════════════════════════════════
        // TYPEWRITER PLACEHOLDER ANIMATION
        // ═══════════════════════════════════════════════════════════════
        
        const placeholderMessages = [
            "💻 Paste code to explain, review, or continue...",
            "🔍 Enter URL to scan for vulnerabilities...",
            "👨‍💻 Ask me to review your code like a tech lead...",
            "⚡ \"Continue this code\" - I'll finish it for you...",
            "🛠️ \"Fix this\" - I'll debug and improve your code...",
            "📝 \"Write a function that...\" - I'll build it...",
            "🔒 Paste suspicious email to check for phishing...",
            "🤖 Ask me anything about security or coding..."
        ];
        
        let currentPlaceholderIndex = 0;
        let currentCharIndex = 0;
        let isDeleting = false;
        let typingTimeout = null;
        
        function startPlaceholderAnimation() {
            const input = document.getElementById('userInput');
            if (!input) return;
            
            function type() {
                // Don't animate if user is typing
                if (document.activeElement === input && input.value.length > 0) {
                    typingTimeout = setTimeout(type, 1000);
                    return;
                }
                
                const currentMessage = placeholderMessages[currentPlaceholderIndex];
                
                if (isDeleting) {
                    currentCharIndex--;
                    input.placeholder = currentMessage.substring(0, currentCharIndex);
                    
                    if (currentCharIndex === 0) {
                        isDeleting = false;
                        currentPlaceholderIndex = (currentPlaceholderIndex + 1) % placeholderMessages.length;
                        typingTimeout = setTimeout(type, 500);
                    } else {
                        typingTimeout = setTimeout(type, 30);
                    }
                } else {
                    currentCharIndex++;
                    input.placeholder = currentMessage.substring(0, currentCharIndex);
                    
                    if (currentCharIndex === currentMessage.length) {
                        isDeleting = true;
                        typingTimeout = setTimeout(type, 3000); // Pause before deleting
                    } else {
                        typingTimeout = setTimeout(type, 80);
                    }
                }
            }
            
            // Start the animation
            type();
        }
        
        // Stop animation when user focuses input
        document.getElementById('userInput')?.addEventListener('focus', () => {
            if (typingTimeout) {
                clearTimeout(typingTimeout);
            }
        });
        
        // Resume animation when user blurs input (if empty)
        document.getElementById('userInput')?.addEventListener('blur', () => {
            const input = document.getElementById('userInput');
            if (input && input.value.length === 0) {
                currentCharIndex = 0;
                isDeleting = false;
                startPlaceholderAnimation();
            }
        });
        
        // ═══════════════════════════════════════════════════════════════
        // CODE SELECTION POPUP - Ask about highlighted code
        // ═══════════════════════════════════════════════════════════════
        
        let selectedCodeText = '';
        
        // Listen for text selection in chat messages
        document.addEventListener('mouseup', (e) => {
            const selection = window.getSelection();
            const selectedText = selection.toString().trim();
            
            // Check if selection is within chat messages area
            const chatMessages = document.getElementById('chatMessages');
            if (!chatMessages) return;
            
            // Check if selection contains code-like content
            if (selectedText.length > 10 && isLikelyCode(selectedText)) {
                const range = selection.getRangeAt(0);
                const rect = range.getBoundingClientRect();
                
                // Check if selection is within chat area
                const chatRect = chatMessages.getBoundingClientRect();
                if (rect.top >= chatRect.top && rect.bottom <= chatRect.bottom + 100) {
                    showCodeSelectionPopup(selectedText, rect);
                }
            } else {
                // Hide popup if clicking elsewhere (not on popup itself)
                const popup = document.getElementById('codeSelectionPopup');
                if (popup && !popup.contains(e.target)) {
                    hideCodeSelectionPopup();
                }
            }
        });
        
        // Check if text looks like code
        function isLikelyCode(text) {
            const codeIndicators = [
                /[{}\[\]();]/, // Brackets and semicolons
                /\bfunction\b/, /\bconst\b/, /\blet\b/, /\bvar\b/, // JS keywords
                /\bdef\b/, /\bclass\b/, /\bimport\b/, /\breturn\b/, // Python/general
                /=>/, /===/, /!==/, // Operators
                /\bif\s*\(/, /\bfor\s*\(/, /\bwhile\s*\(/, // Control structures
                /^\s{2,}/m, // Indentation
                /\.\w+\(/, // Method calls
            ];
            
            const matches = codeIndicators.filter(pattern => pattern.test(text)).length;
            return matches >= 2 || text.includes('```');
        }
        
        // Show the popup near the selection
        function showCodeSelectionPopup(text, rect) {
            selectedCodeText = text;
            
            const popup = document.getElementById('codeSelectionPopup');
            const preview = document.getElementById('selectedCodePreview');
            const customInput = document.getElementById('customCodeQuestion');
            
            // Show preview (truncated)
            const truncated = text.length > 100 ? text.substring(0, 100) + '...' : text;
            preview.textContent = truncated;
            
            // Position popup near selection
            const popupWidth = 280;
            let left = rect.left + (rect.width / 2) - (popupWidth / 2);
            let top = rect.bottom + 10;
            
            // Keep popup on screen
            if (left < 10) left = 10;
            if (left + popupWidth > window.innerWidth - 10) {
                left = window.innerWidth - popupWidth - 10;
            }
            if (top + 250 > window.innerHeight) {
                top = rect.top - 260;
            }
            
            popup.style.left = left + 'px';
            popup.style.top = top + 'px';
            popup.style.display = 'block';
            
            // Clear custom question
            customInput.value = '';
        }
        
        // Hide the popup
        function hideCodeSelectionPopup() {
            const popup = document.getElementById('codeSelectionPopup');
            if (popup) {
                popup.style.display = 'none';
            }
            selectedCodeText = '';
        }
        
        // Ask about the selected code
        async function askAboutCode(action) {
            if (!selectedCodeText) return;
            
            let question = '';
            const customInput = document.getElementById('customCodeQuestion');
            
            switch (action) {
                case 'explain':
                    question = `Explain this code in detail - what does each part do?\n\n\`\`\`\n${selectedCodeText}\n\`\`\``;
                    break;
                case 'simplify':
                    question = `Simplify this code and make it more readable:\n\n\`\`\`\n${selectedCodeText}\n\`\`\``;
                    break;
                case 'improve':
                    question = `Improve this code - better performance, cleaner structure, best practices:\n\n\`\`\`\n${selectedCodeText}\n\`\`\``;
                    break;
                case 'bugs':
                    question = `Find any bugs, issues, or potential problems in this code:\n\n\`\`\`\n${selectedCodeText}\n\`\`\``;
                    break;
                case 'custom':
                    const customQuestion = customInput.value.trim();
                    if (!customQuestion) {
                        customInput.focus();
                        return;
                    }
                    question = `${customQuestion}\n\n\`\`\`\n${selectedCodeText}\n\`\`\``;
                    break;
            }
            
            // Hide popup
            hideCodeSelectionPopup();
            
            // Clear any text selection
            window.getSelection().removeAllRanges();
            
            // Add user message to chat
            addMessage(question, true);
            
            // Send to Neo
            const typingId = addTypingIndicator();
            
            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: question, sessionId })
                });
                
                const data = await response.json();
                removeTypingIndicator(typingId);
                
                if (data.message) {
                    addAIMessage(data.message);
                }
            } catch (error) {
                removeTypingIndicator(typingId);
                addMessage(`❌ Error: ${error.message}`, false);
            }
        }
        
        // Close popup on Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                hideCodeSelectionPopup();
            }
        });
    </script>
</body>
</html>
