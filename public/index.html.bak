        // Show whitelist in chat
        async function showWhitelistInChat() {
            try {
                const response = await fetch('/api/network-guardian/whitelist');
                const data = await response.json();
                
                if (!data.devices || data.devices.length === 0) {
                    addMessage(`
                        <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #00ff41;">
                            <strong style="color: #00ff41;">📋 Trusted Devices Whitelist</strong><br><br>
                            <p style="color: #888;">No devices in whitelist yet. Run a network scan and trust your devices!</p>
                        </div>
                    `);
                    return;
                }
                
                let html = `
                    <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #00ff41;">
                        <strong style="color: #00ff41;">📋 Trusted Devices (${data.devices.length})</strong><br><br>
                `;
                
                data.devices.forEach(d => {
                    html += `
                        <div style="padding: 10px; background: #0a0a0f; border-radius: 6px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <strong style="color: #e0e0e0;">${d.name}</strong><br>
                                <span style="font-size: 11px; color: #666;">${d.mac} • ${d.vendor || 'Unknown vendor'}</span>
                            </div>
                            <button onclick="removeFromWhitelistChat('${d.mac}')" style="background: #ff004020; border: 1px solid #ff0040; color: #ff0040; padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 11px;">
                                ✕ Remove
                            </button>
                        </div>
                    `;
                });
                
                html += `</div>`;
                addMessage(html);
                
            } catch (e) {
                addMessage(`❌ Failed to load whitelist: ${e.message}`);
            }
        }
        
        // Remove from whitelist via chat
        async function removeFromWhitelistChat(mac) {
            await removeFromWhitelistUI(mac);
            await showWhitelistInChat(); // Refresh the list
        }
        
        // Show network history in chat
        async function showNetworkHistoryInChat() {
            try {
                const response = await fetch('/api/network-guardian/history?limit=5');
                const scans = await response.json();
                
                if (!scans || scans.length === 0) {
                    addMessage(`
                        <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #0abdc6;">
                            <strong style="color: #0abdc6;">📊 Scan History</strong><br><br>
                            <p style="color: #888;">No scan history yet. Run your first network scan!</p>
                        </div>
                    `);
                    return;
                }
                
                let html = `
                    <div style="background: #1a1a25; padding: 15px; border-radius: 8px; border: 1px solid #0abdc6;">
                        <strong style="color: #0abdc6;">📊 Recent Network Scans</strong><br><br>
                `;
                
                scans.forEach((scan, i) => {
                    const time = new Date(scan.scanTime).toLocaleString();
                    const deviceCount = scan.devices?.length || 0;
                    const unknownCount = scan.unknownCount || 0;
                    
                    html += `
                        <div style="padding: 10px; background: #0a0a0f; border-radius: 6px; margin-bottom: 8px;">
                            <div style="display: flex; justify-content: space-between;">
                                <strong style="color: #e0e0e0;">${time}</strong>
                                <span style="color: #00ff41;">${deviceCount} devices</span>
                            </div>
                            <div style="font-size: 11px; color: #888; margin-top: 5px;">
                                ${unknownCount > 0 ? `<span style="color: #ffaa00;">${unknownCount} unknown</span> • ` : ''}
                                ${scan.method || 'arp'}
                            </div>
                        </div>
                    `;
                });
                
                html += `</div>`;
                addMessage(html);
                
            } catch (e) {
                addMessage(`❌ Failed to load history: ${e.message}`);
            }
        }
        
