                        <strong>Location:</strong> ${geo.city || 'Unknown'}, ${geo.region || ''}, ${geo.country || 'Unknown'}<br>
                        <strong>Coordinates:</strong> ${geo.latitude}, ${geo.longitude}<br>
                        <strong>Timezone:</strong> ${geo.timezone || 'N/A'}<br>
                        <strong>ISP:</strong> ${geo.isp || 'Unknown'}<br>
                        <strong>Organization:</strong> ${geo.organization || 'Unknown'}<br>
                        ${geo.asn ? `<strong>ASN:</strong> ${geo.asn}<br>` : ''}
                        ${geo.isProxy ? '<span style="color: #ff6b6b;">⚠️ Proxy/VPN</span><br>' : ''}
                        ${geo.mapUrl ? `<br><a href="${geo.mapUrl}" target="_blank" style="color: #0abdc6;">🗺️ View on Map</a>` : ''}
                    </div>
                `, true);
            } catch (error) {
                addMessage(`❌ Geolocation failed: ${error.message}`, true);
            }
        }
        
        async function quickWhois() {
            const ip = document.getElementById('ipInvestigatorTarget').value.trim();
            if (!ip) {
                addMessage('❌ Please enter an IP address.', true);
                return;
            }
            
            addMessage(`🏛️ <strong>WHOIS Lookup:</strong> ${ip}`, true);
            
