<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumen Cortex - AI Security & Coding Assistant</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00ff41;
            --secondary: #0abdc6;
            --danger: #ff0040;
            --warning: #ffaa00;
            --bg-dark: #0a0a0f;
            --bg-card: #12121a;
            --bg-input: #1a1a25;
            --text: #e0e0e0;
            --text-dim: #666;
            --border: #2a2a3a;
            --glow: rgba(0, 255, 65, 0.3);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            font-family: 'JetBrains Mono', monospace;
            background: var(--bg-dark);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        /* Matrix rain background */
        .matrix-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            opacity: 0.08;
        }

        /* Scanlines effect */
        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1000;
            background: repeating-linear-gradient(
                0deg,
                rgba(0, 0, 0, 0.1),
                rgba(0, 0, 0, 0.1) 1px,
                transparent 1px,
                transparent 2px
            );
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 20px 30px;
            width: 100%;
            position: relative;
            z-index: 1;
        }

        /* Header */
        header {
            text-align: center;
            padding: 20px 0;
            border-bottom: 1px solid var(--border);
            margin-bottom: 20px;
        }

        .logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 3rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 40px var(--glow);
            letter-spacing: 4px;
            animation: glitch 3s infinite;
        }

        @keyframes glitch {
            0%, 90%, 100% { transform: translate(0); }
            92% { transform: translate(-2px, 1px); }
            94% { transform: translate(2px, -1px); }
            96% { transform: translate(-1px, 2px); }
            98% { transform: translate(1px, -2px); }
        }

        .tagline {
            color: var(--secondary);
            margin-top: 10px;
            font-size: 0.9rem;
            letter-spacing: 2px;
        }

        .footnote {
            color: var(--text-dim);
            margin-top: 15px;
            font-size: 0.75rem;
            letter-spacing: 1px;
            opacity: 0.7;
        }

        /* Typewriter cursor animation for input */
        @keyframes blink-cursor {
            0%, 50% { border-right-color: var(--primary); }
            51%, 100% { border-right-color: transparent; }
        }
        
        .typewriter-input::placeholder {
            color: var(--secondary);
            opacity: 0.8;
        }
        
        .typewriter-input:focus::placeholder {
            color: var(--primary);
        }

        /* Code Selection Popup */
        .code-selection-popup {
            position: fixed;
            background: linear-gradient(135deg, #1a1a25, #12121a);
            border: 2px solid var(--primary);
            border-radius: 12px;
            padding: 12px;
            box-shadow: 0 8px 32px rgba(0, 255, 65, 0.3);
            z-index: 10000;
            display: none;
            animation: popupFadeIn 0.2s ease;
            max-width: 300px;
        }
        
        @keyframes popupFadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .code-selection-popup .popup-title {
            color: var(--primary);
            font-size: 0.85em;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .code-selection-popup .selected-code-preview {
            background: rgba(0, 0, 0, 0.4);
            border-radius: 6px;
            padding: 8px;
            font-size: 0.75em;
            color: var(--secondary);
            max-height: 60px;
            overflow: hidden;
            margin-bottom: 10px;
            font-family: 'JetBrains Mono', monospace;
            border-left: 3px solid var(--primary);
        }
        
        .code-selection-popup .quick-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }
        
        .code-selection-popup .quick-action-btn {
            background: rgba(0, 255, 65, 0.1);
            border: 1px solid var(--primary);
            color: var(--primary);
            padding: 6px 10px;
            border-radius: 6px;
            font-size: 0.75em;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }
        
        .code-selection-popup .quick-action-btn:hover {
            background: var(--primary);
            color: #0a0a0f;
        }
        
        .code-selection-popup .custom-question {
            width: 100%;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 8px;
            border-radius: 6px;
            font-size: 0.8em;
            margin-top: 8px;
            font-family: inherit;
        }
        
        .code-selection-popup .custom-question:focus {
            border-color: var(--primary);
            outline: none;
        }
        
        .code-selection-popup .ask-btn {
            width: 100%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: none;
            color: #0a0a0f;
            padding: 8px;
            border-radius: 6px;
            font-size: 0.85em;
            font-weight: bold;
            cursor: pointer;
            margin-top: 8px;
            font-family: inherit;
        }
        
        .code-selection-popup .ask-btn:hover {
            filter: brightness(1.1);
        }
        
        .code-selection-popup .close-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            background: none;
            border: none;
            color: var(--text-dim);
            cursor: pointer;
            font-size: 1em;
            padding: 2px 6px;
        }
        
        .code-selection-popup .close-btn:hover {
            color: var(--danger);
        }

        /* Main grid */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 25px;
            align-items: start;
            width: 100%;
        }

        /* Chat panel */
        .chat-panel {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            height: 70vh;
        }

        .chat-header {
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .status-indicator {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--primary);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; box-shadow: 0 0 10px var(--primary); }
            50% { opacity: 0.5; box-shadow: 0 0 5px var(--primary); }
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .message {
            margin-bottom: 20px;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message.user {
            text-align: right;
        }

        .message-content {
            display: inline-block;
            padding: 12px 18px;
            border-radius: 12px;
            max-width: 80%;
        }

        .message.user .message-content {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: var(--bg-dark);
        }

        .message.ai .message-content {
            background: var(--bg-input);
            border: 1px solid var(--border);
        }

        .message-label {
            font-size: 0.7rem;
            color: var(--text-dim);
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .chat-input-area {
            padding: 20px;
            border-top: 1px solid var(--border);
        }

        .input-wrapper {
            display: flex;
            gap: 10px;
        }

        .chat-input {
            flex: 1;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            color: var(--text);
            font-family: inherit;
            font-size: 0.95rem;
            outline: none;
            transition: all 0.3s;
        }

        .chat-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 20px var(--glow);
        }

        .chat-input::placeholder {
            color: var(--text-dim);
        }

        .send-btn {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: none;
            border-radius: 8px;
            padding: 15px 25px;
            color: var(--bg-dark);
            font-family: inherit;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .send-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px var(--glow);
        }

        .send-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Voice button */
        .voice-btn {
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            font-size: 1.2em;
            cursor: pointer;
            transition: all 0.3s;
        }

        .voice-btn:hover {
            border-color: var(--secondary);
            box-shadow: 0 0 15px rgba(10, 189, 198, 0.3);
        }

        .voice-btn.listening {
            background: linear-gradient(135deg, #ff0040, #ff4444);
            animation: pulse-voice 1s infinite;
            border-color: #ff0040;
        }

        @keyframes pulse-voice {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        /* Input hints */
        .input-hints {
            display: flex;
            gap: 8px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .input-hints span {
            background: var(--bg-input);
            border: 1px solid var(--border);
            padding: 5px 10px;
            border-radius: 15px;
            font-size: 0.75em;
            cursor: pointer;
            transition: all 0.2s;
        }

        .input-hints span:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .input-hints span.active {
            background: var(--primary);
            color: var(--bg-dark);
            border-color: var(--primary);
        }

        /* AI Message styling */
        .message.ai .message-content {
            background: var(--bg-input);
            border: 1px solid var(--border);
        }

        .message.ai .message-content pre {
            background: rgba(0, 0, 0, 0.3);
            padding: 12px;
            border-radius: 6px;
            overflow-x: auto;
            margin: 10px 0;
        }

        .message.ai .message-content code {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85em;
        }

        .message.ai .message-content h1,
        .message.ai .message-content h2,
        .message.ai .message-content h3 {
            color: var(--secondary);
            margin-top: 15px;
        }

        .message.ai .message-content ul,
        .message.ai .message-content ol {
            padding-left: 20px;
        }

        .message.ai .message-content a {
            color: var(--secondary);
        }

        /* Typing indicator */
        .typing-indicator {
            display: flex;
            gap: 4px;
            padding: 10px;
        }

        .typing-indicator span {
            width: 8px;
            height: 8px;
            background: var(--secondary);
            border-radius: 50%;
            animation: typing 1.4s infinite ease-in-out;
        }

        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
            30% { transform: translateY(-10px); opacity: 1; }
        }

        /* Code highlighting in findings */
        .finding-location {
            background: rgba(255, 0, 64, 0.1);
            border-left: 3px solid #ff0040;
            padding: 10px;
            margin: 10px 0;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85em;
        }

        .finding-location .file {
            color: var(--secondary);
        }

        .finding-location .line {
            color: #ff0040;
        }

        /* Side panel */
        .side-panel {
            display: flex;
            flex-direction: column;
            gap: 15px;
            max-height: 80vh;
            overflow-y: auto;
            padding-right: 5px;
            position: sticky;
            top: 20px;
        }
        
        .side-panel::-webkit-scrollbar {
            width: 6px;
        }
        
        .side-panel::-webkit-scrollbar-track {
            background: var(--bg-dark);
        }
        
        .side-panel::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }
        
        .side-panel::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

        .panel-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
        }

        .panel-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9rem;
            color: var(--primary);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 2px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel-title::before {
            content: '▸';
            color: var(--secondary);
        }

        /* Active tools */
        .tool-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .tool-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            background: var(--bg-input);
            border-radius: 6px;
            font-size: 0.85rem;
        }

        .tool-item.ai-powered {
            border-left: 2px solid var(--secondary);
        }

        .ai-badge {
            font-size: 0.65rem;
            background: linear-gradient(135deg, var(--secondary), #8b5cf6);
            color: var(--bg-dark);
            padding: 2px 6px;
            border-radius: 10px;
            font-weight: 700;
            margin-left: auto;
        }

        .tool-status {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .tool-status.running {
            background: var(--warning);
            animation: pulse 1s infinite;
        }

        .tool-status.success {
            background: var(--primary);
        }

        .tool-status.error {
            background: var(--danger);
        }

        .tool-status.pending {
            background: var(--text-dim);
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .stat-item {
            text-align: center;
            padding: 15px;
            background: var(--bg-input);
            border-radius: 6px;
        }

        .stat-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.5rem;
            color: var(--primary);
        }

        .stat-label {
            font-size: 0.7rem;
            color: var(--text-dim);
            text-transform: uppercase;
            margin-top: 5px;
        }

        /* Risk indicator */
        .risk-indicator {
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .risk-indicator.low {
            background: rgba(0, 255, 65, 0.1);
            border: 1px solid var(--primary);
            color: var(--primary);
        }

        .risk-indicator.medium {
            background: rgba(255, 170, 0, 0.1);
            border: 1px solid var(--warning);
            color: var(--warning);
        }

        .risk-indicator.high {
            background: rgba(255, 0, 64, 0.1);
            border: 1px solid var(--danger);
            color: var(--danger);
        }

        /* Quick actions */
        .quick-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .quick-btn {
            padding: 8px 12px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 20px;
            color: var(--text);
            font-family: inherit;
            font-size: 0.75rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .quick-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .quick-btn.attack-quick {
            border-color: #ff0040;
            color: #ff6666;
        }

        .quick-btn.attack-quick:hover {
            border-color: #ff0040;
            background: rgba(255, 0, 64, 0.2);
            color: #ff0040;
        }

        .attack-btn {
            background: linear-gradient(135deg, #0abdc6, #00ff41) !important;
        }

        .attack-btn:hover {
            box-shadow: 0 0 30px rgba(255, 0, 64, 0.5) !important;
        }

        /* Results panel */
        .results-panel {
            margin-top: 20px;
            max-height: 300px;
            overflow-y: auto;
        }

        .result-item {
            padding: 10px;
            margin-bottom: 8px;
            background: var(--bg-input);
            border-radius: 6px;
            border-left: 3px solid var(--primary);
            font-size: 0.8rem;
        }

        .result-item.warning {
            border-left-color: var(--warning);
        }

        .result-item.error {
            border-left-color: var(--danger);
        }

        /* Loading animation */
        .loading {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .loading-bar {
            flex: 1;
            height: 4px;
            background: var(--bg-input);
            border-radius: 2px;
            overflow: hidden;
        }

        .loading-progress {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            animation: loading 2s infinite;
        }

        @keyframes loading {
            0% { width: 0%; }
            50% { width: 70%; }
            100% { width: 100%; }
        }

        /* ASCII art header */
        .ascii-art {
            font-size: 0.6rem;
            color: var(--primary);
            opacity: 0.5;
            white-space: pre;
            text-align: center;
            margin-bottom: 10px;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .main-grid {
                grid-template-columns: 1fr;
            }
            .container {
                padding: 10px;
            }
        }

        @media (max-width: 768px) {
            .ascii-art {
                display: none;
            }
            .logo {
                font-size: 1.5rem !important;
            }
            .tagline {
                font-size: 0.8rem !important;
            }
            header {
                padding: 15px 10px !important;
            }
            .chat-panel, .side-panel {
                padding: 10px !important;
            }
            .chat-input {
                font-size: 14px !important;
            }
            .btn {
                padding: 8px 12px !important;
                font-size: 12px !important;
            }
            .tool-btn {
                padding: 8px 10px !important;
                font-size: 11px !important;
            }
            .tools-grid {
                grid-template-columns: repeat(2, 1fr) !important;
                gap: 8px !important;
            }
            .module-grid {
                grid-template-columns: 1fr !important;
            }
            .stat-box {
                padding: 10px !important;
            }
            .stat-value {
                font-size: 1.2rem !important;
            }
            .message-content {
                font-size: 13px !important;
            }
            .footnote {
                font-size: 10px !important;
            }
            #deviceDashboard, #monitoringSection, #reportSection {
                padding: 0 10px !important;
            }
            .device-card {
                padding: 12px !important;
            }
            h2 {
                font-size: 1.1rem !important;
            }
            h3 {
                font-size: 1rem !important;
            }
        }

        @media (max-width: 480px) {
            .logo {
                font-size: 1.2rem !important;
            }
            .tools-grid {
                grid-template-columns: 1fr !important;
            }
            .chat-messages {
                min-height: 200px !important;
                max-height: 300px !important;
            }
            .btn {
                width: 100%;
                margin-bottom: 5px;
            }
        }
    </style>
</head>
<body>
    <div class="scanlines"></div>
    <canvas class="matrix-bg" id="matrix"></canvas>
    
    <!-- Code Selection Popup -->
    <div class="code-selection-popup" id="codeSelectionPopup">
        <button class="close-btn" onclick="hideCodeSelectionPopup()">✕</button>
        <div class="popup-title">💻 Ask about this code</div>
        <div class="selected-code-preview" id="selectedCodePreview"></div>
        <div class="quick-actions">
            <button class="quick-action-btn" onclick="askAboutCode('explain')">🔍 Explain</button>
            <button class="quick-action-btn" onclick="askAboutCode('simplify')">✨ Simplify</button>
            <button class="quick-action-btn" onclick="askAboutCode('improve')">⚡ Improve</button>
            <button class="quick-action-btn" onclick="askAboutCode('bugs')">🐛 Find Bugs</button>
        </div>
        <input type="text" class="custom-question" id="customCodeQuestion" placeholder="Or ask your own question..." onkeypress="if(event.key==='Enter')askAboutCode('custom')">
        <button class="ask-btn" onclick="askAboutCode('custom')">Ask Neo →</button>
    </div>

    <div class="container">
        <header>
            <div class="ascii-art">
    ██╗     ██╗   ██╗███╗   ███╗███████╗███╗   ██╗     ██████╗ ██████╗ ██████╗ ████████╗███████╗██╗  ██╗
    ██║     ██║   ██║████╗ ████║██╔════╝████╗  ██║    ██╔════╝██╔═══██╗██╔══██╗╚══██╔══╝██╔════╝╚██╗██╔╝
    ██║     ██║   ██║██╔████╔██║█████╗  ██╔██╗ ██║    ██║     ██║   ██║██████╔╝   ██║   █████╗   ╚███╔╝ 
    ██║     ██║   ██║██║╚██╔╝██║██╔══╝  ██║╚██╗██║    ██║     ██║   ██║██╔══██╗   ██║   ██╔══╝   ██╔██╗ 
    ███████╗╚██████╔╝██║ ╚═╝ ██║███████╗██║ ╚████║    ╚██████╗╚██████╔╝██║  ██║   ██║   ███████╗██╔╝ ██╗
    ╚══════╝ ╚═════╝ ╚═╝     ╚═╝╚══════╝╚═╝  ╚═══╝     ╚═════╝ ╚═════╝ ╚═╝  ╚═╝   ╚═╝   ╚══════╝╚═╝  ╚═╝
            </div>
            <h1 class="logo">LUMEN CORTEX</h1>
            <p class="tagline">[ CYBERSECURITY EXPERT • CODE EXPERT • YOUR TECH LEAD ]</p>
            <p class="footnote">Paste code to explain, review, or continue • Ask Neo anything • Lumen AI Solutions</p>
        </header>

        <div class="main-grid">
            <div class="chat-panel">
                <div class="chat-header">
                    <div class="status-indicator"></div>
                    <span>Neo • Online</span>
                    <span style="margin-left: auto; font-size: 0.75em; color: var(--secondary);">💻 Code Expert • 🛡️ Cybersecurity Expert</span>
                </div>
                <div class="chat-messages" id="chatMessages">
                    <div class="message ai">
                        <div class="message-label">🤖 Neo</div>
                        <div class="message-content">
                            <strong style="font-size: 1.1em;">Hey! I'm Neo</strong> — your AI cybersecurity expert, code expert, and tech coach all in one. 🧠<br><br>
                            
                            <strong style="color: #00ff41;">💻 Code — I can help you:</strong><br>
                            • <strong>Explain</strong> any code in plain English<br>
                            • <strong>Review</strong> your code like a senior engineer<br>
                            • <strong>Write</strong> new code from your description<br>
                            • <strong>Fix bugs</strong> and improve your code<br>
                            • <strong>Refactor</strong> messy code into clean code<br><br>
                            
                            <strong style="color: #0abdc6;">🔒 Security — I can:</strong><br>
                            • <strong>Scan</strong> websites for vulnerabilities<br>
                            • <strong>Analyze</strong> mobile apps (APK/IPA) for security issues<br>
                            • <strong>Find</strong> secrets & API keys in code<br>
                            • <strong>Explain</strong> threats in plain English<br><br>
                            
                            <strong style="color: #ff6b35;">📎 Files — Drop any file and ask me:</strong><br>
                            • "What does this file do?"<br>
                            • "Is this code secure?"<br>
                            • "Refactor this and make it better"<br><br>
                            
                            <span style="color: #888;">I explain everything in plain English — no confusing jargon. Just ask!</span>
                        </div>
                    </div>
                </div>
                <div class="chat-input-area">
                    <!-- Attached File Indicator -->
                    <div id="attachedFileIndicator" style="display: none; margin-bottom: 8px; padding: 10px 12px; background: linear-gradient(135deg, #1a1a25, #12121a); border: 1px solid #0abdc6; border-radius: 8px;">
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span id="attachedFileIcon" style="font-size: 1.5em;">📄</span>
                                <div>
                                    <div id="attachedFileName" style="color: #0abdc6; font-size: 0.9em; font-weight: bold;">filename.js</div>
                                    <div id="attachedFileInfo" style="color: #666; font-size: 0.75em;">JavaScript • 2.4 KB</div>
                                </div>
                            </div>
                            <button onclick="removeAttachedFile()" style="background: none; border: none; color: #ff0040; cursor: pointer; font-size: 1.2em;" title="Remove file">✕</button>
                        </div>
                        <div id="attachedFilePreview" style="margin-top: 8px; max-height: 100px; overflow: hidden; background: rgba(0,0,0,0.3); border-radius: 4px; padding: 8px; font-size: 0.75em; color: #888; display: none;">
                            <pre style="margin: 0; white-space: pre-wrap; word-break: break-all;"></pre>
                        </div>
                    </div>
                    
                    <!-- Unified Chat Input - Always Available -->
                    <div class="input-wrapper">
                        <button class="voice-btn" onclick="toggleVoiceInput()" id="voiceBtn" title="Voice Input">
                            🎤
                        </button>
                        <button class="voice-btn" onclick="document.getElementById('chatFileInput').click()" id="fileBtn" title="Upload File" style="margin-left: 4px;">
                            📎
                        </button>
                        <input type="file" id="chatFileInput" style="display: none;" onchange="handleChatFileUpload(this.files[0])">
                        <input type="text" class="chat-input typewriter-input" id="userInput" 
                               placeholder="💻 Paste code to explain, review, or continue..." 
                               onkeypress="handleSmartInput(event)"
                               onfocus="showInputContext()">
                        <button class="send-btn" onclick="handleSmartSend()" id="sendBtn" style="background: linear-gradient(135deg, #0abdc6, #00ff41); color: #0a0a0f;">💬 Send</button>
                    </div>
                    
                    <!-- Context indicator (shows what mode/tool is active) -->
                    <div id="inputContext" style="display: none; margin-top: 8px; padding: 8px 12px; background: #1a1a25; border-radius: 6px; border-left: 3px solid #0abdc6;">
                        <span id="contextIcon">🤖</span>
                        <span id="contextText" style="color: #888; font-size: 12px;">AI Assistant ready</span>
                        <button onclick="clearInputContext()" style="float: right; background: none; border: none; color: #666; cursor: pointer; font-size: 10px;">✕ clear</button>
                    </div>
                    
                    <!-- Quick action chips -->
                    <div class="input-hints" style="margin-top: 10px;">
                        <span onclick="setInputMode('scan')" class="mode-chip" data-mode="scan" style="cursor: pointer;">🔍 Scan URL</span>
                        <span onclick="setInputMode('network')" class="mode-chip" data-mode="network" style="cursor: pointer;">🛡️ Network</span>
                        <span onclick="setInputMode('github')" class="mode-chip" data-mode="github" style="cursor: pointer;">🐙 GitHub</span>
                        <span onclick="insertPrompt('explain the security findings', this)" class="prompt-chip" style="cursor: pointer;">💡 Explain</span>
                        <span onclick="insertPrompt('how do I fix these vulnerabilities?', this)" class="prompt-chip" style="cursor: pointer;">🔧 Fix</span>
                        <span onclick="toggleVoiceOutput()" id="voiceOutputToggle" style="cursor: pointer;">🔊 Voice</span>
                    </div>
                    
                    <!-- File action chips (shown when file is attached) -->
                    <div id="fileActionChips" class="input-hints" style="margin-top: 8px; display: none;">
                        <span onclick="insertPrompt('What does this file do? Explain in detail.', this)" class="prompt-chip" style="cursor: pointer; border-color: #0abdc6;">📖 Explain</span>
                        <span onclick="insertPrompt('Review this code. Give me suggestions for improvements.', this)" class="prompt-chip" style="cursor: pointer; border-color: #00ff41;">👨‍💻 Review</span>
                        <span onclick="insertPrompt('Scan this file for security vulnerabilities.', this)" class="prompt-chip" style="cursor: pointer; border-color: #ff0040;">🔒 Security Scan</span>
                        <span onclick="insertPrompt('Refactor this code to be cleaner and more efficient.', this)" class="prompt-chip" style="cursor: pointer; border-color: #ffaa00;">✨ Refactor</span>
                        <span onclick="insertPrompt('Find and fix bugs in this code.', this)" class="prompt-chip" style="cursor: pointer; border-color: #ff6b35;">🐛 Fix Bugs</span>
                    </div>
                    
                    <!-- Hidden mode state -->
                    <input type="hidden" id="currentInputMode" value="chat">
                    <input type="hidden" id="selectedModeLabel" value="">
                </div>
            </div>

            <div class="side-panel">
                <!-- Tool Category Tabs -->
                <div style="display: flex; gap: 4px; margin-bottom: 12px; flex-wrap: wrap;">
                    <button class="tool-tab active" onclick="showToolCategory('intel')" id="tab-intel" style="flex: 1; min-width: 60px; padding: 8px 4px; background: #1a1a25; border: 1px solid #ff6b6b; color: #ff6b6b; border-radius: 6px; cursor: pointer; font-size: 10px; font-weight: bold;">🔍 Intel</button>
                    <button class="tool-tab" onclick="showToolCategory('network')" id="tab-network" style="flex: 1; min-width: 60px; padding: 8px 4px; background: #1a1a25; border: 1px solid #444; color: #888; border-radius: 6px; cursor: pointer; font-size: 10px;">🛡️ Network</button>
                    <button class="tool-tab" onclick="showToolCategory('scanners')" id="tab-scanners" style="flex: 1; min-width: 60px; padding: 8px 4px; background: #1a1a25; border: 1px solid #444; color: #888; border-radius: 6px; cursor: pointer; font-size: 10px;">🎯 Scan</button>
                    <button class="tool-tab" onclick="showToolCategory('mobile')" id="tab-mobile" style="flex: 1; min-width: 60px; padding: 8px 4px; background: #1a1a25; border: 1px solid #444; color: #888; border-radius: 6px; cursor: pointer; font-size: 10px;">📱 Mobile</button>
                    <button class="tool-tab" onclick="showToolCategory('more')" id="tab-more" style="flex: 1; min-width: 60px; padding: 8px 4px; background: #1a1a25; border: 1px solid #444; color: #888; border-radius: 6px; cursor: pointer; font-size: 10px;">⚡ More</button>
                </div>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- INTEL CATEGORY - IP & Domain Investigation -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <div id="category-intel" class="tool-category">
                    <!-- IP Investigator -->
                    <div class="panel-card" style="border: 1px solid #ff6b6b;">
                        <div class="panel-title" style="color: #ff6b6b;">🔍 IP Investigator</div>
                        <div style="margin-bottom: 10px;">
                            <input type="text" id="ipInvestigatorTarget" placeholder="Enter IP address (e.g., 8.8.8.8)" style="width: 100%; background: #1a1a25; border: 1px solid #ff6b6b; color: #e0e0e0; padding: 8px; border-radius: 4px; font-size: 11px;">
                        </div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="investigateIP()" style="flex: 2; background: linear-gradient(135deg, #ff6b6b, #ff0040); color: #0a0a0f;">🔍 Investigate</button>
                            <button class="quick-btn" onclick="quickGeolocate()" style="flex: 1; border-color: #ff6b6b;">📍</button>
                            <button class="quick-btn" onclick="quickPortScan()" style="flex: 1; border-color: #ff6b6b;">🚪</button>
                        </div>
                        <div id="ipInvestigatorStatus" style="margin-top: 6px; font-size: 10px; color: #666;"></div>
                    </div>

                    <!-- Domain Investigator -->
                    <div class="panel-card" style="border: 1px solid #0abdc6;">
                        <div class="panel-title" style="color: #0abdc6;">🌐 Domain Investigator</div>
                        <div style="margin-bottom: 10px;">
                            <input type="text" id="domainInvestigatorTarget" placeholder="Enter domain (e.g., google.com)" style="width: 100%; background: #1a1a25; border: 1px solid #0abdc6; color: #e0e0e0; padding: 8px; border-radius: 4px; font-size: 11px;">
                        </div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="investigateDomain()" style="flex: 2; background: linear-gradient(135deg, #0abdc6, #00ff41); color: #0a0a0f;">🌐 Investigate</button>
                            <button class="quick-btn" onclick="quickDNS()" style="flex: 1; border-color: #0abdc6;">📋</button>
                            <button class="quick-btn" onclick="quickSSL()" style="flex: 1; border-color: #0abdc6;">🔒</button>
                        </div>
                        <div id="domainInvestigatorStatus" style="margin-top: 6px; font-size: 10px; color: #666;"></div>
                    </div>

                    <!-- GitHub Secret Hunter (compact) -->
                    <div class="panel-card" style="border: 1px solid #8b5cf6;">
                        <div class="panel-title" style="color: #8b5cf6;">🔑 Secret Hunter</div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="githubHuntWithChat('aws')" style="border-color: #8b5cf6;">AWS</button>
                            <button class="quick-btn" onclick="githubHuntWithChat('stripe')" style="border-color: #8b5cf6;">Stripe</button>
                            <button class="quick-btn" onclick="githubHuntWithChat('openai')" style="border-color: #8b5cf6;">OpenAI</button>
                            <button class="quick-btn" onclick="githubHuntWithChat('firebase')" style="border-color: #8b5cf6;">Firebase</button>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- NETWORK CATEGORY - Network Security & Monitoring -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <div id="category-network" class="tool-category" style="display: none;">
                    <!-- Network Guardian -->
                    <div class="panel-card" style="border: 1px solid #00ff41;">
                        <div class="panel-title" style="color: #00ff41;">🛡️ Network Guardian</div>
                        <div id="networkGuardianStatus" style="margin-bottom: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="color: #666; font-size: 11px;">WiFi: <span id="networkName">Loading...</span></span>
                                <span id="deviceCount" style="color: #00ff41; font-size: 11px;">0 devices</span>
                            </div>
                        </div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="scanNetworkQuickWithChat()" style="flex: 1; border-color: #00ff41;">⚡ Quick</button>
                            <button class="quick-btn" onclick="scanNetworkFullWithChat()" style="flex: 1; background: linear-gradient(135deg, #00ff41, #0abdc6); color: #0a0a0f;">🤖 AI Scan</button>
                        </div>
                        <div class="quick-actions" style="margin-top: 6px;">
                            <button class="quick-btn" onclick="showWhitelistInChat()" style="flex: 1;">📋 Whitelist</button>
                            <button class="quick-btn" onclick="showNetworkHistoryInChat()" style="flex: 1;">📊 History</button>
                        </div>
                    </div>

                    <!-- Monitoring -->
                    <div class="panel-card">
                        <div class="panel-title">📡 Monitoring</div>
                        <div id="monitoringList" style="max-height: 150px; overflow-y: auto;">
                            <div class="tool-item" style="justify-content: space-between;">
                                <span style="color: #666;">No sites monitored</span>
                                <button class="quick-btn" onclick="showAddMonitoring()" style="font-size: 10px; padding: 4px 8px;">+ Add</button>
                            </div>
                        </div>
                        <div id="addMonitoringForm" style="display: none; margin-top: 10px;">
                            <input type="text" id="monitorUrl" placeholder="https://example.com" style="width: 100%; background: #1a1a25; border: 1px solid #2a2a3a; color: #e0e0e0; padding: 8px; margin-bottom: 5px; border-radius: 4px;">
                            <div style="display: flex; gap: 5px;">
                                <button class="quick-btn" onclick="addMonitoringSite()" style="flex: 1;">Add</button>
                                <button class="quick-btn" onclick="hideAddMonitoring()" style="background: #333;">✕</button>
                            </div>
                        </div>
                        <button class="quick-btn" onclick="checkAllMonitoring()" style="width: 100%; margin-top: 8px; background: linear-gradient(135deg, #0abdc6, #00ff41); color: #0a0a0f;">🔄 Refresh</button>
                    </div>

                    <!-- Network Sniffer (compact) -->
                    <div class="panel-card" style="border: 1px solid #ff00ff;">
                        <div class="panel-title" style="color: #ff00ff;">📡 Traffic Sniffer</div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="startPacketCapture()" style="border-color: #ff00ff;">▶️ Start</button>
                            <button class="quick-btn" onclick="stopPacketCapture()" style="border-color: #ff00ff;">⏹️ Stop</button>
                            <button class="quick-btn" onclick="analyzePackets()" style="border-color: #ff00ff;">🔍 Analyze</button>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- SCANNERS CATEGORY - DAST, SAST, Quick Scans -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <div id="category-scanners" class="tool-category" style="display: none;">
                    <!-- Quick Scans -->
                    <div class="panel-card">
                        <div class="panel-title">⚡ Quick Scans</div>
                        <div style="margin-bottom: 8px;">
                            <input type="text" id="quickScanTarget" placeholder="URL or domain to scan" style="width: 100%; background: #1a1a25; border: 1px solid #444; color: #e0e0e0; padding: 8px; border-radius: 4px; font-size: 11px;">
                        </div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="quickScanWithChat('web')">🌐 Web</button>
                            <button class="quick-btn" onclick="quickScanWithChat('recon')">🔍 Recon</button>
                            <button class="quick-btn" onclick="quickScanWithChat('secrets')">🔑 Secrets</button>
                        </div>
                        <div class="quick-actions" style="margin-top: 6px;">
                            <button class="quick-btn" onclick="quickScanWithChat('code')">📝 Code</button>
                            <button class="quick-btn" onclick="quickScanWithChat('github')">🐙 GitHub</button>
                            <button class="quick-btn" onclick="quickScanWithChat('full')" style="background: linear-gradient(135deg, #ff6b6b, #ff0040); color: #0a0a0f;">⚡ Full</button>
                        </div>
                    </div>

                    <!-- DAST & SAST -->
                    <div class="panel-card" style="border: 1px solid #00ff41;">
                        <div class="panel-title" style="color: #00ff41;">🛡️ DAST & SAST</div>
                        <div style="margin-bottom: 8px;">
                            <input type="text" id="dastSastTarget" placeholder="URL (DAST) or /path (SAST)" style="width: 100%; background: #1a1a25; border: 1px solid #00ff41; color: #e0e0e0; padding: 8px; border-radius: 4px; font-size: 11px;">
                        </div>
                        <div style="font-size: 10px; color: #ff6b6b; margin-bottom: 4px;">🔴 DAST</div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="runDASTScan('zap')" style="border-color: #ff6b6b;">ZAP</button>
                            <button class="quick-btn" onclick="runDASTScan('nikto')" style="border-color: #ff6b6b;">Nikto</button>
                            <button class="quick-btn" onclick="runDASTScan('nuclei')" style="border-color: #ff6b6b;">Nuclei</button>
                            <button class="quick-btn" onclick="runDASTScan('sqlmap')" style="border-color: #ff6b6b;">SQL</button>
                        </div>
                        <div style="font-size: 10px; color: #4dabf7; margin: 8px 0 4px 0;">🔵 SAST</div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="runSASTScan('semgrep')" style="border-color: #4dabf7;">Semgrep</button>
                            <button class="quick-btn" onclick="runSASTScan('bandit')" style="border-color: #4dabf7;">Bandit</button>
                            <button class="quick-btn" onclick="runSASTScan('secrets')" style="border-color: #4dabf7;">Secrets</button>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- MOBILE CATEGORY - Mobile App Security -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <div id="category-mobile" class="tool-category" style="display: none;">
                    <!-- MobSF -->
                    <div class="panel-card" style="border: 1px solid #ff6b35;">
                        <div class="panel-title" style="color: #ff6b35;">📱 Mobile App Security</div>
                        <div style="margin-bottom: 10px;">
                            <input type="file" id="mobsfFileInput" accept=".apk,.ipa,.zip" style="display: none;" onchange="handleMobsfUpload(this)">
                            <button class="quick-btn" onclick="document.getElementById('mobsfFileInput').click()" style="width: 100%; border-color: #ff6b35;">📤 Upload APK/IPA</button>
                        </div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="listMobsfScans()" style="border-color: #ff6b35;">📋 Scans</button>
                            <button class="quick-btn" onclick="showMobsfHelp()" style="border-color: #ff6b35;">❓ Help</button>
                        </div>
                        <div id="mobsfStatus" style="margin-top: 8px; font-size: 10px; color: #666;"></div>
                    </div>

                    <!-- AI Debugger -->
                    <div class="panel-card" style="border: 1px solid #e91e63;">
                        <div class="panel-title" style="color: #e91e63;">🐛 AI Debugger</div>
                        <div style="margin-bottom: 10px;">
                            <textarea id="debugCode" placeholder="Paste code to debug..." style="width: 100%; height: 80px; background: #1a1a25; border: 1px solid #e91e63; color: #e0e0e0; padding: 8px; border-radius: 4px; font-size: 11px; font-family: monospace; resize: vertical;"></textarea>
                        </div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="debugCodeWithAI()" style="flex: 1; background: linear-gradient(135deg, #e91e63, #ff6b6b); color: #0a0a0f;">🐛 Debug</button>
                            <button class="quick-btn" onclick="explainCodeWithAI()" style="flex: 1; border-color: #e91e63;">📖 Explain</button>
                        </div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- MORE CATEGORY - Additional Tools -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                <div id="category-more" class="tool-category" style="display: none;">
                    <!-- Scan Stats -->
                    <div class="panel-card">
                        <div class="panel-title">📊 Stats</div>
                        <div id="scanStatsContent" style="font-size: 11px; color: #888;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                                <span>Total Scans:</span><span id="totalScans" style="color: #00ff41;">0</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                                <span>Vulns Found:</span><span id="totalVulns" style="color: #ff6b6b;">0</span>
                            </div>
                            <div style="display: flex; justify-content: space-between;">
                                <span>IP Investigations:</span><span id="totalIPInvestigations" style="color: #0abdc6;">0</span>
                            </div>
                        </div>
                    </div>

                    <!-- Active Tools -->
                    <div class="panel-card">
                        <div class="panel-title">🔧 Active Tools</div>
                        <div id="activeToolsPanel" style="font-size: 10px; color: #666;">No active scans</div>
                    </div>

                    <!-- AI Features -->
                    <div class="panel-card" style="border: 1px solid #ff6b35;">
                        <div class="panel-title" style="color: #ff6b35;">🤖 AI Features</div>
                        <div class="quick-actions">
                            <button class="quick-btn" onclick="generateSecurityReport()" style="border-color: #ff6b35;">📄 Report</button>
                            <button class="quick-btn" onclick="showAIHelp()" style="border-color: #ff6b35;">❓ Help</button>
                        </div>
                    </div>

                    <!-- Scan Progress (hidden by default) -->
                    <div class="panel-card" id="scanProgressPanel" style="display: none; border-color: #ffaa00;">
                        <div class="panel-title" style="color: #ffaa00;">⏳ Scan in Progress</div>
                        <div id="scanProgressContent" style="font-size: 11px;"></div>
                    </div>
                </div>

                <!-- ═══════════════════════════════════════════════════════════ -->
                <!-- LEGACY PANELS (kept for compatibility) -->
                <!-- ═══════════════════════════════════════════════════════════ -->
                
                <!-- Hidden elements for legacy function compatibility -->
                <div id="legacy-elements" style="display: none;">
                    <div id="networkGuardianAlerts"></div>
                    <input type="file" id="mobileFileInput" accept=".apk,.ipa,.zip,.appx" onchange="handleMobileUpload(this.files[0])">
                    <div id="mobileScanProgress"></div>
                    <div id="mobileScanStatus"></div>
                    <div id="mobileScanPercent"></div>
                    <div id="mobileScanBar"></div>
                    <div id="recentMobileScans"></div>
                    <div id="recentMobileScansList"></div>
                    <div id="debugCodeInput"></div>
                    <div id="debugErrorInput"></div>
                    <div id="debugFileInput"></div>
                    <div id="debugFileInfo"></div>
                    <div id="debugFileName"></div>
                    <div id="githubRepoUrl"></div>
                    <div id="toolList"></div>
                    <div id="toolCount">0</div>
                    <div id="aiToolCount">0</div>
                    <div id="findingCount">0</div>
