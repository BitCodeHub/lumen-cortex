                        <strong style="color: #ffa500;">🏛️ WHOIS: ${ip}</strong><br><br>
                        <strong>Organization:</strong> ${whois.organization || 'Unknown'}<br>
                        <strong>Net Range:</strong> ${whois.netRange || 'N/A'}<br>
                        <strong>Net Name:</strong> ${whois.netName || 'N/A'}<br>
                        <strong>Country:</strong> ${whois.country || 'N/A'}<br>
                        ${whois.address ? `<strong>Address:</strong> ${whois.address}<br>` : ''}
                        ${whois.regDate ? `<strong>Registered:</strong> ${whois.regDate}<br>` : ''}
                        ${whois.abuseEmail ? `<strong>Abuse Contact:</strong> ${whois.abuseEmail}<br>` : ''}
                        ${whois.cidr ? `<strong>CIDR:</strong> ${whois.cidr}<br>` : ''}
                    </div>
                `, true);
            } catch (error) {
                addMessage(`❌ WHOIS lookup failed: ${error.message}`, true);
            }
        }
        
        async function quickPortScan() {
            const ip = document.getElementById('ipInvestigatorTarget').value.trim();
            if (!ip) {
                addMessage('❌ Please enter an IP address.', true);
                return;
            }
            
            addMessage(`🚪 <strong>Port Scan (Top 100):</strong> ${ip}`, true);
            document.getElementById('ipInvestigatorStatus').innerHTML = '<span style="color: #ffa500;">🔍 Scanning ports...</span>';
            
            try {
                const response = await fetch('/api/ip-investigator/portscan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ip, quick: true })
                });
                const ports = await response.json();
                
                if (ports.error) {
                    addMessage(`❌ Error: ${ports.error}`, true);
                    document.getElementById('ipInvestigatorStatus').innerHTML = '';
                    return;
                }
                
                const portList = ports.openPorts?.length > 0 
                    ? ports.openPorts.map(p => `<tr><td style="padding: 4px; border-bottom: 1px solid #333;">${p.port}</td><td style="padding: 4px; border-bottom: 1px solid #333;">${p.protocol}</td><td style="padding: 4px; border-bottom: 1px solid #333;">${p.service}</td></tr>`).join('')
                    : '<tr><td colspan="3" style="padding: 10px; color: #888;">No open ports found</td></tr>';
                
                addMessage(`
                    <div style="background: #1a1a25; padding: 12px; border-radius: 8px; border: 1px solid #00ff41;">
                        <strong style="color: #00ff41;">🚪 Port Scan: ${ip}</strong><br>
                        <span style="color: #888; font-size: 10px;">${ports.scanType || 'Quick scan'} | Host: ${ports.hostUp ? 'Up' : 'Down'} | Latency: ${ports.latency || 'N/A'}</span><br><br>
                        <table style="width: 100%; font-size: 11px; border-collapse: collapse;">
                            <tr style="color: #0abdc6;"><th style="text-align: left; padding: 4px;">Port</th><th style="text-align: left; padding: 4px;">Proto</th><th style="text-align: left; padding: 4px;">Service</th></tr>
                            ${portList}
                        </table>
                        <br><strong style="color: #00ff41;">Total Open: ${ports.totalOpen || 0}</strong>
                    </div>
                `, true);
                document.getElementById('ipInvestigatorStatus').innerHTML = `<span style="color: #00ff41;">✅ ${ports.totalOpen || 0} ports open</span>`;
            } catch (error) {
                addMessage(`❌ Port scan failed: ${error.message}`, true);
                document.getElementById('ipInvestigatorStatus').innerHTML = '';
            }
        }
        
        async function showIPHistory() {
            try {
                const response = await fetch('/api/ip-investigator/history?limit=10');
                const history = await response.json();
                
                if (history.length === 0) {
                    addMessage(`
                        <div style="background: #1a1a25; padding: 12px; border-radius: 8px; border: 1px solid #ff6b6b;">
                            <strong style="color: #ff6b6b;">📋 IP Investigation History</strong><br><br>
                            <span style="color: #888;">No investigations yet. Enter an IP and click "Full Investigation".</span>
                        </div>
                    `, true);
                    return;
                }
                
                const rows = history.map(h => `
                    <tr style="cursor: pointer;" onclick="document.getElementById('ipInvestigatorTarget').value='${h.ip}'; investigateIP();">
                        <td style="padding: 6px; border-bottom: 1px solid #333;">${h.ip}</td>
                        <td style="padding: 6px; border-bottom: 1px solid #333;">${h.location}</td>
                        <td style="padding: 6px; border-bottom: 1px solid #333;">${h.riskAssessment}</td>
                    </tr>
                `).join('');
                
                addMessage(`
                    <div style="background: #1a1a25; padding: 12px; border-radius: 8px; border: 1px solid #ff6b6b;">
                        <strong style="color: #ff6b6b;">📋 Recent IP Investigations</strong><br><br>
                        <table style="width: 100%; font-size: 11px; border-collapse: collapse;">
                            <tr style="color: #0abdc6;"><th style="text-align: left; padding: 6px;">IP</th><th style="text-align: left; padding: 6px;">Location</th><th style="text-align: left; padding: 6px;">Risk</th></tr>
                            ${rows}
                        </table>
                        <br><span style="color: #666; font-size: 10px;">Click any row to re-investigate</span>
                    </div>
                `, true);
            } catch (error) {
                addMessage(`❌ Failed to load history: ${error.message}`, true);
            }
        }
        
