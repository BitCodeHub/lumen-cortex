<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumen Cortex - AI Security Scanner</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00ff41;
            --secondary: #0abdc6;
            --danger: #ff0040;
            --warning: #ffaa00;
            --bg-dark: #0a0a0f;
            --bg-card: #12121a;
            --bg-input: #1a1a25;
            --text: #e0e0e0;
            --text-dim: #666;
            --border: #2a2a3a;
            --glow: rgba(0, 255, 65, 0.3);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            font-family: 'JetBrains Mono', monospace;
            background: var(--bg-dark);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            width: 100%;
            max-width: 100vw;
        }

        /* Matrix rain background */
        .matrix-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            opacity: 0.08;
        }

        /* Scanlines effect */
        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1000;
            background: repeating-linear-gradient(
                0deg,
                rgba(0, 0, 0, 0.1),
                rgba(0, 0, 0, 0.1) 1px,
                transparent 1px,
                transparent 2px
            );
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 20px 30px;
            width: 100%;
            position: relative;
            z-index: 1;
        }

        /* Header */
        header {
            text-align: center;
            padding: 20px 0;
            border-bottom: 1px solid var(--border);
            margin-bottom: 20px;
        }

        .logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 3rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 40px var(--glow);
            letter-spacing: 4px;
            animation: glitch 3s infinite;
        }

        @keyframes glitch {
            0%, 90%, 100% { transform: translate(0); }
            92% { transform: translate(-2px, 1px); }
            94% { transform: translate(2px, -1px); }
            96% { transform: translate(-1px, 2px); }
            98% { transform: translate(1px, -2px); }
        }

        .tagline {
            color: var(--secondary);
            margin-top: 10px;
            font-size: 0.9rem;
            letter-spacing: 2px;
        }

        .footnote {
            color: var(--text-dim);
            margin-top: 15px;
            font-size: 0.75rem;
            letter-spacing: 1px;
            opacity: 0.7;
        }

        /* Main grid */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 25px;
            align-items: start;
            width: 100%;
        }

        /* Chat panel */
        .chat-panel {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            height: 70vh;
        }

        .chat-header {
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .status-indicator {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--primary);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; box-shadow: 0 0 10px var(--primary); }
            50% { opacity: 0.5; box-shadow: 0 0 5px var(--primary); }
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .message {
            margin-bottom: 20px;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message.user {
            text-align: right;
        }

        .message-content {
            display: inline-block;
            padding: 12px 18px;
            border-radius: 12px;
            max-width: 80%;
        }

        .message.user .message-content {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: var(--bg-dark);
        }

        .message.ai .message-content {
            background: var(--bg-input);
            border: 1px solid var(--border);
        }

        .message-label {
            font-size: 0.7rem;
            color: var(--text-dim);
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .chat-input-area {
            padding: 20px;
            border-top: 1px solid var(--border);
        }

        .input-wrapper {
            display: flex;
            gap: 10px;
        }

        .chat-input {
            flex: 1;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            color: var(--text);
            font-family: inherit;
            font-size: 0.95rem;
            outline: none;
            transition: all 0.3s;
        }

        .chat-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 20px var(--glow);
        }

        .chat-input::placeholder {
            color: var(--text-dim);
        }

        .send-btn {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: none;
            border-radius: 8px;
            padding: 15px 25px;
            color: var(--bg-dark);
            font-family: inherit;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .send-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px var(--glow);
        }

        .send-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Voice button */
        .voice-btn {
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            font-size: 1.2em;
            cursor: pointer;
            transition: all 0.3s;
        }

        .voice-btn:hover {
            border-color: var(--secondary);
            box-shadow: 0 0 15px rgba(10, 189, 198, 0.3);
        }

        .voice-btn.listening {
            background: linear-gradient(135deg, #ff0040, #ff4444);
            animation: pulse-voice 1s infinite;
            border-color: #ff0040;
        }

        @keyframes pulse-voice {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        /* Input hints */
        .input-hints {
            display: flex;
            gap: 8px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .input-hints span {
            background: var(--bg-input);
            border: 1px solid var(--border);
            padding: 5px 10px;
            border-radius: 15px;
            font-size: 0.75em;
            cursor: pointer;
            transition: all 0.2s;
        }

        .input-hints span:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .input-hints span.active {
            background: var(--primary);
            color: var(--bg-dark);
            border-color: var(--primary);
        }

        /* AI Message styling */
        .message.ai .message-content {
            background: var(--bg-input);
            border: 1px solid var(--border);
        }

        .message.ai .message-content pre {
            background: rgba(0, 0, 0, 0.3);
            padding: 12px;
            border-radius: 6px;
            overflow-x: auto;
            margin: 10px 0;
        }

        .message.ai .message-content code {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85em;
        }

        .message.ai .message-content h1,
        .message.ai .message-content h2,
        .message.ai .message-content h3 {
            color: var(--secondary);
            margin-top: 15px;
        }

        .message.ai .message-content ul,
        .message.ai .message-content ol {
            padding-left: 20px;
        }

        .message.ai .message-content a {
            color: var(--secondary);
        }

        /* Typing indicator */
        .typing-indicator {
            display: flex;
            gap: 4px;
            padding: 10px;
        }

        .typing-indicator span {
            width: 8px;
            height: 8px;
            background: var(--secondary);
            border-radius: 50%;
            animation: typing 1.4s infinite ease-in-out;
        }

        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
            30% { transform: translateY(-10px); opacity: 1; }
        }

        /* Code highlighting in findings */
        .finding-location {
            background: rgba(255, 0, 64, 0.1);
            border-left: 3px solid #ff0040;
            padding: 10px;
            margin: 10px 0;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85em;
        }

        .finding-location .file {
            color: var(--secondary);
        }

        .finding-location .line {
            color: #ff0040;
        }

        /* Side panel */
        .side-panel {
            display: flex;
            flex-direction: column;
            gap: 15px;
            max-height: 80vh;
            overflow-y: auto;
            padding-right: 5px;
            position: sticky;
            top: 20px;
        }
        
        .side-panel::-webkit-scrollbar {
            width: 6px;
        }
        
        .side-panel::-webkit-scrollbar-track {
            background: var(--bg-dark);
        }
        
        .side-panel::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }
        
        .side-panel::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

        .panel-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 15px;
        }

        .panel-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9rem;
            color: var(--primary);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 2px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .panel-title::before {
            content: '▸';
            color: var(--secondary);
        }

        /* Active tools */
        .tool-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .tool-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            background: var(--bg-input);
            border-radius: 6px;
            font-size: 0.85rem;
        }

        .tool-item.ai-powered {
            border-left: 2px solid var(--secondary);
        }

        .ai-badge {
            font-size: 0.65rem;
            background: linear-gradient(135deg, var(--secondary), #8b5cf6);
            color: var(--bg-dark);
            padding: 2px 6px;
            border-radius: 10px;
            font-weight: 700;
            margin-left: auto;
        }

        .tool-status {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .tool-status.running {
            background: var(--warning);
            animation: pulse 1s infinite;
        }

        .tool-status.success {
            background: var(--primary);
        }

        .tool-status.error {
            background: var(--danger);
        }

        .tool-status.pending {
            background: var(--text-dim);
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .stat-item {
            text-align: center;
            padding: 15px;
            background: var(--bg-input);
            border-radius: 6px;
        }

        .stat-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.5rem;
            color: var(--primary);
        }

        .stat-label {
            font-size: 0.7rem;
            color: var(--text-dim);
            text-transform: uppercase;
            margin-top: 5px;
        }

        /* Risk indicator */
        .risk-indicator {
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .risk-indicator.low {
            background: rgba(0, 255, 65, 0.1);
            border: 1px solid var(--primary);
            color: var(--primary);
        }

        .risk-indicator.medium {
            background: rgba(255, 170, 0, 0.1);
            border: 1px solid var(--warning);
            color: var(--warning);
        }

        .risk-indicator.high {
            background: rgba(255, 0, 64, 0.1);
            border: 1px solid var(--danger);
            color: var(--danger);
        }

        /* Quick actions */
        .quick-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .quick-btn {
            padding: 8px 12px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 20px;
            color: var(--text);
            font-family: inherit;
            font-size: 0.75rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .quick-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .quick-btn.attack-quick {
            border-color: #ff0040;
            color: #ff6666;
        }

        .quick-btn.attack-quick:hover {
            border-color: #ff0040;
            background: rgba(255, 0, 64, 0.2);
            color: #ff0040;
        }

        .attack-btn {
            background: linear-gradient(135deg, #0abdc6, #00ff41) !important;
        }

        .attack-btn:hover {
            box-shadow: 0 0 30px rgba(255, 0, 64, 0.5) !important;
        }

        /* Results panel */
        .results-panel {
            margin-top: 20px;
            max-height: 300px;
            overflow-y: auto;
        }

        .result-item {
            padding: 10px;
            margin-bottom: 8px;
            background: var(--bg-input);
            border-radius: 6px;
            border-left: 3px solid var(--primary);
            font-size: 0.8rem;
        }

        .result-item.warning {
            border-left-color: var(--warning);
        }

        .result-item.error {
            border-left-color: var(--danger);
        }

        /* Loading animation */
        .loading {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .loading-bar {
            flex: 1;
            height: 4px;
            background: var(--bg-input);
            border-radius: 2px;
            overflow: hidden;
        }

        .loading-progress {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            animation: loading 2s infinite;
        }

        @keyframes loading {
            0% { width: 0%; }
            50% { width: 70%; }
            100% { width: 100%; }
        }

        /* ASCII art header */
        .ascii-art {
            font-size: 0.6rem;
            color: var(--primary);
            opacity: 0.5;
            white-space: pre;
            text-align: center;
            margin-bottom: 10px;
        }

        /* Responsive */
        @media (max-width: 1000px) {
            .main-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
