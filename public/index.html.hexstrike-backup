                    if (finding.details) {
                        const details = Array.isArray(finding.details) ? finding.details : [finding.details];
                        html += `<div style="color: #888; font-size: 0.85em; margin-top: 5px;">`;
                        html += details.slice(0, 3).join('<br>');
                        html += `</div>`;
                    }
                    if (finding.tool) {
                        html += `<div style="color: #666; font-size: 0.75em; margin-top: 5px;">Tool: ${finding.tool}</div>`;
                    }
                    html += `</div>`;
                }
                html += `</div>`;
            }

            // Recommendations
            if (a.recommendations && a.recommendations.length > 0) {
                html += `<div style="background: rgba(10,189,198,0.1); border-radius: 8px; padding: 15px; margin-bottom: 15px;">`;
                html += `<div style="color: #0abdc6; font-weight: bold; margin-bottom: 10px;">💡 Remediation Recommendations</div>`;
                html += `<ul style="margin: 0; padding-left: 20px; color: #aaa;">`;
                for (const rec of a.recommendations) {
                    html += `<li style="margin: 5px 0;">${rec}</li>`;
                }
                html += `</ul>`;
                html += `</div>`;
            }

            // Tool Results
            html += `<div style="background: rgba(0,0,0,0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px;">`;
            html += `<div style="color: #888; font-weight: bold; margin-bottom: 10px;">🔧 Security Tools Used</div>`;
            for (const result of (data.results || [])) {
                const icon = result.status === 'success' ? '✅' : result.status === 'warning' ? '⚠️' : result.status === 'vuln_found' ? '💀' : '❌';
                const statusColor = result.status === 'vuln_found' ? '#ff0040' : result.status === 'success' ? '#00ff41' : result.status === 'warning' ? '#ffaa00' : '#666';
                html += `<div style="display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #222;">`;
                html += `<span>${icon} ${result.name || result.tool}</span>`;
                html += `<span style="color: ${statusColor};">${result.status}${result.findingsCount ? ` (${result.findingsCount} vulns)` : ''}</span>`;
                html += `</div>`;
            }
            html += `</div>`;

            // Stats Footer
            html += `<div style="display: flex; justify-content: space-around; padding: 15px; background: rgba(0,0,0,0.2); border-radius: 8px;">`;
            html += `<div style="text-align: center;"><div style="font-size: 1.5em; color: #ff0040;">${data.totalVulns || 0}</div><div style="font-size: 0.7em; color: #666;">Vulns Found</div></div>`;
            html += `<div style="text-align: center;"><div style="font-size: 1.5em; color: #ffaa00;">${(data.results || []).length}</div><div style="font-size: 0.7em; color: #666;">Tools Run</div></div>`;
            html += `<div style="text-align: center;"><div style="font-size: 1.5em; color: #0abdc6;">${Math.round(data.duration || 0)}s</div><div style="font-size: 0.7em; color: #666;">Duration</div></div>`;
            html += `</div>`;

            // Detailed Tool Results (expanded by default for full report)
            html += `<details open style="margin-top: 15px;">`;
            html += `<summary style="cursor: pointer; color: #ff0040; font-weight: bold;">📋 Detailed Tool Output (${(data.results || []).length} tools)</summary>`;
            html += `<div style="max-height: 600px; overflow-y: auto; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 8px; margin-top: 10px;">`;
            for (const result of (data.results || [])) {
                const statusIcon = result.status === 'vuln_found' ? '💀' : result.status === 'success' ? '✅' : result.status === 'error' ? '❌' : '⚠️';
                const borderColor = result.status === 'vuln_found' ? '#ff0040' : result.status === 'success' ? '#00ff41' : '#ffaa00';
                
                html += `<div style="margin-bottom: 15px; padding: 12px; background: rgba(0,0,0,0.2); border-left: 3px solid ${borderColor}; border-radius: 4px;">`;
                html += `<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">`;
                html += `<strong style="color: #fff; font-size: 1em;">${statusIcon} ${result.name || result.tool}</strong>`;
                html += `<span style="color: ${borderColor}; font-size: 0.8em;">${result.findingsCount ? result.findingsCount + ' findings' : result.status}</span>`;
                html += `</div>`;
                
                if (result.output && result.output.trim()) {
                    html += `<div style="background: rgba(0,0,0,0.3); padding: 8px; border-radius: 4px; margin-top: 8px;">`;
                    html += `<pre style="white-space: pre-wrap; color: #aaa; margin: 0; font-size: 0.8em; max-height: 300px; overflow-y: auto;">${escapeHtml(result.output.substring(0, 5000))}${result.output.length > 5000 ? '\n\n... (showing first 5000 chars)' : ''}</pre>`;
                    html += `</div>`;
                }
                
                if (result.error) {
                    html += `<div style="color: #ff6666; font-size: 0.8em; margin-top: 5px;">⚠️ Error: ${escapeHtml(result.error.substring(0, 500))}</div>`;
                }
                html += `</div>`;
            }
            html += `</div></details>`;
            
            // Helper function for HTML escaping
            function escapeHtml(text) {
                return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
            }

            html += `</div>`;
            return html;
        }

        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        });

        // ═══════════════════════════════════════════════════════════════
        // MONITORING FUNCTIONS (UptimeRobot Integration)
        // ═══════════════════════════════════════════════════════════════
        
        function showAddMonitoring() {
            document.getElementById('addMonitoringForm').style.display = 'block';
        }
        
        function hideAddMonitoring() {
            document.getElementById('addMonitoringForm').style.display = 'none';
        }
        
        async function addMonitoringSite() {
            const url = document.getElementById('monitorUrl').value;
            if (!url) return alert('Please enter a URL');
            
            try {
                const res = await fetch('/api/uptimerobot/monitors', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url, name: url })
                });
                const data = await res.json();
                if (data.success) {
                    document.getElementById('monitorUrl').value = '';
                    hideAddMonitoring();
                    loadMonitoringSites();
                } else if (data.error?.includes('API key')) {
                    alert('⚠️ UptimeRobot not configured.\\n\\nGo to https://uptimerobot.com to get your API key, then run:\\ncurl -X POST http://localhost:3333/api/uptimerobot/setup -H "Content-Type: application/json" -d \'{"apiKey": "YOUR_KEY"}\'');
                } else {
                    alert('Error: ' + (data.error || 'Failed to add monitor'));
                }
            } catch (e) {
                alert('Error: ' + e.message);
            }
        }
        
        async function loadMonitoringSites() {
            const container = document.getElementById('monitoringList');
            
            try {
                const res = await fetch('/api/uptimerobot/monitors');
                const data = await res.json();
                
                if (!data.configured) {
                    container.innerHTML = `<div class="tool-item" style="flex-direction: column; align-items: flex-start; gap: 8px;">
                        <span style="color: #ffaa00;">⚠️ UptimeRobot not configured</span>
                        <span style="color: #666; font-size: 11px;">Get API key from uptimerobot.com</span>
                        <button class="quick-btn" onclick="showAddMonitoring()" style="font-size: 10px; padding: 4px 8px;">+ Add Site Anyway</button>
                    </div>`;
                    return;
                }
                
                if (!data.monitors || data.monitors.length === 0) {
                    container.innerHTML = `<div class="tool-item" style="justify-content: space-between;">
                        <span style="color: #666;">No sites monitored</span>
                        <button class="quick-btn" onclick="showAddMonitoring()" style="font-size: 10px; padding: 4px 8px;">+ Add</button>
                    </div>`;
                    return;
                }
                
                let html = '';
                for (const monitor of data.monitors) {
                    const statusColor = monitor.status === 'online' ? '#00ff41' : monitor.status === 'down' ? '#ff0040' : '#ffaa00';
                    const statusIcon = monitor.status === 'online' ? '🟢' : monitor.status === 'down' ? '🔴' : '🟡';
                    const responseTime = monitor.responseTime ? `${monitor.responseTime}ms` : '-';
                    const avgTime = monitor.avgResponseTime ? `avg ${monitor.avgResponseTime}ms` : '';
                    const uptime24h = monitor.uptime?.day ? `${monitor.uptime.day}%` : '-';
                    const uptime7d = monitor.uptime?.week ? `${monitor.uptime.week}%` : '-';
                    const uptime30d = monitor.uptime?.month ? `${monitor.uptime.month}%` : '-';
                    const lastChecked = monitor.lastChecked ? new Date(monitor.lastChecked).toLocaleTimeString() : '-';
                    
                    // SSL info (only show if we have valid expiry data)
                    let sslInfo = '';
                    if (monitor.ssl && monitor.ssl.daysUntilExpiry !== null && monitor.ssl.daysUntilExpiry !== undefined) {
                        const sslColor = monitor.ssl.daysUntilExpiry > 30 ? '#00ff41' : monitor.ssl.daysUntilExpiry > 7 ? '#ffaa00' : '#ff0040';
                        sslInfo = `<div style="font-size: 9px; color: ${sslColor};">🔒 SSL: ${monitor.ssl.daysUntilExpiry}d left</div>`;
                    }
                    
                    // Recent incidents
                    let incidentInfo = '';
                    const downLogs = monitor.logs?.filter(l => l.type === 'down') || [];
                    if (downLogs.length > 0) {
                        incidentInfo = `<div style="font-size: 9px; color: #ff0040;">⚠️ ${downLogs.length} incident(s)</div>`;
                    }
                    
                    html += `<div class="tool-item" style="flex-direction: column; padding: 10px 0; border-bottom: 1px solid #222; gap: 6px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                            <span style="font-size: 12px; font-weight: bold;">${statusIcon} ${monitor.friendlyName}</span>
                            <div style="display: flex; align-items: center; gap: 6px;">
                                <span style="color: ${statusColor}; font-size: 11px; font-weight: bold;">${monitor.status.toUpperCase()}</span>
                                <button onclick="deleteMonitor(${monitor.id}, '${monitor.friendlyName}')" style="background: transparent; border: none; color: #ff0040; cursor: pointer; font-size: 12px; padding: 2px;" title="Delete">🗑️</button>
                            </div>
                        </div>
                        <div style="font-size: 10px; color: #666; word-break: break-all;">${monitor.url}</div>
                        <div style="display: flex; justify-content: space-between; font-size: 10px; color: #888; margin-top: 4px;">
                            <span>⚡ ${responseTime} ${avgTime ? `(${avgTime})` : ''}</span>
                            <span>🕐 ${lastChecked}</span>
                        </div>
                        <div style="display: flex; gap: 10px; font-size: 9px; color: #0abdc6;">
                            <span title="24h uptime">24h: ${uptime24h}</span>
                            <span title="7 day uptime">7d: ${uptime7d}</span>
                            <span title="30 day uptime">30d: ${uptime30d}</span>
                        </div>
                        ${sslInfo}
                        ${incidentInfo}
                    </div>`;
                }
                html += `<button class="quick-btn" onclick="showAddMonitoring()" style="width: 100%; margin-top: 8px; font-size: 10px;">+ Add Site</button>`;
                container.innerHTML = html;
            } catch (e) {
                container.innerHTML = `<div class="tool-item" style="color: #ff0040;">Error loading monitors: ${e.message}</div>`;
            }
        }
        
        async function checkAllMonitoring() {
            const btn = event.target;
            btn.textContent = '⏳ Refreshing...';
            btn.disabled = true;
            
            // UptimeRobot handles checking automatically, we just refresh the display
            await loadMonitoringSites();
            
            btn.textContent = '🔄 Refresh';
            btn.disabled = false;
        }
        
        async function deleteMonitor(id, name) {
            if (!confirm(`Delete monitor "${name}"?`)) return;
            
            try {
                const res = await fetch(`/api/uptimerobot/monitors/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) {
                    loadMonitoringSites();
                } else {
                    alert('Error: ' + (data.error || 'Failed to delete'));
                }
            } catch (e) {
                alert('Error: ' + e.message);
            }
        }
        
        // Load monitoring on page load
        loadMonitoringSites();
        
        // ═══════════════════════════════════════════════════════════════
        // AI REPORT FUNCTIONS (Dedicated Report Section)
        // ═══════════════════════════════════════════════════════════════
        
        let currentReportData = null;
        
        async function generateAIReport() {
            if (!currentScanId) return alert('No scan to generate report for');
            
            const btn = document.getElementById('generateReportBtn');
            const statusEl = document.getElementById('aiReportStatus');
            btn.textContent = '⏳ Generating...';
            btn.disabled = true;
            statusEl.innerHTML = '🔄 AI is analyzing your scan results...';
            
            // Show report section with loading state
            document.getElementById('reportSection').style.display = 'block';
            document.getElementById('reportContent').innerHTML = `
                <div style="text-align: center; padding: 60px; color: #0abdc6;">
                    <div style="font-size: 4em; margin-bottom: 20px; animation: pulse 2s infinite;">🧠</div>
                    <p style="font-size: 1.2em;">AI is generating your security assessment...</p>
                    <p style="color: #666; margin-top: 10px;">This may take 15-30 seconds</p>
                </div>
            `;
            
            // Scroll to report section
            document.getElementById('reportSection').scrollIntoView({ behavior: 'smooth' });
            
            try {
                const res = await fetch(`/api/scan/${currentScanId}/report`);
                const data = await res.json();
                currentReportData = data;
                
                // Update status
                if (data.aiPowered) {
                    statusEl.innerHTML = '✅ AI Report Generated!';
                } else {
                    statusEl.innerHTML = '⚠️ Basic report (configure Claude API for AI)';
                }
                
                // Get scan info for header
                const scanRes = await fetch(`/api/scan/${currentScanId}`);
                const scanData = await scanRes.json();
                
                document.getElementById('reportTarget').textContent = `Target: ${scanData.target || 'Unknown'}`;
                document.getElementById('reportTimestamp').textContent = `Generated: ${new Date().toLocaleString()}`;
                
                // Format and display report
                const formattedReport = formatReportContent(data.report, data.aiPowered);
                document.getElementById('reportContent').innerHTML = formattedReport;
                
            } catch (error) {
                document.getElementById('reportContent').innerHTML = `
                    <div style="text-align: center; padding: 40px; color: #ff0040;">
                        <div style="font-size: 3em; margin-bottom: 20px;">❌</div>
                        <p>Failed to generate report: ${error.message}</p>
                    </div>
                `;
            }
            
            btn.textContent = '📋 Generate Scan Results';
            btn.disabled = false;
        }
        
        function formatReportContent(report, aiPowered) {
            if (!report) return '<p style="color: #666;">No report content available.</p>';
            
            // Convert markdown-like formatting to HTML
            let html = report
                // Headers
                .replace(/### (.*?)(?:\n|$)/g, '<h4 style="color: #ffaa00; margin: 20px 0 10px; font-size: 1.1em;">$1</h4>')
                .replace(/## (.*?)(?:\n|$)/g, '<h3 style="color: #0abdc6; margin: 25px 0 15px; font-size: 1.3em; border-bottom: 1px solid #2a2a3a; padding-bottom: 10px;">$1</h3>')
                .replace(/# (.*?)(?:\n|$)/g, '<h2 style="color: #00ff41; margin: 30px 0 20px; font-size: 1.5em;">$1</h2>')
                // Bold
                .replace(/\*\*(.*?)\*\*/g, '<strong style="color: #fff;">$1</strong>')
                // Lists
                .replace(/^- (.*?)$/gm, '<li style="margin: 5px 0; margin-left: 20px;">$1</li>')
                .replace(/^\d+\. (.*?)$/gm, '<li style="margin: 5px 0; margin-left: 20px;">$1</li>')
                // Code blocks
                .replace(/`([^`]+)`/g, '<code style="background: #1a1a25; padding: 2px 6px; border-radius: 3px; color: #00ff41;">$1</code>')
                // Line breaks
                .replace(/\n\n/g, '</p><p style="margin: 15px 0;">')
                .replace(/\n/g, '<br>');
            
            // Wrap in paragraph
            html = '<p style="margin: 15px 0;">' + html + '</p>';
            
            // Add AI badge
            const badge = aiPowered 
                ? '<div style="display: inline-block; background: linear-gradient(135deg, #00ff41, #0abdc6); color: #0a0a0f; padding: 5px 15px; border-radius: 20px; font-weight: bold; margin-bottom: 20px;">🤖 AI-Powered Analysis</div>'
                : '<div style="display: inline-block; background: #333; color: #ffaa00; padding: 5px 15px; border-radius: 20px; font-weight: bold; margin-bottom: 20px;">⚠️ Basic Analysis (Configure Claude API for AI)</div>';
            
            return badge + html;
        }
        
        function closeReportSection() {
            document.getElementById('reportSection').style.display = 'none';
        }
        
        async function exportPDF() {
            if (!currentScanId) return alert('No scan to export');
            
            // For now, open HTML export (can be printed to PDF)
            // Later: integrate proper PDF generation
            const win = window.open(`/api/scan/${currentScanId}/export/html`, '_blank');
            
            // Show instructions
            alert('📄 HTML Report opened in new tab.\\n\\nTo save as PDF:\\n1. Press Ctrl+P (or Cmd+P on Mac)\\n2. Select "Save as PDF"\\n3. Click Save');
        }
        
        async function exportHTML() {
            if (!currentScanId) return alert('No scan to export');
            window.open(`/api/scan/${currentScanId}/export/html`, '_blank');
        }
        
        // Show AI report panel when scan completes
        function showAIReportPanel() {
            document.getElementById('aiReportPanel').style.display = 'block';
        }
        
        // Hook into scan completion
        const originalUpdateScanUI = typeof updateScanUI === 'function' ? updateScanUI : null;
        if (originalUpdateScanUI) {
            updateScanUI = function(data) {
                originalUpdateScanUI(data);
                if (data.status === 'complete') {
                    showAIReportPanel();
                }
            };
        }
    </script>
</body>
